<Window x:Class="MofCoordinateDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MOF Coordinate Matrix Viewer"
        Width="1580"
        Height="980"
        MinWidth="1240"
        MinHeight="780"
        Background="#0B1120">
  <Grid Margin="14">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="355"/>
      <ColumnDefinition Width="14"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Background="#111827"
            BorderBrush="#243244"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <TextBlock Text="Coordinate Input"
                     FontSize="22"
                     FontWeight="Bold"
                     Foreground="#F8FAFC"/>
          <TextBlock Text="AK1, Cell, Scanner, DOE Beam selection"
                     Foreground="#94A3B8"
                     Margin="0,3,0,12"/>

          <TextBlock Text="Board / Align" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Board X"/><TextBox x:Name="BoardXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Board Y"/><TextBox x:Name="BoardYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="AK Margin X"/><TextBox x:Name="AkMarginXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="AK Margin Y"/><TextBox x:Name="AkMarginYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Home Stage Y"/><TextBox x:Name="HomeStageYBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Forward Y Sign"/><TextBox x:Name="ForwardTransportSignYBox"/></StackPanel>
          </UniformGrid>

          <TextBlock Text="Review Camera" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Center X"/><TextBox x:Name="ReviewCenterXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Center Y"/><TextBox x:Name="ReviewCenterYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="U0"/><TextBox x:Name="U0Box"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="V0"/><TextBox x:Name="V0Box"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Scale X"/><TextBox x:Name="ScaleXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Scale Y"/><TextBox x:Name="ScaleYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="AK1 U"/><TextBox x:Name="Ak1UBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="AK1 V"/><TextBox x:Name="Ak1VBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Theta deg"/><TextBox x:Name="ThetaBox"/></StackPanel>
          </UniformGrid>

          <TextBlock Text="Cell / Pattern" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="First X"/><TextBox x:Name="CellFirstXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="First Y"/><TextBox x:Name="CellFirstYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Pitch X"/><TextBox x:Name="CellPitchXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Pitch Y"/><TextBox x:Name="CellPitchYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Pattern Off X"/><TextBox x:Name="PatternOffsetXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Pattern Off Y"/><TextBox x:Name="PatternOffsetYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Columns"/><TextBox x:Name="CellColumnsBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Rows"/><TextBox x:Name="CellRowsBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Cell Block Cols"/><TextBox x:Name="CellBlockColumnsBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Cell Block Rows"/><TextBox x:Name="CellBlockRowsBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Block Pitch X"/><TextBox x:Name="CellBlockPitchXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Block Pitch Y"/><TextBox x:Name="CellBlockPitchYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Selected Cell#"/><TextBox x:Name="SelectedCellBlockBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Selected Col"/><TextBox x:Name="SelectedCellColumnBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Selected Row"/><TextBox x:Name="SelectedCellRowBox"/></StackPanel>
          </UniformGrid>

          <TextBlock Text="Scanner / DOE" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Head Count"/><TextBox x:Name="ScannerCountBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Highlight Heads"/><TextBox x:Name="HighlightHeadsBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="H1 Initial Stage X"/><TextBox x:Name="FirstScannerInitialXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="H1 Initial Stage Y"/><TextBox x:Name="FirstScannerInitialYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Camera → H1 Off X"/><TextBox x:Name="CameraToScannerOffsetXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Camera → H1 Off Y"/><TextBox x:Name="CameraToScannerOffsetYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Origin Tolerance"/><TextBox x:Name="ScannerOriginToleranceBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Pitch X"/><TextBox x:Name="ScannerPitchXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Even Y Offset"/><TextBox x:Name="EvenYOffsetBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Process Area Half X"/><TextBox x:Name="FieldHalfXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Process Area Half Y"/><TextBox x:Name="FieldHalfYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Review Head"/><TextBox x:Name="ReviewBasisHeadBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="DOE Beam 1-16"/><TextBox x:Name="ReviewBasisBeamBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="DOE Pitch X"/><TextBox x:Name="DoePitchXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="DOE Pitch Y"/><TextBox x:Name="DoePitchYBox"/></StackPanel>
          </UniformGrid>
          <UniformGrid Columns="2" Margin="0,0,0,10">
            <Button x:Name="SelectAllScannersButton"
                    Height="34"
                    Margin="0,0,5,0"
                    Content="All Scanner Select"
                    Click="SelectAllScannersButton_Click"/>
            <Button x:Name="ClearScannerSelectionButton"
                    Height="34"
                    Margin="5,0,0,0"
                    Content="Clear Scanner"
                    Click="ClearScannerSelectionButton_Click"/>
          </UniformGrid>

          <TextBlock Text="Dynamic Review Correction" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,14">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Offset Global X"/><TextBox x:Name="OffsetXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Offset Global Y"/><TextBox x:Name="OffsetYBox"/></StackPanel>
          </UniformGrid>

          <Button x:Name="GenerateButton"
                  Height="40"
                  Content="Generate / Refresh"
                  FontWeight="Bold"
                  Click="GenerateButton_Click"/>
          <Button x:Name="OpenConfigButton"
                  Height="36"
                  Margin="0,8,0,0"
                  Content="Open CSV Template in Excel"
                  Click="OpenConfigButton_Click"/>
          <Button x:Name="LoadConfigButton"
                  Height="36"
                  Margin="0,6,0,0"
                  Content="Load Saved CSV Config"
                  Click="LoadConfigButton_Click"/>
          <Button x:Name="ReloadConfigButton"
                  Height="36"
                  Margin="0,6,0,0"
                  Content="Reload Current CSV"
                  Click="ReloadConfigButton_Click"/>
          <Button x:Name="SaveConfigButton"
                  Height="36"
                  Margin="0,6,0,0"
                  Content="Save Current CSV"
                  Click="SaveConfigButton_Click"/>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="2.1*"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="1.7*"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="92"/>
      </Grid.RowDefinitions>

      <Border Background="#111827" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock x:Name="SummaryText"
                     FontSize="15"
                     Foreground="#CBD5E1"
                     Margin="0,0,0,8"/>
          <ScrollViewer x:Name="LayoutScrollViewer"
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto"
                        PreviewMouseWheel="LayoutScrollViewer_PreviewMouseWheel">
            <Canvas x:Name="LayoutCanvas"
                    Width="1280"
                    Height="520"
                    Background="#0F172A"/>
          </ScrollViewer>
        </Grid>
      </Border>

      <Border Grid.Row="2" Background="#111827" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="8">
        <TabControl>
          <TabItem Header="Design 2D Matrix">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="MatrixScrollViewer_PreviewMouseWheel">
              <Canvas x:Name="DesignMatrixCanvas" Background="#0F172A"/>
            </ScrollViewer>
          </TabItem>
          <TabItem Header="Process Gx/Gy 2D Matrix">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="MatrixScrollViewer_PreviewMouseWheel">
              <Canvas x:Name="ProcessMatrixCanvas" Background="#0F172A"/>
            </ScrollViewer>
          </TabItem>
          <TabItem Header="Review Camera 2D Matrix">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="MatrixScrollViewer_PreviewMouseWheel">
              <Canvas x:Name="ReviewMatrixCanvas" Background="#0F172A"/>
            </ScrollViewer>
          </TabItem>
          <TabItem Header="DOE 16 Matrix">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="12">
                <TextBlock Text="DOE 16 Beam Matrix"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#F8FAFC"
                           Margin="0,0,0,8"/>
                <UniformGrid x:Name="DoeMatrixPanel"
                             Rows="4"
                             Columns="4"
                             Width="440"
                             Height="300"/>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
          <TabItem Header="Automation1 Script I/F">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Margin="12">
                <UniformGrid Columns="5" Margin="0,0,0,8">
                  <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="Script Mode"/>
                    <ComboBox x:Name="ScriptModeComboBox" SelectedIndex="0" ToolTip="Virtual Wait Simulation은 Laser/PSO 없이 wait 통과만 검증합니다. Hardware Coordinate Program은 실제 장비용 좌표 프로그램 골격입니다.">
                      <ComboBoxItem Content="Virtual Wait Simulation" Tag="VirtualWaitSimulation"/>
                      <ComboBoxItem Content="Hardware Coordinate Program" Tag="HardwareCoordinateProgram"/>
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="Server PC Host"/><TextBox x:Name="ServerHostBox" Text="192.168.10.10" ToolTip="AeroScript를 수신하는 별도 Automation1Server 프로그램이 실행되는 Scanner Server PC 주소입니다. MDK 설치만으로 Server가 자동 실행되지는 않습니다."/></StackPanel>
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="Script Gateway Port"/><TextBox x:Name="ServerPortBox" Text="46100" ToolTip="이 예제의 Automation1Server가 수신하는 JSON protocol 포트입니다. Automation1 Controller native endpoint 12200을 입력하면 안 됩니다."/></StackPanel>
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="API Key"/><TextBox x:Name="ServerApiKeyBox" Text="change-this-key" ToolTip="Server 요청 인증값입니다. 운영에서는 기본값을 사용하지 말고 장비망 정책에 맞는 비밀값을 설정해야 합니다."/></StackPanel>
                  <StackPanel Margin="0,0,0,8"><TextBlock Text="Automation1 Task"/><TextBox x:Name="Automation1TaskIndexBox" Text="1" ToolTip="Controller.Runtime.Tasks[index]에서 AeroScript를 실행할 User Task 번호입니다. Task index는 1부터 시작합니다."/></StackPanel>

                  <StackPanel Margin="0,0,8,8"><TextBlock Text="Controller File"/><TextBox x:Name="ControllerFileNameBox" Text="programs/mof_generated.ascript" ToolTip="Server가 Controller.Files.WriteText로 저장하고 Task.Program.Run에 전달하는 Controller 내부 경로입니다. Client PC의 D:\ 경로를 입력하는 항목이 아닙니다."/></StackPanel>
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="Local Script File"/><TextBox x:Name="LocalScriptPathBox" Text="mof_generated.ascript" ToolTip="Script 생성 버튼을 누를 때 Client PC에 실제로 저장할 파일입니다. 상대 경로는 실행 파일 폴더를 기준으로 계산합니다."/></StackPanel>
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="Stage Axis"/><TextBox x:Name="StageAxisNameBox" Text="Y" ToolTip="기판을 이송하는 Stage 축 이름입니다. Virtual Wait 조건은 이 축의 PositionFeedback을 읽습니다."/></StackPanel>
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="GX Axis Template"/><TextBox x:Name="AxisXTemplateBox" Text="GX" ToolTip="Scanner X축 이름입니다. {0}을 넣으면 선택 Head 번호로 치환됩니다."/></StackPanel>
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="GY Axis Template"/><TextBox x:Name="AxisYTemplateBox" Text="GY" ToolTip="Scanner Y축 이름입니다. {0}을 넣으면 선택 Head 번호로 치환됩니다."/></StackPanel>
                  <StackPanel Margin="0,0,0,8"><TextBlock Text="Laser Library"/><TextBox x:Name="LaserLibraryNameBox" Text="LaserOnLibrary.a1lib" ToolTip="Hardware 모드에서 import 문만 생성할 검증된 Library 이름입니다. 함수 호출은 장비 Interlock 확정 후 구현해야 합니다."/></StackPanel>
                </UniformGrid>

                <Border Background="#172554" BorderBrush="#3B82F6" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                  <TextBlock Foreground="#BFDBFE" TextWrapping="Wrap"
                             Text="통신 경로: Client WPF → 192.168.10.10:46100 Script Gateway → Automation1 .NET API → Controller native endpoint 12200. 이 화면에는 46100을 입력합니다."/>
                </Border>

                <Expander Header="MOF Script 생성 조건" IsExpanded="False" Foreground="#93C5FD" Margin="0,0,0,8">
                  <UniformGrid Columns="5" Margin="0,8,0,0">
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Start Y Position"/><TextBox x:Name="StartYPositionBox" Text="500" ToolTip="비동기 Stage 이동을 시작하는 기준 Y 위치입니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Stage Travel"/><TextBox x:Name="StageTravelDistanceBox" Text="40" ToolTip="Start Y에서 이동할 거리입니다. 음수이면 wait 조건도 PositionFeedback 감소 방향으로 생성됩니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Stage Speed"/><TextBox x:Name="StageSpeedBox" Text="20" ToolTip="MoveAbsolute(Stage, target, speed)의 Stage 이송 속도입니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Scanner Rapid Speed"/><TextBox x:Name="ScannerRapidSpeedBox" Text="1000" ToolTip="Virtual mode의 G0 GX/GY 이동에 적용되는 축별 rapid speed입니다."/></StackPanel>
                    <StackPanel Margin="0,0,0,8"><TextBlock Text="Coordinated Speed"/><TextBox x:Name="CoordinatedSpeedBox" Text="100" ToolTip="Hardware mode MoveLinear의 coordinated speed입니다."/></StackPanel>

                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Ramp Rate"/><TextBox x:Name="RampRateBox" Text="3000000" ToolTip="GX/GY independent 및 coordinated Sine ramp rate입니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Trajectory FIR"/><TextBox x:Name="TrajectoryFirFilterBox" Text="3" ToolTip="GX/GY AxisParameter.TrajectoryFirFilter active parameter입니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Motion Update kHz"/><TextBox x:Name="MotionUpdateRateBox" Text="100" ToolTip="TaskParameter.MotionUpdateRate입니다. MoveDelay 해상도와 연관되며 Controller 종류가 지원하는 값인지 확인해야 합니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Execute Num Lines"/><TextBox x:Name="ExecuteNumLinesBox" Text="110" ToolTip="Task scheduling에서 1 ms마다 실행을 시도하는 program line 수입니다."/></StackPanel>
                    <StackPanel Margin="0,0,0,8"><TextBlock Text="Setup Dwell sec"/><TextBox x:Name="SetupDwellSecondsBox" Text="0.2" ToolTip="동적 Parameter 적용 뒤 다른 controller 작업에 시간을 주는 초기 Dwell 시간입니다."/></StackPanel>

                    <StackPanel Margin="0,0,8,8"><TextBlock Text="MoveDelay ms"/><TextBox x:Name="MoveDelayMillisecondsBox" Text="0.1" ToolTip="각 GY drill point 사이 MoveDelay 값이며 단위는 밀리초입니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Wait Step Y"/><TextBox x:Name="WaitStepYBox" Text="10" ToolTip="GX band 하나가 끝날 때마다 증가하는 Stage PositionFeedback wait 임계 간격입니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Software Limit Low"/><TextBox x:Name="SoftwareLimitLowBox" Text="-10000" ToolTip="GX/GY active software lower limit입니다. 실제 장비 유효 범위를 사용해야 합니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Software Limit High"/><TextBox x:Name="SoftwareLimitHighBox" Text="10000" ToolTip="GX/GY active software upper limit입니다. 실제 장비 유효 범위를 사용해야 합니다."/></StackPanel>
                  </UniformGrid>
                </Expander>

                <WrapPanel Margin="0,0,0,8">
                  <CheckBox x:Name="SelectedCoordinatesOnlyCheckBox" Content="선택 좌표만" Foreground="#E2E8F0" Margin="0,0,14,0"/>
                  <CheckBox x:Name="EnableAxesCheckBox" Content="Script에서 축 Enable" Foreground="#E2E8F0" Margin="0,0,14,0" ToolTip="장비 초기화 계층이 축 Enable을 담당한다면 체크하지 않습니다."/>
                  <CheckBox x:Name="DisableAxesAtEndCheckBox" Content="완료 후 축 Disable" Foreground="#E2E8F0" Margin="0,0,14,0"/>
                  <CheckBox x:Name="IncludeLaserLibraryCheckBox" Content="Hardware 모드 Library import" Foreground="#FBBF24" ToolTip="Import 문만 추가합니다. Laser/PSO 함수와 Interlock은 자동 생성하지 않습니다."/>
                </WrapPanel>

                <TextBlock Text="Virtual Mode는 Laser/PSO/HW Aux 출력이 아니라 Y PositionFeedback wait 해제 순서만 검증합니다. 한 번에 Scanner Head 한 개만 선택하십시오."
                           Foreground="#FBBF24" TextWrapping="Wrap" Margin="0,0,0,8"/>

                <WrapPanel Margin="0,0,0,8">
                  <Button x:Name="GenerateAeroScriptButton" Content="1. Script 생성" Margin="0,0,6,0" Click="GenerateAeroScriptButton_Click"/>
                  <Button x:Name="OpenLocalScriptFolderButton" Content="저장 위치 열기" Margin="0,0,6,0" Click="OpenLocalScriptFolderButton_Click"/>
                  <Button x:Name="ServerHealthCheckButton" Content="Server 연결 확인" Margin="0,0,6,0" Background="#075985" BorderBrush="#38BDF8" Click="ServerHealthCheckButton_Click"/>
                  <Button x:Name="UploadAeroScriptButton" Content="2. Server 전송" Margin="0,0,6,0" Click="UploadAeroScriptButton_Click"/>
                  <Button x:Name="RunAeroScriptButton" Content="3. Server 실행" Margin="0,0,6,0" Click="RunAeroScriptButton_Click"/>
                  <Button x:Name="QueryAeroScriptStatusButton" Content="상태 조회" Margin="0,0,6,0" Click="QueryAeroScriptStatusButton_Click"/>
                  <Button x:Name="ExecuteAeroScriptWorkflowButton" Content="전체 실행 및 완료 대기" Background="#047857" BorderBrush="#10B981" Click="ExecuteAeroScriptWorkflowButton_Click"/>
                </WrapPanel>

                <Grid Height="250">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="1.45*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                  <TextBox x:Name="ScriptPreviewBox" FontFamily="Consolas" FontSize="11" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                  <TextBox x:Name="DeploymentLogBox" Grid.Column="2" FontFamily="Consolas" FontSize="11" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                </Grid>

                <TextBlock x:Name="ScriptJobText" Margin="0,8,0,0" Foreground="#67E8F9" TextWrapping="Wrap" Text="대기: Client PC에서 Script를 생성한 뒤 Server PC로 전송하십시오."/>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
        </TabControl>
      </Border>

      <Border Grid.Row="4" Background="#111827" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="12">
        <TextBlock x:Name="FormulaText"
                   TextWrapping="Wrap"
                   Foreground="#CBD5E1"/>
      </Border>
    </Grid>
  </Grid>
</Window>
