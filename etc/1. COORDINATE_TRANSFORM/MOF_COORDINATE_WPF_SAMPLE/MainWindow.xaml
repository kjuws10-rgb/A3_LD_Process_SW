<Window x:Class="MofCoordinateDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MOF Coordinate Matrix Viewer"
        Width="1580"
        Height="980"
        MinWidth="1240"
        MinHeight="780"
        Background="#0B1120">
  <Grid Margin="14">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="355"/>
      <ColumnDefinition Width="14"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Background="#111827"
            BorderBrush="#243244"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <TextBlock Text="Coordinate Input"
                     FontSize="22"
                     FontWeight="Bold"
                     Foreground="#F8FAFC"/>
          <TextBlock Text="AK1, Cell, Scanner, DOE Beam selection"
                     Foreground="#94A3B8"
                     Margin="0,3,0,12"/>

          <TextBlock Text="PPID / PP Recipe" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="ONLINE_PPID_NAME"/><TextBox x:Name="OnlinePpidNameBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="MAX_CELL_NUMBER"/><TextBox x:Name="MaxCellNumberBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="STAGE_SPEED"/><TextBox x:Name="PpStageSpeedBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="LASER_POWER"/><TextBox x:Name="LaserPowerBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="LASER_FREQUENCY"/><TextBox x:Name="LaserFrequencyBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="SHOT_COUNT"/><TextBox x:Name="ShotCountBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="NUM_OF_PIXEL_X"/><TextBox x:Name="NumOfPixelXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="NUM_OF_PIXEL_Y"/><TextBox x:Name="NumOfPixelYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="PITCH"/><TextBox x:Name="PpPitchBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="CHESS"/><TextBox x:Name="ChessBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="SPLITED_BEAM_COUNT"/><TextBox x:Name="SplitedBeamCountBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="ZERO_DEFENCE_REVIEW_POINT"/><TextBox x:Name="ZeroDefenceReviewPointBox"/></StackPanel>
          </UniformGrid>
          <UniformGrid Columns="2" Margin="0,0,0,8">
            <Button x:Name="BuildCellPpTableButton"
                    Height="34"
                    Margin="0,0,5,0"
                    Content="Cell PP Table 생성"
                    Click="BuildCellPpTableButton_Click"/>
            <Button x:Name="AutoArrangeCellPpTableButton"
                    Height="34"
                    Margin="5,0,0,0"
                    Content="Cell 좌표 자동배치"
                    Click="AutoArrangeCellPpTableButton_Click"/>
          </UniformGrid>
          <TextBlock Text="Cell PP Table"
                     Style="{StaticResource SectionTitleStyle}"
                     Margin="0,6,0,4"/>
          <Border Background="#0F172A"
                  BorderBrush="#334155"
                  BorderThickness="1"
                  CornerRadius="6"
                  Padding="4"
                  Margin="0,0,0,10">
            <DataGrid x:Name="CellPpDataGrid"
                      Height="220"
                      RowHeight="28"
                      FontSize="12"
                      CellEditEnding="CellPpDataGrid_CellEditEnding"
                      CurrentCellChanged="CellPpDataGrid_CurrentCellChanged">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Cell#" Binding="{Binding CellNumber}" IsReadOnly="True" Width="54"/>
                <DataGridTextColumn Header="1st Pixel X" Binding="{Binding AlignToFirstPixelX, StringFormat=0.###}" Width="88"/>
                <DataGridTextColumn Header="1st Pixel Y" Binding="{Binding AlignToFirstPixelY, StringFormat=0.###}" Width="88"/>
                <DataGridTextColumn Header="Rotation" Binding="{Binding RotationDeg, StringFormat=0.###}" Width="74"/>
              </DataGrid.Columns>
            </DataGrid>
          </Border>

          <TextBlock Text="Board / Align" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Board X"/><TextBox x:Name="BoardXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Board Y"/><TextBox x:Name="BoardYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="AK Margin X"/><TextBox x:Name="AkMarginXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="AK Margin Y"/><TextBox x:Name="AkMarginYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Home Stage Y"/><TextBox x:Name="HomeStageYBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Forward Y Sign"/><TextBox x:Name="ForwardTransportSignYBox"/></StackPanel>
          </UniformGrid>

          <TextBlock Text="Review Camera" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Center X"/><TextBox x:Name="ReviewCenterXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Center Y"/><TextBox x:Name="ReviewCenterYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="U0"/><TextBox x:Name="U0Box"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="V0"/><TextBox x:Name="V0Box"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Scale X"/><TextBox x:Name="ScaleXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Scale Y"/><TextBox x:Name="ScaleYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="AK1 U"/><TextBox x:Name="Ak1UBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="AK1 V"/><TextBox x:Name="Ak1VBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Theta deg"/><TextBox x:Name="ThetaBox"/></StackPanel>
          </UniformGrid>

          <TextBlock Text="Cell / Pixel Pattern" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Cell1 First X"/><TextBox x:Name="CellFirstXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Cell1 First Y"/><TextBox x:Name="CellFirstYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Pixel Pitch X"/><TextBox x:Name="CellPitchXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Pixel Pitch Y"/><TextBox x:Name="CellPitchYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Pattern Off X"/><TextBox x:Name="PatternOffsetXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Pattern Off Y"/><TextBox x:Name="PatternOffsetYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Columns"/><TextBox x:Name="CellColumnsBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Rows"/><TextBox x:Name="CellRowsBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Legacy Grid Cols"/><TextBox x:Name="CellBlockColumnsBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Legacy Grid Rows"/><TextBox x:Name="CellBlockRowsBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Legacy Pitch X"/><TextBox x:Name="CellBlockPitchXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Legacy Pitch Y"/><TextBox x:Name="CellBlockPitchYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Selected Cell#"/><TextBox x:Name="SelectedCellBlockBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Selected Col"/><TextBox x:Name="SelectedCellColumnBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Selected Row"/><TextBox x:Name="SelectedCellRowBox"/></StackPanel>
          </UniformGrid>

          <TextBlock Text="Scanner / DOE" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Head Count"/><TextBox x:Name="ScannerCountBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Highlight Heads"/><TextBox x:Name="HighlightHeadsBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="H1 Initial Stage X"/><TextBox x:Name="FirstScannerInitialXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="H1 Initial Stage Y"/><TextBox x:Name="FirstScannerInitialYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Camera → H1 Off X"/><TextBox x:Name="CameraToScannerOffsetXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Camera → H1 Off Y"/><TextBox x:Name="CameraToScannerOffsetYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Origin Tolerance"/><TextBox x:Name="ScannerOriginToleranceBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Pitch X"/><TextBox x:Name="ScannerPitchXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Even Y Offset"/><TextBox x:Name="EvenYOffsetBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Process Area Half X"/><TextBox x:Name="FieldHalfXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Process Area Half Y"/><TextBox x:Name="FieldHalfYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Review Head"/><TextBox x:Name="ReviewBasisHeadBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="DOE Beam 1-16"/><TextBox x:Name="ReviewBasisBeamBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="DOE Pitch X"/><TextBox x:Name="DoePitchXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="DOE Pitch Y"/><TextBox x:Name="DoePitchYBox"/></StackPanel>
          </UniformGrid>
          <UniformGrid Columns="2" Margin="0,0,0,10">
            <Button x:Name="SelectAllScannersButton"
                    Height="34"
                    Margin="0,0,5,0"
                    Content="All Scanner Select"
                    Click="SelectAllScannersButton_Click"/>
            <Button x:Name="ClearScannerSelectionButton"
                    Height="34"
                    Margin="5,0,0,0"
                    Content="Clear Scanner"
                    Click="ClearScannerSelectionButton_Click"/>
          </UniformGrid>

          <TextBlock Text="Dynamic Review Correction" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,14">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Offset Global X"/><TextBox x:Name="OffsetXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Offset Global Y"/><TextBox x:Name="OffsetYBox"/></StackPanel>
          </UniformGrid>

          <Button x:Name="GenerateButton"
                  Height="40"
                  Content="Generate / Refresh"
                  FontWeight="Bold"
                  Click="GenerateButton_Click"/>
          <Button x:Name="OpenConfigButton"
                  Height="36"
                  Margin="0,8,0,0"
                  Content="Open CSV Template in Excel"
                  Click="OpenConfigButton_Click"/>
          <Button x:Name="LoadConfigButton"
                  Height="36"
                  Margin="0,6,0,0"
                  Content="Load Saved CSV Config"
                  Click="LoadConfigButton_Click"/>
          <Button x:Name="ReloadConfigButton"
                  Height="36"
                  Margin="0,6,0,0"
                  Content="Reload Current CSV"
                  Click="ReloadConfigButton_Click"/>
          <Button x:Name="SaveConfigButton"
                  Height="36"
                  Margin="0,6,0,0"
                  Content="Save Current CSV"
                  Click="SaveConfigButton_Click"/>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="2.1*"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="1.7*"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="92"/>
      </Grid.RowDefinitions>

      <Border Background="#111827" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock x:Name="SummaryText"
                     FontSize="15"
                     Foreground="#CBD5E1"
                     Margin="0,0,0,8"/>
          <ScrollViewer x:Name="LayoutScrollViewer"
                        Grid.Row="1"
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto"
                        PreviewMouseWheel="LayoutScrollViewer_PreviewMouseWheel">
            <Canvas x:Name="LayoutCanvas"
                    Width="1280"
                    Height="520"
                    Background="#0F172A"/>
          </ScrollViewer>
        </Grid>
      </Border>

      <Border Grid.Row="2" Background="#111827" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="8">
        <TabControl x:Name="CoordinateTabControl" SelectionChanged="CoordinateTabControl_SelectionChanged">
          <TabItem Header="Design 2D Matrix">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="MatrixScrollViewer_PreviewMouseWheel">
              <Canvas x:Name="DesignMatrixCanvas" Background="#0F172A"/>
            </ScrollViewer>
          </TabItem>
          <TabItem Header="Process Gx/Gy 2D Matrix">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="MatrixScrollViewer_PreviewMouseWheel">
              <Canvas x:Name="ProcessMatrixCanvas" Background="#0F172A"/>
            </ScrollViewer>
          </TabItem>
          <TabItem Header="Review Camera 2D Matrix">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          PreviewMouseWheel="MatrixScrollViewer_PreviewMouseWheel">
              <Canvas x:Name="ReviewMatrixCanvas" Background="#0F172A"/>
            </ScrollViewer>
          </TabItem>
          <TabItem Header="DOE 16 Matrix">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel Margin="12">
                <TextBlock Text="DOE 16 Beam Matrix"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#F8FAFC"
                           Margin="0,0,0,8"/>
                <UniformGrid x:Name="DoeMatrixPanel"
                             Rows="4"
                             Columns="4"
                             Width="440"
                             Height="300"/>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
          <TabItem Header="Automation1 Script I/F">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
              <StackPanel Margin="12">
                <UniformGrid Columns="5" Margin="0,0,0,8">
                  <StackPanel Margin="0,0,8,8">
                    <TextBlock Text="실행 환경 / Script Mode"/>
                    <ComboBox x:Name="ScriptModeComboBox" SelectedIndex="0" ToolTip="Simulation은 소프트웨어 Stage 카운터를 사용하고, External Stage AUX MOF는 타사 Stage 엔코더가 Scanner GY AUX 입력으로 들어오는 실제 설비 구성을 사용합니다.">
                      <ComboBoxItem Content="Simulation - Virtual Wait" Tag="VirtualWaitSimulation"/>
                      <ComboBoxItem Content="Equipment - External Stage AUX MOF" Tag="ExternalStageAuxMofProgram"/>
                      <ComboBoxItem Content="Equipment - Hardware Coordinate" Tag="HardwareCoordinateProgram"/>
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="Controller Host"/><TextBox x:Name="ControllerHostBox" Text="192.168.10.10" ToolTip="Client PC에서 Automation1 Studio와 같은 방식으로 직접 접속할 원격 Controller 또는 Server PC 주소입니다."/></StackPanel>
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="Controller Port"/><TextBox x:Name="ControllerPortBox" Text="12200" ToolTip="Automation1 공식 .NET API가 접속할 Controller endpoint입니다. 기본값은 12200이며 별도 JSON Gateway를 사용하지 않습니다."/></StackPanel>
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="Controller Start"/><CheckBox x:Name="StartControllerIfStoppedCheckBox" Content="정지 시 시작" Foreground="#E2E8F0" ToolTip="연결된 Automation1 Controller가 정지 상태이면 Controller.Start를 요청합니다. 장비 운전 정책 확인 후 사용하십시오."/></StackPanel>
                  <StackPanel Margin="0,0,0,8"><TextBlock Text="Automation1 Task"/><TextBox x:Name="Automation1TaskIndexBox" Text="1" ToolTip="Controller.Runtime.Tasks[index]에서 AeroScript를 실행할 User Task 번호입니다. Task index는 1부터 시작합니다."/></StackPanel>

                  <StackPanel Margin="0,0,8,8"><TextBlock Text="Controller File"/><TextBox x:Name="ControllerFileNameBox" Text="programs/mof_generated.ascript" ToolTip="Controller.Files.WriteText로 기록하고 Task.Program.Run에 전달하는 Automation1 Controller File System 내부 경로입니다."/></StackPanel>
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="Local Script File"/><TextBox x:Name="LocalScriptPathBox" Text="mof_generated.ascript" ToolTip="Script 생성 버튼을 누를 때 Client PC에 실제로 저장할 파일입니다. 상대 경로는 실행 파일 폴더를 기준으로 계산합니다."/></StackPanel>
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="GX Axis Template"/><TextBox x:Name="AxisXTemplateBox" Text="GX" ToolTip="Scanner X축 이름입니다. {0}을 넣으면 선택 Head 번호로 치환됩니다."/></StackPanel>
                  <StackPanel Margin="0,0,8,8"><TextBlock Text="GY Axis Template"/><TextBox x:Name="AxisYTemplateBox" Text="GY" ToolTip="Scanner Y축 이름입니다. {0}을 넣으면 선택 Head 번호로 치환됩니다."/></StackPanel>
                  <StackPanel Margin="0,0,0,8"><TextBlock Text="Laser Library"/><TextBox x:Name="LaserLibraryNameBox" Text="LaserOnLibrary.a1lib" ToolTip="Hardware 모드에서 import 문만 생성할 검증된 Library 이름입니다. 함수 호출은 장비 Interlock 확정 후 구현해야 합니다."/></StackPanel>
                </UniformGrid>

                <Border Background="#172554" BorderBrush="#3B82F6" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                  <TextBlock Foreground="#BFDBFE" TextWrapping="Wrap"
                             Text="직접 연결 경로: Client WPF → Aerotech Automation1 .NET API → 192.168.10.10:12200 Controller. 별도 Automation1Server, JSON Gateway, TCP 46100은 사용하지 않습니다."/>
                </Border>

                <Expander Header="MOF Script 생성 조건" IsExpanded="False" Foreground="#93C5FD" Margin="0,0,0,8">
                  <UniformGrid Columns="5" Margin="0,8,0,0">
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Start Y Position"/><TextBox x:Name="StartYPositionBox" Text="500" ToolTip="비동기 Stage 이동을 시작하는 기준 Y 위치입니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Stage Travel"/><TextBox x:Name="StageTravelDistanceBox" Text="40" ToolTip="가상 모드에서는 부호가 소프트웨어 Stage 카운터 방향을 결정합니다. External AUX 모드에서는 예상 이동 범위 검증에만 사용합니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Stage Speed"/><TextBox x:Name="StageSpeedBox" Text="20" ToolTip="MoveAbsolute(Stage, target, speed)의 Stage 이송 속도입니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Scanner Rapid Speed"/><TextBox x:Name="ScannerRapidSpeedBox" Text="1000" ToolTip="Virtual mode의 G0 GX/GY 이동에 적용되는 축별 rapid speed입니다."/></StackPanel>
                    <StackPanel Margin="0,0,0,8"><TextBlock Text="Coordinated Speed"/><TextBox x:Name="CoordinatedSpeedBox" Text="100" ToolTip="Hardware mode MoveLinear의 coordinated speed입니다."/></StackPanel>

                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Ramp Rate"/><TextBox x:Name="RampRateBox" Text="3000000" ToolTip="GX/GY independent 및 coordinated Sine ramp rate입니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Trajectory FIR"/><TextBox x:Name="TrajectoryFirFilterBox" Text="3" ToolTip="GX/GY AxisParameter.TrajectoryFirFilter active parameter입니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Motion Update kHz"/><TextBox x:Name="MotionUpdateRateBox" Text="100" ToolTip="TaskParameter.MotionUpdateRate입니다. MoveDelay 해상도와 연관되며 Controller 종류가 지원하는 값인지 확인해야 합니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Execute Num Lines"/><TextBox x:Name="ExecuteNumLinesBox" Text="110" ToolTip="Task scheduling에서 1 ms마다 실행을 시도하는 program line 수입니다."/></StackPanel>
                    <StackPanel Margin="0,0,0,8"><TextBlock Text="Setup Dwell sec"/><TextBox x:Name="SetupDwellSecondsBox" Text="0.2" ToolTip="동적 Parameter 적용 뒤 다른 controller 작업에 시간을 주는 초기 Dwell 시간입니다."/></StackPanel>

                    <StackPanel Margin="0,0,8,8"><TextBlock Text="MoveDelay ms"/><TextBox x:Name="MoveDelayMillisecondsBox" Text="0.1" ToolTip="각 GY drill point 사이 MoveDelay 값이며 단위는 밀리초입니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="External Encoder cnt/mm"/><TextBox x:Name="ExternalEncoderCountsPerUnitBox" Text="16000" ToolTip="타사 Stage 엔코더가 1 mm 이동할 때 Scanner AUX 입력에 들어오는 count입니다. 현장 설비 기준값은 16,000 cts/mm입니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Encoder Direction"/><TextBox x:Name="ExternalEncoderDirectionSignBox" Text="-1" ToolTip="Scanner 보정 방향과 외부 Stage 엔코더 방향이 반대이면 -1, 같으면 1을 입력합니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="AUX Initial Wait mm"/><TextBox x:Name="AuxiliaryInitialWaitDistanceBox" Text="0.1" ToolTip="AUX 피드백을 0점화한 뒤 첫 가공 구간을 허용할 최소 외부 Stage 이동 거리입니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Follow Before Process mm"/><TextBox x:Name="FollowDistanceBeforeProcessBox" Text="200" ToolTip="가공 시작 전까지 Scanner가 외부 Stage를 따라가는 거리입니다. 현장 컨셉은 200 mm 전까지 추종 후 가공 좌표로 점프합니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Virtual Counter Tick sec"/><TextBox x:Name="VirtualStageTickSecondsBox" Text="0.02" ToolTip="Virtual Stage 카운터가 한 번 갱신될 때의 시간 간격입니다. 위치 변화량은 Stage Speed × Tick으로 계산됩니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Software Limit Low"/><TextBox x:Name="SoftwareLimitLowBox" Text="-10000" ToolTip="GX/GY active software lower limit입니다. 실제 장비 유효 범위를 사용해야 합니다."/></StackPanel>
                    <StackPanel Margin="0,0,8,8"><TextBlock Text="Software Limit High"/><TextBox x:Name="SoftwareLimitHighBox" Text="10000" ToolTip="GX/GY active software upper limit입니다. 실제 장비 유효 범위를 사용해야 합니다."/></StackPanel>
                  </UniformGrid>
                </Expander>

                <WrapPanel Margin="0,0,0,8">
                  <CheckBox x:Name="SelectedCoordinatesOnlyCheckBox" Content="선택 좌표만" Foreground="#E2E8F0" Margin="0,0,14,0"/>
                  <CheckBox x:Name="EnableAxesCheckBox" Content="Script에서 축 Enable" Foreground="#E2E8F0" Margin="0,0,14,0" ToolTip="장비 초기화 계층이 축 Enable을 담당한다면 체크하지 않습니다."/>
                  <CheckBox x:Name="DisableAxesAtEndCheckBox" Content="완료 후 축 Disable" Foreground="#E2E8F0" Margin="0,0,14,0"/>
                  <CheckBox x:Name="IncludeLaserLibraryCheckBox" Content="Hardware 모드 Library import" Foreground="#FBBF24" ToolTip="Import 문만 추가합니다. Laser/PSO 함수와 Interlock은 자동 생성하지 않습니다."/>
                  <CheckBox x:Name="PreserveControllerJobFileCheckBox" Content="Job별 Controller Script 보존" IsChecked="True" Foreground="#E2E8F0" Margin="14,0,0,0" ToolTip="파일명에 생성시각과 Job ID를 붙여 Controller File System에 실행 Script를 보존합니다."/>
                </WrapPanel>

                <Border Background="#071A2A" BorderBrush="#22D3EE" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                  <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="220"/></Grid.ColumnDefinitions>
                    <TextBlock x:Name="ProcessMonitorText" Text="가공 모니터: 대기" Foreground="#CFFAFE" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    <ProgressBar x:Name="ProcessProgressBar" Grid.Column="1" Height="16" Minimum="0" Maximum="100" Value="0" Margin="12,0" Foreground="#22D3EE" Background="#0F172A"/>
                    <TextBlock x:Name="VirtualStagePositionText" Grid.Column="2" Text="Virtual Stage Y: -" Foreground="#67E8F9" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                  </Grid>
                </Border>

                <Border Background="#201A0D" BorderBrush="#F59E0B" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
                  <StackPanel>
                    <TextBlock Text="설비 모드 실행 확인" Foreground="#FCD34D" FontWeight="SemiBold" Margin="0,0,0,6"/>
                    <WrapPanel>
                      <CheckBox x:Name="EquipmentMotionReadyCheckBox" Content="축 초기화/원점/Limit 확인" Foreground="#E2E8F0" Margin="0,0,16,4" ToolTip="실제 축의 Enable, Home, Fault, Software Limit 및 이동 가능 상태를 작업자가 확인합니다."/>
                      <CheckBox x:Name="EquipmentInterlockReadyCheckBox" Content="안전 Interlock 확인" Foreground="#E2E8F0" Margin="0,0,16,4" ToolTip="Door, Emergency Stop, Stage/Scanner 간섭 및 설비 안전 회로 상태를 확인합니다."/>
                      <CheckBox x:Name="EquipmentLaserReadyCheckBox" Content="Laser/Beam Path 확인" Foreground="#E2E8F0" Margin="0,0,16,4" ToolTip="Laser Ready, Shutter, Beam Path 및 출력 허가 조건을 확인합니다."/>
                      <CheckBox x:Name="EquipmentOperatorConfirmCheckBox" Content="최종 실행 승인" Foreground="#FDE68A" Margin="0,0,16,4" ToolTip="좌표, 속도, Ramp, Task, 가공 대상과 주변 안전 상태를 최종 확인합니다."/>
                    </WrapPanel>
                  </StackPanel>
                </Border>

                <TextBlock Text="Simulation은 Stage Y 축 없이 속도×Tick으로 증가하는 소프트웨어 카운터를 사용하며 현재 위치와 가공 순서를 화면에 표시합니다. External Stage AUX MOF는 타사 Stage 이동 중 Scanner GY의 AuxiliaryFeedback을 감시합니다. 두 모드 모두 AK1→AK2 순서로 가공합니다."
                           Foreground="#FBBF24" TextWrapping="Wrap" Margin="0,0,0,8"/>

                <WrapPanel Margin="0,0,0,8">
                  <Button x:Name="GenerateAeroScriptButton" Content="1. Script 생성" Margin="0,0,6,0" Click="GenerateAeroScriptButton_Click"/>
                  <Button x:Name="OpenLocalScriptFolderButton" Content="저장 위치 열기" Margin="0,0,6,0" Click="OpenLocalScriptFolderButton_Click"/>
                  <Button x:Name="ControllerConnectionButton" Content="Automation1 직접 연결" Margin="0,0,6,0" Background="#075985" BorderBrush="#38BDF8" Click="ControllerConnectionButton_Click"/>
                  <Button x:Name="UploadAeroScriptButton" Content="2. Controller 기록" Margin="0,0,6,0" Click="UploadAeroScriptButton_Click"/>
                  <Button x:Name="CompileAeroScriptButton" Content="3. Compile 검사" Margin="0,0,6,0" Background="#6D28D9" BorderBrush="#A78BFA" Click="CompileAeroScriptButton_Click" ToolTip="Controller Compiler로 먼저 컴파일하여 파일, 행, 열, 오류 메시지를 확인합니다."/>
                  <Button x:Name="RunAeroScriptButton" Content="4. Task 실행" Margin="0,0,6,0" Click="RunAeroScriptButton_Click"/>
                  <Button x:Name="QueryAeroScriptStatusButton" Content="상태 조회" Margin="0,0,6,0" Click="QueryAeroScriptStatusButton_Click"/>
                  <Button x:Name="StopAeroScriptButton" Content="실행 중지" Margin="0,0,6,0" Background="#7F1D1D" BorderBrush="#F87171" Click="StopAeroScriptButton_Click"/>
                  <Button x:Name="ExecuteAeroScriptWorkflowButton" Content="전체 실행 및 완료 대기" Background="#047857" BorderBrush="#10B981" Click="ExecuteAeroScriptWorkflowButton_Click"/>
                </WrapPanel>

                <Grid Height="250">
                  <Grid.ColumnDefinitions><ColumnDefinition Width="1.45*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                  <TextBox x:Name="ScriptPreviewBox" FontFamily="Consolas" FontSize="11" IsReadOnly="True" AcceptsReturn="True" TextWrapping="NoWrap" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"/>
                  <TextBox x:Name="DeploymentLogBox" Grid.Column="2" FontFamily="Consolas" FontSize="11" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MouseDoubleClick="DeploymentLogBox_MouseDoubleClick" ToolTip="Double-click to clear the deployment log."/>
                </Grid>

                <TextBlock x:Name="ScriptJobText" Margin="0,8,0,0" Foreground="#67E8F9" TextWrapping="Wrap" Text="대기: 좌표 Script 생성 → Controller File System 기록 → Task 실행 → 상태 확인 순서로 진행하십시오."/>
              </StackPanel>
            </ScrollViewer>
          </TabItem>
        </TabControl>
      </Border>

      <Border Grid.Row="4" Background="#111827" BorderBrush="#243244" BorderThickness="1" CornerRadius="8" Padding="12">
        <TextBlock x:Name="FormulaText"
                   TextWrapping="Wrap"
                   Foreground="#CBD5E1"/>
      </Border>
    </Grid>
  </Grid>
</Window>
