<Window x:Class="Talon.Driver.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Talon Laser Driver Validation"
        Width="1500" Height="930" MinWidth="1180" MinHeight="720"
        Background="{StaticResource WindowBrush}"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="12" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="12" />
      <RowDefinition Height="*" />
      <RowDefinition Height="10" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="TALON LASER DRIVER VALIDATION" FontSize="24" FontWeight="SemiBold" />
        <TextBlock Text="Talon User Manual Rev. C 기반 RS-232 프로토콜 · 시뮬레이션 · 안전 검증" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0" />
      </StackPanel>
      <Border Grid.Column="1" Background="#14293A" BorderBrush="#1E8BA0" BorderThickness="1" CornerRadius="5" Padding="14,8">
        <StackPanel Orientation="Horizontal">
          <Ellipse x:Name="ConnectionLamp" Width="10" Height="10" Fill="{StaticResource MutedBrush}" Margin="0,0,8,0" />
          <TextBlock x:Name="ConnectionText" Text="OFFLINE" FontWeight="SemiBold" />
        </StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="145" />
          <ColumnDefinition Width="160" />
          <ColumnDefinition Width="145" />
          <ColumnDefinition Width="165" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,12,0">
          <Label Content="연결 모드" />
          <ComboBox x:Name="ModeCombo" SelectionChanged="ModeCombo_SelectionChanged" ToolTip="Simulation은 장비 없이 전체 명령 흐름을 검증합니다. Hardware는 실제 COM Port를 사용합니다.">
            <ComboBoxItem Content="Simulation" IsSelected="True" />
            <ComboBoxItem Content="Hardware" />
          </ComboBox>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,12,0">
          <Label Content="COM Port" />
          <TextBox x:Name="PortText" Text="COM1" ToolTip="Talon Laser Head의 RS-232 또는 USB Virtual COM Port 이름입니다." />
        </StackPanel>
        <StackPanel Grid.Column="2" Margin="0,0,12,0">
          <Label Content="Baud Rate" />
          <ComboBox x:Name="BaudCombo" SelectedIndex="4" ToolTip="매뉴얼 기본값은 115200 bps입니다.">
            <ComboBoxItem Content="9600" /><ComboBoxItem Content="19200" /><ComboBoxItem Content="38400" /><ComboBoxItem Content="57600" /><ComboBoxItem Content="115200" />
          </ComboBox>
        </StackPanel>
        <StackPanel Grid.Column="3" Margin="0,0,12,0">
          <Label Content="Timeout (ms)" />
          <TextBox x:Name="TimeoutText" Text="1500" ToolTip="Query 응답의 최대 대기시간입니다. Set 명령은 응답을 기다리지 않습니다." />
        </StackPanel>
        <StackPanel Grid.Column="4" VerticalAlignment="Bottom">
          <TextBlock x:Name="EndpointText" Text="SIM:TALON-355" Foreground="{StaticResource AccentBrush}" FontFamily="Consolas" />
          <TextBlock Text="Command TX: &lt;CR&gt; / Query RX: &lt;CR&gt; 또는 &lt;LF&gt;" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0" />
        </StackPanel>
        <StackPanel Grid.Column="5" Orientation="Horizontal" VerticalAlignment="Bottom">
          <Button x:Name="ConnectButton" Content="연결" Click="ConnectButton_Click" ToolTip="선택한 모드로 드라이버 전송부를 생성하고 연결합니다." />
          <Button x:Name="DisconnectButton" Content="연결 해제" Click="DisconnectButton_Click" ToolTip="현재 Serial 또는 Simulation 연결을 종료합니다." />
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="4">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="365" />
        <ColumnDefinition Width="12" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <TextBlock Text="매뉴얼 명령 카탈로그" FontSize="16" FontWeight="SemiBold" />
          <DataGrid x:Name="CommandGrid" Grid.Row="2" AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="CommandGrid_SelectionChanged">
            <DataGrid.Columns>
              <DataGridTextColumn Header="분류" Binding="{Binding Category}" Width="82" />
              <DataGridTextColumn Header="명령" Binding="{Binding DisplayName}" Width="*" />
              <DataGridTextColumn Header="위험" Binding="{Binding RiskLevel}" Width="82" />
            </DataGrid.Columns>
          </DataGrid>
          <GroupBox Grid.Row="4" Header="선택 명령">
            <StackPanel>
              <TextBlock x:Name="SelectedCommandText" Text="명령을 선택하세요" FontFamily="Consolas" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap" />
              <TextBlock x:Name="SelectedDescriptionText" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" TextWrapping="Wrap" />
              <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <TextBox x:Name="ParameterText" Text="0" ToolTip="선택 명령의 숫자 Parameter입니다. 매뉴얼 범위를 벗어나면 전송 전에 차단됩니다." />
                <TextBlock Grid.Column="1" x:Name="ParameterUnitText" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}" />
              </Grid>
              <Button x:Name="SendButton" Content="선택 명령 실행" Margin="0,10,0,0" Click="SendButton_Click" ToolTip="Command Catalog의 형식과 안전조건을 검증한 뒤 실행합니다." />
            </StackPanel>
          </GroupBox>
        </Grid>
      </Border>

      <TabControl Grid.Column="2" x:Name="MainTabs">
        <TabItem Header="상태 대시보드">
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="16">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" /><ColumnDefinition Width="10" /><ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="14">
                  <StackPanel><TextBlock Text="SYSTEM" Foreground="{StaticResource MutedBrush}" /><TextBlock x:Name="SystemStatusText" Text="Unknown" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0" /></StackPanel>
                </Border>
                <Border Grid.Column="2" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="14">
                  <StackPanel><TextBlock Text="OUTPUT POWER" Foreground="{StaticResource MutedBrush}" /><TextBlock x:Name="PowerText" Text="0.000 W" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0" /></StackPanel>
                </Border>
                <Border Grid.Column="4" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="14">
                  <StackPanel><TextBlock Text="DIODE CURRENT" Foreground="{StaticResource MutedBrush}" /><TextBlock x:Name="CurrentText" Text="0.00 A" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0" /></StackPanel>
                </Border>
                <Border Grid.Column="6" Background="{StaticResource PanelAltBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="14">
                  <StackPanel><TextBlock Text="TEMPERATURE" Foreground="{StaticResource MutedBrush}" /><TextBlock x:Name="TemperatureText" Text="0.0 / 0.0 °C" FontSize="18" FontWeight="SemiBold" Margin="0,6,0,0" /></StackPanel>
                </Border>
              </Grid>

              <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                <Button Content="안전 상태 Poll" Click="PollButton_Click" ToolTip="출력을 변경하지 않는 Query 명령만 순서대로 실행합니다." />
                <Button Content="Read-only 자동 검증" Click="ValidationButton_Click" ToolTip="매뉴얼 핵심 Query 14개를 실행하고 응답 형식을 판정합니다." />
                <Button Content="1회 Timeout 주입" Click="InjectTimeoutButton_Click" ToolTip="Simulation에서 다음 명령 한 번을 Timeout으로 만들어 오류 복구를 확인합니다." />
                <Button Content="1회 잘못된 응답 주입" Click="InjectInvalidButton_Click" ToolTip="Simulation에서 다음 Query에 잘못된 응답을 반환합니다." />
              </StackPanel>

              <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <GroupBox Header="Status Byte (*STB?)">
                  <UniformGrid Columns="3">
                    <CheckBox x:Name="EmissionBit" Content="Emission" IsHitTestVisible="False" />
                    <CheckBox x:Name="ShutterBit" Content="Shutter Open" IsHitTestVisible="False" />
                    <CheckBox x:Name="GateBit" Content="Gate Open" IsHitTestVisible="False" />
                    <CheckBox x:Name="ExternalGateBit" Content="External Gate" IsHitTestVisible="False" />
                    <CheckBox x:Name="FaultBit" Content="System Fault" IsHitTestVisible="False" />
                    <CheckBox x:Name="MotorBit" Content="Motor Moving" IsHitTestVisible="False" />
                    <CheckBox x:Name="ShgAutoBit" Content="SHG Autotune" IsHitTestVisible="False" />
                    <CheckBox x:Name="ThgAutoBit" Content="THG Autotune" IsHitTestVisible="False" />
                    <TextBlock x:Name="StatusByteText" Text="RAW: 0" Margin="0,5" />
                  </UniformGrid>
                </GroupBox>
                <GroupBox Grid.Column="2" Header="Hardware 출력 안전 잠금">
                  <StackPanel>
                    <TextBlock Text="Simulation에서는 명령 흐름만 검증합니다. Hardware 출력 명령은 아래 네 조건이 모두 확인되어야 합니다." Foreground="{StaticResource WarningBrush}" TextWrapping="Wrap" />
                    <WrapPanel Margin="0,8,0,0">
                      <CheckBox x:Name="UnlockCheck" Content="Hardware 명령 잠금 해제" ToolTip="실제 설정/출력 명령을 허용합니다." Margin="0,4,18,4" />
                      <CheckBox x:Name="InterlockCheck" Content="Area Interlock 확인" ToolTip="Analog interlock와 장비 Area 안전상태를 확인합니다." Margin="0,4,18,4" />
                      <CheckBox x:Name="BeamPathCheck" Content="Beam Path 확인" ToolTip="Beam dump 또는 Power Meter로 안전하게 종단되는지 확인합니다." Margin="0,4,18,4" />
                      <CheckBox x:Name="OperatorCheck" Content="작업자 확인" ToolTip="레이저 안전교육을 받은 작업자가 실행을 확인합니다." Margin="0,4,18,4" />
                    </WrapPanel>
                  </StackPanel>
                </GroupBox>
              </Grid>

              <GroupBox Header="식별 / 상태 이력" Margin="0,16,0,0">
                <StackPanel>
                  <TextBlock x:Name="IdentityText" Text="Identity: -" FontFamily="Consolas" TextWrapping="Wrap" />
                  <TextBlock x:Name="HistoryText" Text="History: -" FontFamily="Consolas" Foreground="{StaticResource MutedBrush}" Margin="0,7,0,0" TextWrapping="Wrap" />
                </StackPanel>
              </GroupBox>
            </StackPanel>
          </ScrollViewer>
        </TabItem>

        <TabItem Header="자동 검증 결과">
          <DataGrid x:Name="ValidationGrid" Margin="12" AutoGenerateColumns="False">
            <DataGrid.Columns>
              <DataGridCheckBoxColumn Header="통과" Binding="{Binding Passed}" Width="60" />
              <DataGridTextColumn Header="항목" Binding="{Binding Name}" Width="170" />
              <DataGridTextColumn Header="명령" Binding="{Binding Command}" Width="120" />
              <DataGridTextColumn Header="실제 응답" Binding="{Binding Actual}" Width="*" />
              <DataGridTextColumn Header="기대 형식" Binding="{Binding Expected}" Width="160" />
              <DataGridTextColumn Header="판정" Binding="{Binding Detail}" Width="220" />
            </DataGrid.Columns>
          </DataGrid>
        </TabItem>

        <TabItem Header="통신 Trace">
          <DataGrid x:Name="TraceGrid" Margin="12" AutoGenerateColumns="False">
            <DataGrid.Columns>
              <DataGridTextColumn Header="시각" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="105" />
              <DataGridCheckBoxColumn Header="정상" Binding="{Binding Success}" Width="55" />
              <DataGridTextColumn Header="TX" Binding="{Binding Command}" Width="160" />
              <DataGridTextColumn Header="RX" Binding="{Binding Response}" Width="*" />
              <DataGridTextColumn Header="ms" Binding="{Binding Elapsed.TotalMilliseconds, StringFormat=F1}" Width="70" />
              <DataGridTextColumn Header="메시지" Binding="{Binding Message}" Width="260" />
            </DataGrid.Columns>
          </DataGrid>
        </TabItem>
      </TabControl>
    </Grid>

    <Border Grid.Row="6" Background="#0D1624" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="10,8">
      <TextBlock x:Name="FooterText" Text="Simulation 모드입니다. 장비 출력 없이 프로토콜과 UI 흐름을 검증할 수 있습니다." Foreground="{StaticResource MutedBrush}" />
    </Border>
  </Grid>
</Window>
