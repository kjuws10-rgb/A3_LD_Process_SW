<Window x:Class="Talon.Driver.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="A3 Optical Component Driver Validation"
        Width="1540" Height="940" MinWidth="1180" MinHeight="720"
        Background="{StaticResource WindowBrush}" WindowStartupLocation="CenterScreen">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/><RowDefinition Height="12"/><RowDefinition Height="Auto"/>
      <RowDefinition Height="12"/><RowDefinition Height="*"/><RowDefinition Height="10"/><RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="OPTICAL COMPONENT DRIVER VALIDATION" FontSize="24" FontWeight="SemiBold"/>
        <TextBlock Text="Laser · Attenuator · Beam Expander · Power Meter · XPS · Picomotor 통합 검증" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0"/>
      </StackPanel>
      <Border Grid.Column="1" Background="#14293A" BorderBrush="#1E8BA0" BorderThickness="1" CornerRadius="5" Padding="14,8">
        <StackPanel Orientation="Horizontal"><Ellipse x:Name="ConnectionLamp" Width="10" Height="10" Fill="{StaticResource MutedBrush}" Margin="0,0,8,0"/><TextBlock x:Name="ConnectionText" Text="OFFLINE" FontWeight="SemiBold"/></StackPanel>
      </Border>
    </Grid>

    <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="230"/><ColumnDefinition Width="140"/><ColumnDefinition Width="180"/><ColumnDefinition Width="125"/>
          <ColumnDefinition Width="115"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,12,0"><Label Content="검증 컴포넌트"/><ComboBox x:Name="ComponentCombo" DisplayMemberPath="DisplayName" SelectionChanged="ComponentCombo_SelectionChanged" ToolTip="검증할 장비를 선택합니다. 선택 시 명령, 연결 기본값, 이론/운용 설명이 함께 바뀝니다."/></StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,12,0"><Label Content="연결 모드"/><ComboBox x:Name="ModeCombo" SelectionChanged="ModeCombo_SelectionChanged" ToolTip="Simulation은 실제 장비 없이 protocol과 UI를 검증합니다."><ComboBoxItem Content="Simulation" IsSelected="True"/><ComboBoxItem Content="Hardware"/></ComboBox></StackPanel>
        <StackPanel Grid.Column="2" Margin="0,0,12,0"><Label Content="Endpoint"/><TextBox x:Name="EndpointTextBox" ToolTip="Serial은 COM 이름, TCP는 IP 주소입니다."/></StackPanel>
        <StackPanel Grid.Column="3" Margin="0,0,12,0"><Label Content="Baud Rate"/><TextBox x:Name="BaudTextBox" ToolTip="Serial profile의 기본 통신속도입니다."/></StackPanel>
        <StackPanel Grid.Column="4" Margin="0,0,12,0"><Label Content="TCP Port"/><TextBox x:Name="TcpPortTextBox" ToolTip="XPS API command socket은 기본 5001입니다."/></StackPanel>
        <StackPanel Grid.Column="5" VerticalAlignment="Bottom"><TextBlock x:Name="RoleText" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"/><TextBlock x:Name="ProtocolText" Foreground="{StaticResource MutedBrush}" Margin="0,5,0,0"/></StackPanel>
        <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Bottom"><Button x:Name="ConnectButton" Content="연결" Click="ConnectButton_Click"/><Button x:Name="DisconnectButton" Content="해제" Click="DisconnectButton_Click"/></StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="4">
      <Grid.ColumnDefinitions><ColumnDefinition Width="390"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Grid.Column="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="12">
        <Grid>
          <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="8"/><RowDefinition Height="*"/><RowDefinition Height="10"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
          <TextBlock Text="컴포넌트 기능 및 명령 목록" FontSize="16" FontWeight="SemiBold"/>
          <DataGrid x:Name="CommandGrid" Grid.Row="2" AutoGenerateColumns="False" SelectionMode="Single" SelectionChanged="CommandGrid_SelectionChanged">
            <DataGrid.Columns><DataGridTextColumn Header="분류" Binding="{Binding Category}" Width="82"/><DataGridTextColumn Header="기능" Binding="{Binding DisplayName}" Width="*"/><DataGridTextColumn Header="위험" Binding="{Binding Risk}" Width="90"/></DataGrid.Columns>
          </DataGrid>
          <GroupBox Grid.Row="4" Header="선택 기능 실행">
            <StackPanel>
              <TextBlock x:Name="SelectedCommandText" Text="기능을 선택하세요" FontFamily="Consolas" Foreground="{StaticResource AccentBrush}" TextWrapping="Wrap"/>
              <TextBlock x:Name="SelectedDescriptionText" Foreground="{StaticResource MutedBrush}" Margin="0,7,0,0" TextWrapping="Wrap"/>
              <Grid Margin="0,9,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="ParameterText" Text="0" ToolTip="명령 parameter입니다. 범위를 벗어나면 전송 전에 차단됩니다."/><TextBlock Grid.Column="1" x:Name="ParameterUnitText" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{StaticResource MutedBrush}"/></Grid>
              <Button x:Name="SendButton" Content="선택 기능 실행" Margin="0,10,0,0" Click="SendButton_Click"/>
            </StackPanel>
          </GroupBox>
        </Grid>
      </Border>

      <TabControl Grid.Column="2" x:Name="MainTabs">
        <TabItem Header="상태 및 검증">
          <Grid Margin="14"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="12"/><RowDefinition Height="*"/><RowDefinition Height="12"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <WrapPanel>
              <Button Content="선택 Component Read-only 검증" Click="ValidationButton_Click" ToolTip="현재 컴포넌트의 안전한 조회 명령을 모두 실행합니다."/>
              <Button Content="전체 Component 통합 검증" Click="ValidateAllButton_Click" ToolTip="6개 컴포넌트 simulator의 read-only 흐름을 한 번에 검증합니다."/>
              <Button Content="1회 Timeout 주입" Click="InjectTimeoutButton_Click"/><Button Content="1회 잘못된 응답 주입" Click="InjectInvalidButton_Click"/>
            </WrapPanel>
            <DataGrid x:Name="StatusGrid" Grid.Row="2" AutoGenerateColumns="False"><DataGrid.Columns><DataGridTextColumn Header="상태 항목" Binding="{Binding Name}" Width="220"/><DataGridTextColumn Header="값" Binding="{Binding Value}" Width="*"/><DataGridTextColumn Header="단위" Binding="{Binding Unit}" Width="100"/><DataGridTextColumn Header="갱신" Binding="{Binding UpdatedAt, StringFormat=HH:mm:ss.fff}" Width="120"/></DataGrid.Columns></DataGrid>
            <GroupBox Grid.Row="4" Header="Hardware 동작 안전 잠금"><WrapPanel><CheckBox x:Name="UnlockCheck" Content="Hardware Write 허용"/><CheckBox x:Name="MotionClearCheck" Content="Motion 영역 확인" Margin="18,5"/><CheckBox x:Name="LaserSafeCheck" Content="Beam Path / Interlock 확인" Margin="18,5"/><CheckBox x:Name="OperatorCheck" Content="작업자 최종 확인" Margin="18,5"/></WrapPanel></GroupBox>
          </Grid>
        </TabItem>
        <TabItem Header="자동 검증 결과"><DataGrid x:Name="ValidationGrid" Margin="12" AutoGenerateColumns="False"><DataGrid.Columns><DataGridCheckBoxColumn Header="통과" Binding="{Binding Passed}" Width="60"/><DataGridTextColumn Header="컴포넌트" Binding="{Binding Equipment}" Width="190"/><DataGridTextColumn Header="항목" Binding="{Binding Item}" Width="170"/><DataGridTextColumn Header="명령" Binding="{Binding Command}" Width="250"/><DataGridTextColumn Header="응답" Binding="{Binding Actual}" Width="*"/><DataGridTextColumn Header="판정" Binding="{Binding Detail}" Width="220"/></DataGrid.Columns></DataGrid></TabItem>
        <TabItem Header="이론 · 동작 · 필수 지식">
          <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="18">
            <TextBlock x:Name="GuideTitleText" FontSize="22" FontWeight="SemiBold"/><TextBlock x:Name="ManualText" Foreground="{StaticResource AccentBrush}" Margin="0,6,0,16"/>
            <GroupBox Header="이론적 특성"><TextBlock x:Name="TheoryText" TextWrapping="Wrap" LineHeight="24"/></GroupBox>
            <GroupBox Header="권장 동작 순서" Margin="0,12,0,0"><TextBlock x:Name="OperationText" TextWrapping="Wrap" LineHeight="24"/></GroupBox>
            <GroupBox Header="반드시 알아야 할 내용" Margin="0,12,0,0"><TextBlock x:Name="NotesText" TextWrapping="Wrap" LineHeight="24"/></GroupBox>
            <GroupBox Header="현재 예제의 검증 범위와 한계" Margin="0,12,0,0"><TextBlock x:Name="LimitText" TextWrapping="Wrap" LineHeight="24" Foreground="{StaticResource WarningBrush}"/></GroupBox>
          </StackPanel></ScrollViewer>
        </TabItem>
        <TabItem Header="통신 Trace"><DataGrid x:Name="TraceGrid" Margin="12" AutoGenerateColumns="False"><DataGrid.Columns><DataGridTextColumn Header="시각" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="105"/><DataGridCheckBoxColumn Header="정상" Binding="{Binding Success}" Width="55"/><DataGridTextColumn Header="컴포넌트" Binding="{Binding Equipment}" Width="170"/><DataGridTextColumn Header="TX" Binding="{Binding Command}" Width="260"/><DataGridTextColumn Header="RX" Binding="{Binding Response}" Width="*"/><DataGridTextColumn Header="ms" Binding="{Binding ElapsedMs, StringFormat=F1}" Width="70"/><DataGridTextColumn Header="메시지" Binding="{Binding Message}" Width="230"/></DataGrid.Columns></DataGrid></TabItem>
      </TabControl>
    </Grid>

    <Border Grid.Row="6" Background="#0D1624" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="5" Padding="10,8"><TextBlock x:Name="FooterText" Text="Simulation 모드에서 6개 컴포넌트 protocol을 안전하게 검증할 수 있습니다." Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap"/></Border>
  </Grid>
</Window>
