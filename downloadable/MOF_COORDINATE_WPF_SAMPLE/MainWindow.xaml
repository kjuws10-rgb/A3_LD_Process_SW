<Window x:Class="MofCoordinateDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MOF Coordinate Matrix Viewer"
        Width="1580"
        Height="980"
        MinWidth="1240"
        MinHeight="780"
        Background="#F4F6F8">
  <Grid Margin="14">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="355"/>
      <ColumnDefinition Width="14"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Background="White"
            BorderBrush="#D5DEE8"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <TextBlock Text="Coordinate Input"
                     FontSize="22"
                     FontWeight="Bold"
                     Foreground="#172033"/>
          <TextBlock Text="AK1, Cell, Scanner, DOE Beam selection"
                     Foreground="#52637A"
                     Margin="0,3,0,12"/>

          <TextBlock Text="Board / Align" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Board X"/><TextBox x:Name="BoardXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Board Y"/><TextBox x:Name="BoardYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="AK Margin X"/><TextBox x:Name="AkMarginXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="AK Margin Y"/><TextBox x:Name="AkMarginYBox"/></StackPanel>
          </UniformGrid>

          <TextBlock Text="Review Camera" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Center X"/><TextBox x:Name="ReviewCenterXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Center Y"/><TextBox x:Name="ReviewCenterYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="U0"/><TextBox x:Name="U0Box"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="V0"/><TextBox x:Name="V0Box"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Scale X"/><TextBox x:Name="ScaleXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Scale Y"/><TextBox x:Name="ScaleYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="AK1 U"/><TextBox x:Name="Ak1UBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="AK1 V"/><TextBox x:Name="Ak1VBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Theta deg"/><TextBox x:Name="ThetaBox"/></StackPanel>
          </UniformGrid>

          <TextBlock Text="Cell / Pattern" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="First X"/><TextBox x:Name="CellFirstXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="First Y"/><TextBox x:Name="CellFirstYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Pitch X"/><TextBox x:Name="CellPitchXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Pitch Y"/><TextBox x:Name="CellPitchYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Pattern Off X"/><TextBox x:Name="PatternOffsetXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Pattern Off Y"/><TextBox x:Name="PatternOffsetYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Columns"/><TextBox x:Name="CellColumnsBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Rows"/><TextBox x:Name="CellRowsBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Selected Col"/><TextBox x:Name="SelectedCellColumnBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Selected Row"/><TextBox x:Name="SelectedCellRowBox"/></StackPanel>
          </UniformGrid>

          <TextBlock Text="Scanner / DOE" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Head Count"/><TextBox x:Name="ScannerCountBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Highlight Heads"/><TextBox x:Name="HighlightHeadsBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="First Center X"/><TextBox x:Name="FirstScannerXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="First Center Y"/><TextBox x:Name="FirstScannerYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Pitch X"/><TextBox x:Name="ScannerPitchXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Even Y Offset"/><TextBox x:Name="EvenYOffsetBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Field Half X"/><TextBox x:Name="FieldHalfXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Field Half Y"/><TextBox x:Name="FieldHalfYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Review Head"/><TextBox x:Name="ReviewBasisHeadBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="DOE Beam 1-16"/><TextBox x:Name="ReviewBasisBeamBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="DOE Pitch X"/><TextBox x:Name="DoePitchXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="DOE Pitch Y"/><TextBox x:Name="DoePitchYBox"/></StackPanel>
          </UniformGrid>

          <TextBlock Text="Review Offset" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,14">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Offset Global X"/><TextBox x:Name="OffsetXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Offset Global Y"/><TextBox x:Name="OffsetYBox"/></StackPanel>
          </UniformGrid>

          <Button x:Name="GenerateButton"
                  Height="40"
                  Content="Generate / Refresh"
                  FontWeight="Bold"
                  Click="GenerateButton_Click"/>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="455"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="105"/>
      </Grid.RowDefinitions>

      <Border Background="White" BorderBrush="#D5DEE8" BorderThickness="1" CornerRadius="8" Padding="12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock x:Name="SummaryText"
                     FontSize="15"
                     Foreground="#25364D"
                     Margin="0,0,0,8"/>
          <Canvas x:Name="LayoutCanvas"
                  Grid.Row="1"
                  Background="#FFFFFF"
                  ClipToBounds="True"/>
        </Grid>
      </Border>

      <Border Grid.Row="2" Background="White" BorderBrush="#D5DEE8" BorderThickness="1" CornerRadius="8" Padding="8">
        <TabControl>
          <TabItem Header="Design Coordinate">
            <DataGrid x:Name="DesignGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      RowHeight="28">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Cell" Binding="{Binding CellIndex}" Width="90"/>
                <DataGridTextColumn Header="Design Local (x, y)" Binding="{Binding DesignLocalMatrix}" Width="170"/>
                <DataGridTextColumn Header="Design Stage (x, y)" Binding="{Binding DesignStageMatrix}" Width="210"/>
                <DataGridTextColumn Header="Selected" Binding="{Binding IsSelectedCell}" Width="90"/>
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
          <TabItem Header="Process Coordinate">
            <DataGrid x:Name="ProcessGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      RowHeight="28">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Cell" Binding="{Binding CellIndex}" Width="90"/>
                <DataGridTextColumn Header="Scanner" Binding="{Binding ScannerName}" Width="85"/>
                <DataGridTextColumn Header="Type" Binding="{Binding ScannerType}" Width="80"/>
                <DataGridTextColumn Header="Process Stage (x, y)" Binding="{Binding ProcessStageMatrix}" Width="210"/>
                <DataGridTextColumn Header="Scanner Relative (x, y)" Binding="{Binding ScannerRelativeMatrix}" Width="210"/>
                <DataGridTextColumn Header="MOF GxGy (x, y)" Binding="{Binding ProcessGMatrix}" Width="180"/>
                <DataGridCheckBoxColumn Header="In Field" Binding="{Binding InField}" Width="85"/>
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
          <TabItem Header="Review Coordinate">
            <DataGrid x:Name="ReviewGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      RowHeight="28">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Head / DOE" Binding="{Binding DoeSelection}" Width="110"/>
                <DataGridTextColumn Header="Cell" Binding="{Binding CellIndex}" Width="90"/>
                <DataGridTextColumn Header="Process Scanner" Binding="{Binding ScannerName}" Width="115"/>
                <DataGridTextColumn Header="Review Reference Stage (x, y)" Binding="{Binding ReviewReferenceMatrix}" Width="230"/>
                <DataGridTextColumn Header="Review Coordinate mm (x, y)" Binding="{Binding ReviewMatrix}" Width="230"/>
                <DataGridTextColumn Header="Review Pixel (u, v)" Binding="{Binding ReviewPixelMatrix}" Width="210"/>
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
          <TabItem Header="DOE 16 Matrix">
            <DataGrid x:Name="DoeGrid"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      RowHeight="28">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Beam" Binding="{Binding BeamNo}" Width="80"/>
                <DataGridTextColumn Header="Row" Binding="{Binding Row}" Width="70"/>
                <DataGridTextColumn Header="Column" Binding="{Binding Column}" Width="80"/>
                <DataGridTextColumn Header="Scanner Offset (x, y)" Binding="{Binding MatrixCoordinate}" Width="220"/>
              </DataGrid.Columns>
            </DataGrid>
          </TabItem>
        </TabControl>
      </Border>

      <Border Grid.Row="4" Background="White" BorderBrush="#D5DEE8" BorderThickness="1" CornerRadius="8" Padding="12">
        <TextBlock x:Name="FormulaText"
                   TextWrapping="Wrap"
                   Foreground="#25364D"/>
      </Border>
    </Grid>
  </Grid>
</Window>
