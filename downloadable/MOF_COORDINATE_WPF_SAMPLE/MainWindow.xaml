<Window x:Class="MofCoordinateDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MOF Coordinate Transform Demo"
        Width="1480"
        Height="920"
        MinWidth="1180"
        MinHeight="760"
        Background="#F5F7FA">
  <Grid Margin="16">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="360"/>
      <ColumnDefinition Width="16"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0"
            Background="White"
            BorderBrush="#D6DEE8"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <TextBlock Text="MOF 좌표 변환 입력"
                     FontSize="22"
                     FontWeight="Bold"
                     Foreground="#172033"
                     Margin="0,0,0,6"/>
          <TextBlock Text="Review AK1 측정값으로 Stage 좌표와 Scanner Gx/Gy를 생성한다."
                     TextWrapping="Wrap"
                     Foreground="#52637A"
                     Margin="0,0,0,14"/>

          <TextBlock Text="Board / Align Key" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Board X"/><TextBox x:Name="BoardXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Board Y"/><TextBox x:Name="BoardYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="AK Margin X"/><TextBox x:Name="AkMarginXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="AK Margin Y"/><TextBox x:Name="AkMarginYBox"/></StackPanel>
          </UniformGrid>

          <TextBlock Text="Review Camera" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Center X"/><TextBox x:Name="ReviewCenterXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Center Y"/><TextBox x:Name="ReviewCenterYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="U0"/><TextBox x:Name="U0Box"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="V0"/><TextBox x:Name="V0Box"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Scale X"/><TextBox x:Name="ScaleXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Scale Y"/><TextBox x:Name="ScaleYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="AK1 U"/><TextBox x:Name="Ak1UBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="AK1 V"/><TextBox x:Name="Ak1VBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Theta deg"/><TextBox x:Name="ThetaBox"/></StackPanel>
          </UniformGrid>

          <TextBlock Text="Cell / Pattern" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="First X"/><TextBox x:Name="CellFirstXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="First Y"/><TextBox x:Name="CellFirstYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Pitch X"/><TextBox x:Name="CellPitchXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Pitch Y"/><TextBox x:Name="CellPitchYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Pattern Off X"/><TextBox x:Name="PatternOffsetXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Pattern Off Y"/><TextBox x:Name="PatternOffsetYBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Columns"/><TextBox x:Name="CellColumnsBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Rows"/><TextBox x:Name="CellRowsBox"/></StackPanel>
          </UniformGrid>

          <TextBlock Text="Scanner Array" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,10">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Count"/><TextBox x:Name="ScannerCountBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="First Center X"/><TextBox x:Name="FirstScannerXBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="First Center Y"/><TextBox x:Name="FirstScannerYBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Pitch X"/><TextBox x:Name="ScannerPitchXBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Even Y Offset"/><TextBox x:Name="EvenYOffsetBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Field Half X"/><TextBox x:Name="FieldHalfXBox"/></StackPanel>
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Field Half Y"/><TextBox x:Name="FieldHalfYBox"/></StackPanel>
          </UniformGrid>

          <TextBlock Text="Review Offset" Style="{StaticResource SectionTitleStyle}"/>
          <UniformGrid Columns="2" Margin="0,4,0,14">
            <StackPanel Margin="0,0,8,8"><TextBlock Text="Offset Global X"/><TextBox x:Name="OffsetXBox"/></StackPanel>
            <StackPanel Margin="0,0,0,8"><TextBlock Text="Offset Global Y"/><TextBox x:Name="OffsetYBox"/></StackPanel>
          </UniformGrid>

          <Button x:Name="GenerateButton"
                  Height="38"
                  Content="Generate Coordinates"
                  FontWeight="Bold"
                  Click="GenerateButton_Click"/>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <Grid Grid.Column="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="310"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="12"/>
        <RowDefinition Height="130"/>
      </Grid.RowDefinitions>

      <Border Background="White" BorderBrush="#D6DEE8" BorderThickness="1" CornerRadius="8" Padding="12">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock x:Name="SummaryText"
                     FontSize="15"
                     Foreground="#25364D"
                     Margin="0,0,0,8"/>
          <Canvas x:Name="LayoutCanvas"
                  Grid.Row="1"
                  Background="#FAFCFF"
                  ClipToBounds="True"/>
        </Grid>
      </Border>

      <Border Grid.Row="2" Background="White" BorderBrush="#D6DEE8" BorderThickness="1" CornerRadius="8" Padding="8">
        <DataGrid x:Name="CommandGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeight="28">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Col" Binding="{Binding Column}" Width="55"/>
            <DataGridTextColumn Header="Row" Binding="{Binding Row}" Width="55"/>
            <DataGridTextColumn Header="Local X" Binding="{Binding LocalX}" Width="90"/>
            <DataGridTextColumn Header="Local Y" Binding="{Binding LocalY}" Width="90"/>
            <DataGridTextColumn Header="Stage X" Binding="{Binding StageX}" Width="105"/>
            <DataGridTextColumn Header="Stage Y" Binding="{Binding StageY}" Width="105"/>
            <DataGridTextColumn Header="Scanner" Binding="{Binding ScannerName}" Width="80"/>
            <DataGridTextColumn Header="Type" Binding="{Binding ScannerType}" Width="75"/>
            <DataGridTextColumn Header="Rel X" Binding="{Binding RelativeX}" Width="90"/>
            <DataGridTextColumn Header="Rel Y" Binding="{Binding RelativeY}" Width="90"/>
            <DataGridTextColumn Header="Gx" Binding="{Binding Gx}" Width="90"/>
            <DataGridTextColumn Header="Gy" Binding="{Binding Gy}" Width="90"/>
            <DataGridCheckBoxColumn Header="In Field" Binding="{Binding InField}" Width="80"/>
          </DataGrid.Columns>
        </DataGrid>
      </Border>

      <Border Grid.Row="4" Background="White" BorderBrush="#D6DEE8" BorderThickness="1" CornerRadius="8" Padding="12">
        <TextBlock TextWrapping="Wrap" Foreground="#25364D">
          <Run FontWeight="Bold" Text="Formula: "/>
          <Run Text="AK1_global = ReviewCenter + (MeasuredPixel - PixelCenter) * PixelScale, "/>
          <Run Text="P_global = AK1_global + R(theta) * P_local + ReviewOffset, "/>
          <Run Text="D = P_global - ScannerCenter, "/>
          <Run Text="Odd(Gx=-Dx,Gy=+Dy), Even(Gx=+Dx,Gy=-Dy). "/>
          <Run Text="Review 보정은 Global Error의 반대 방향을 ProcessOffset으로 누적해서 다음 Plan 생성 시 반영한다."/>
        </TextBlock>
      </Border>
    </Grid>
  </Grid>
</Window>
