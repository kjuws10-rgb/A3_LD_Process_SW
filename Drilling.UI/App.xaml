<Application x:Class="Drilling.UI.CApp"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Background" Value="#2F81F7" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#58A6FF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#161B22" />
            <Setter Property="Foreground" Value="#DDE6EF" />
            <Setter Property="BorderBrush" Value="#30363D" />
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="#10151E" />
            <Setter Property="BorderBrush" Value="#273241" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14" />
        </Style>

        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F3F6FA" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <DataTemplate x:Key="DisplayItemRowTemplate">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="128" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}"
                           Foreground="#8B98A8"
                           FontSize="12"
                           TextWrapping="Wrap" />
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding Value}"
                               Foreground="#F3F6FA"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Detail}"
                               Foreground="#6F7B8A"
                               FontSize="11"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <Style x:Key="PlainDataGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#0F141C" />
            <Setter Property="Foreground" Value="#E6EDF3" />
            <Setter Property="RowBackground" Value="#0F141C" />
            <Setter Property="AlternatingRowBackground" Value="#121A24" />
            <Setter Property="HorizontalGridLinesBrush" Value="#273241" />
            <Setter Property="VerticalGridLinesBrush" Value="#273241" />
            <Setter Property="ColumnHeaderStyle">
                <Setter.Value>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#151C26" />
                        <Setter Property="Foreground" Value="#B6C2CF" />
                        <Setter Property="BorderBrush" Value="#273241" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                        <Setter Property="Padding" Value="8,6" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="CellStyle">
                <Setter.Value>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Foreground" Value="#E6EDF3" />
                        <Setter Property="BorderBrush" Value="#273241" />
                        <Setter Property="Padding" Value="6,4" />
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
