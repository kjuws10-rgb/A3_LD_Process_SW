<Window x:Class="Drilling.UI.Popup.CInterfaceStatusDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Interface Status"
        Width="760"
        Height="520"
        MinWidth="680"
        MinHeight="460"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="#07111B"
        Foreground="#F3F6FA"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="130" />
            <Setter Property="Foreground" Value="#F3F6FA" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#101923" />
            <Setter Property="BorderBrush" Value="#344251" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#00D8FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0759C8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#101923"
            BorderBrush="#344251"
            BorderThickness="1"
            Padding="22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText"
                       Grid.Row="0"
                       FontSize="24"
                       FontWeight="SemiBold"
                       Foreground="#F3F6FA" />

            <TextBlock x:Name="SummaryText"
                       Grid.Row="1"
                       Margin="0,6,0,16"
                       FontSize="13"
                       Foreground="#8B98A8" />

            <DataGrid x:Name="StatusGrid"
                      Grid.Row="2"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="All"
                      RowHeaderWidth="0"
                      RowHeight="38"
                      ColumnHeaderHeight="36"
                      Background="#07111B"
                      Foreground="#F3F6FA"
                      BorderBrush="#263847"
                      HorizontalGridLinesBrush="#263847"
                      VerticalGridLinesBrush="#263847"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#162331" />
                        <Setter Property="Foreground" Value="#C9D6E2" />
                        <Setter Property="FontSize" Value="12" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Padding" Value="10,0" />
                        <Setter Property="BorderBrush" Value="#263847" />
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Background" Value="#0B1119" />
                        <Setter Property="Foreground" Value="#F3F6FA" />
                        <Setter Property="BorderBrush" Value="#263847" />
                        <Setter Property="Padding" Value="8,0" />
                        <Setter Property="VerticalContentAlignment" Value="Center" />
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="No."
                                        Binding="{Binding No}"
                                        Width="64" />
                    <DataGridTextColumn Header="Nick Name"
                                        Binding="{Binding NickName}"
                                        Width="150" />
                    <DataGridTextColumn Header="Type"
                                        Binding="{Binding InterfaceType}"
                                        Width="120" />
                    <DataGridTemplateColumn Header="State"
                                            Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding State}"
                                           Foreground="{Binding StateBrush}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Endpoint"
                                        Binding="{Binding Endpoint}"
                                        Width="*" />
                    <DataGridTextColumn Header="Last Changed"
                                        Binding="{Binding LastChangedText}"
                                        Width="150" />
                </DataGrid.Columns>
            </DataGrid>

            <Button Grid.Row="3"
                    Style="{StaticResource DialogButton}"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0"
                    Content="CLOSE"
                    Click="OnCloseClicked" />
        </Grid>
    </Border>
</Window>
