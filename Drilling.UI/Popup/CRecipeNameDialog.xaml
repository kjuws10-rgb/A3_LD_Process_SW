<Window x:Class="Drilling.UI.Popup.CRecipeNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recipe Name"
        Width="500"
        MinHeight="300"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource GridBackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}"
        FontFamily="Segoe UI">
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource ButtonSecondaryBrush}"
            BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}"
            BorderThickness="1"
            Padding="22">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="TitleText"
                       Grid.Row="0"
                       FontSize="23"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" />

            <TextBlock x:Name="MessageText"
                       Grid.Row="1"
                       Margin="0,8,0,0"
                       FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}" />

            <TextBox x:Name="RecipeNameTextBox"
                     Grid.Row="2"
                     Margin="0,22,0,0"
                     Height="42"
                     Padding="12,8"
                     Background="{DynamicResource GridBackgroundBrush}"
                     BorderBrush="{DynamicResource ButtonPrimaryBorderBrush}"
                     BorderThickness="1"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                     FontSize="16"
                     FontWeight="SemiBold"
                     TextChanged="OnRecipeNameTextChanged"
                     KeyDown="OnRecipeNameKeyDown" />

            <TextBlock x:Name="ErrorText"
                       Grid.Row="3"
                       Margin="0,8,0,0"
                       FontSize="12"
                       Foreground="{DynamicResource ButtonDangerBorderBrush}"
                       Visibility="Collapsed" />

            <TextBlock Grid.Row="4"
                       Margin="0,8,0,0"
                       Text="File extension is added automatically."
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}" />

            <Grid Grid.Row="5" Margin="0,18,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="OkButton"
                        Style="{StaticResource DialogButton}"
                        Background="{DynamicResource ButtonPrimaryBrush}"
                        BorderBrush="{DynamicResource ButtonPrimaryBorderBrush}"
                        Content="OK"
                        Click="OnOkClicked" />

                <Button Grid.Column="2"
                        Style="{StaticResource DialogButton}"
                        Background="{DynamicResource ButtonSecondaryBrush}"
                        BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}"
                        Content="CANCEL"
                        Click="OnCancelClicked" />
            </Grid>
        </Grid>
    </Border>
</Window>


