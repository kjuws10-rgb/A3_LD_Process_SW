<UserControl x:Class="Drilling.UI.Views.CSettingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="SettingSmallText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B6C2CF" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="SettingValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F3F6FA" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="SettingTabButton" TargetType="Button">
            <Setter Property="Height" Value="52" />
            <Setter Property="Background" Value="#101923" />
            <Setter Property="BorderBrush" Value="#344251" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#DDE6EF" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingCommandButton" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="118" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#101923" />
            <Setter Property="BorderBrush" Value="#344251" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#DDE6EF" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter x:Name="ButtonContent"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome" Property="Background" Value="#1A2028" />
                                <Setter TargetName="ButtonChrome" Property="BorderBrush" Value="#303A46" />
                                <Setter TargetName="ButtonContent" Property="Opacity" Value="0.42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#748191" />
                    <Setter Property="Cursor" Value="Arrow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingGroupButton" TargetType="Button">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Visibility="{Binding CurrentScreen.IsSettingLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="SETTING / PARAMETER CONFIG"
                       Foreground="#F3F6FA"
                       FontSize="31"
                       FontWeight="SemiBold" />
            <TextBlock Text="Direct grid edit for option, interface, IO and motor parameters"
                       Foreground="#B6C2CF"
                       FontSize="16" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="230" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="58" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ItemsControl Grid.Row="0"
                              ItemsSource="{Binding CurrentScreen.Setting.TabItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                    Command="{Binding DataContext.CurrentScreen.Setting.SelectTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding Name}"
                                    Margin="0,0,4,0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource SettingTabButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="#0B3B78" />
                                                <Setter Property="BorderBrush" Value="#2F81F7" />
                                                <Setter Property="Foreground" Value="#27C7F7" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Grid Grid.Row="1" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Setting Group"
                                       Style="{StaticResource PanelTitle}"
                                       FontSize="18" />
                            <ItemsControl ItemsSource="{Binding CurrentScreen.Setting.GroupItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.CurrentScreen.Setting.SelectGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Name}"
                                                Style="{StaticResource SettingGroupButton}">
                                            <Border Height="58"
                                                    Margin="0,0,0,8"
                                                    Padding="0"
                                                    BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#0B1119" />
                                                        <Setter Property="BorderBrush" Value="#263847" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#082B38" />
                                                                <Setter Property="BorderBrush" Value="#00D8FF" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="5" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="28" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="Transparent" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Background" Value="#FF2F6D" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                    </Border>
                                                    <TextBlock Text="{Binding Name}"
                                                               Grid.Column="1"
                                                               Margin="14,0,0,0"
                                                               VerticalAlignment="Center"
                                                               FontSize="16"
                                                               FontWeight="SemiBold">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#F3F6FA" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                        <Setter Property="Foreground" Value="#27C7F7" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <Path Grid.Column="2"
                                                          Data="M4,4 L12,12 L4,20"
                                                          Stroke="#27C7F7"
                                                          StrokeThickness="2.4"
                                                          StrokeStartLineCap="Round"
                                                          StrokeEndLineCap="Round"
                                                          StrokeLineJoin="Round"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="1" Margin="12,0,0,0" Style="{StaticResource PanelBorder}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding CurrentScreen.Setting.SelectedTab, StringFormat={}{0} Parameter}"
                                           Style="{StaticResource PanelTitle}"
                                           FontSize="18" />

                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <Button Style="{StaticResource SettingCommandButton}"
                                            Background="#0B4EA2"
                                            BorderBrush="#2F81F7"
                                            Width="154"
                                            Margin="0,0,10,0"
                                            IsEnabled="{Binding CurrentScreen.Setting.CanOperateSelectedInterface}"
                                            Command="{Binding CurrentScreen.Setting.ConnectInterfaceCommand}"
                                            Visibility="{Binding CurrentScreen.Setting.IsInterfaceTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                                                <Path Data="M7,4 V9 M17,4 V9 M6,9 H18 V13 C18,16 16,18 13,18 H11 C8,18 6,16 6,13 V9 Z M12,18 V22"
                                                      Stroke="#F3F6FA"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Fill="Transparent" />
                                            </Viewbox>
                                            <TextBlock Grid.Column="1" Text="CONNECT" VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                    <Button Style="{StaticResource SettingCommandButton}"
                                            Background="#9F143B"
                                            BorderBrush="#FF2F6D"
                                            Width="154"
                                            Margin="0,0,10,0"
                                            IsEnabled="{Binding CurrentScreen.Setting.CanOperateSelectedInterface}"
                                            Command="{Binding CurrentScreen.Setting.DisconnectInterfaceCommand}"
                                            Visibility="{Binding CurrentScreen.Setting.IsInterfaceTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                                                <Path Data="M7,4 V9 M17,4 V9 M6,9 H18 V13 C18,16 16,18 13,18 H11 C8,18 6,16 6,13 V9 Z M12,18 V22 M4,20 L20,4"
                                                      Stroke="#F3F6FA"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Fill="Transparent" />
                                            </Viewbox>
                                            <TextBlock Grid.Column="1" Text="DISCONNECT" VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                    <Button Style="{StaticResource SettingCommandButton}"
                                            Background="#0A8F4A"
                                            BorderBrush="#12D466"
                                            Width="112"
                                            Margin="0,0,10,0"
                                            Command="{Binding CurrentScreen.Setting.SaveCommand}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                                                <Path Data="M5,4 H17 L20,7 V20 H4 V4 Z M8,4 V10 H16 V4 M8,17 H16"
                                                      Stroke="#F3F6FA"
                                                      StrokeThickness="2"
                                                      StrokeLineJoin="Round"
                                                      Fill="Transparent" />
                                            </Viewbox>
                                            <TextBlock Grid.Column="1" Text="SAVE" VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                    <Button Style="{StaticResource SettingCommandButton}"
                                            Width="116"
                                            Margin="0,0,10,0"
                                            Command="{Binding CurrentScreen.Setting.CancelCommand}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                                                <Path Data="M5,5 L19,19 M19,5 L5,19"
                                                      Stroke="#8B98A8"
                                                      StrokeThickness="2.2"
                                                      StrokeStartLineCap="Round" />
                                            </Viewbox>
                                            <TextBlock Grid.Column="1" Text="CANCEL" VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                    <Button Style="{StaticResource SettingCommandButton}"
                                            Width="116"
                                            Command="{Binding CurrentScreen.Setting.ReloadCommand}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="34" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                                                <Path Data="M18,9 C17,6 15,4 12,4 C8,4 5,7 5,11 C5,15 8,18 12,18 C15,18 17,16 18,14 M18,5 V9 H14"
                                                      Stroke="#8B98A8"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Fill="Transparent" />
                                            </Viewbox>
                                            <TextBlock Grid.Column="1" Text="RELOAD" VerticalAlignment="Center" />
                                        </Grid>
                                    </Button>
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <DataGrid Grid.Row="0"
                                          ItemsSource="{Binding CurrentScreen.Setting.ParameterRows}"
                                          IsReadOnly="False"
                                          Style="{StaticResource PlainDataGrid}"
                                          FontSize="13"
                                          ColumnHeaderHeight="42"
                                          RowHeight="40"
                                          Visibility="{Binding CurrentScreen.Setting.IsParameterTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="120" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Parameter" Binding="{Binding Parameter}" Width="180" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Value" Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="240">
                                            <DataGridTextColumn.ElementStyle>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{Binding ValueBrush}" />
                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                </Style>
                                            </DataGridTextColumn.ElementStyle>
                                        </DataGridTextColumn>
                                        <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="90" IsReadOnly="True" />
                                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" IsReadOnly="True" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <Border Grid.Row="0"
                                        Grid.RowSpan="2"
                                        Style="{StaticResource PanelBorder}"
                                        Visibility="{Binding CurrentScreen.Setting.IsInterfaceTab, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top"
                                                   Text="JHMI_INTERFACE.csv"
                                                   Style="{StaticResource PanelTitle}"
                                                   FontSize="18" />
                                        <DataGrid ItemsSource="{Binding CurrentScreen.Setting.InterfaceRows}"
                                                  SelectedItem="{Binding CurrentScreen.Setting.SelectedInterfaceRow, Mode=TwoWay}"
                                                  IsReadOnly="False"
                                                  Style="{StaticResource PlainDataGrid}"
                                                  FontSize="12"
                                                  ColumnHeaderHeight="40"
                                                  RowHeight="38"
                                                  SelectionMode="Single"
                                                  SelectionUnit="FullRow"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                                            <DataGrid.RowStyle>
                                                <Style TargetType="DataGridRow">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="BorderBrush" Value="Transparent" />
                                                    <Setter Property="BorderThickness" Value="0" />
                                                    <Setter Property="Foreground" Value="#E6EDF3" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#122334" />
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#073B5C" />
                                                            <Setter Property="BorderBrush" Value="#00D5FF" />
                                                            <Setter Property="BorderThickness" Value="4,0,0,0" />
                                                            <Setter Property="Foreground" Value="#F6FAFF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.RowStyle>
                                            <DataGrid.CellStyle>
                                                <Style TargetType="DataGridCell">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Foreground" Value="#E6EDF3" />
                                                    <Setter Property="BorderBrush" Value="#273241" />
                                                    <Setter Property="BorderThickness" Value="0,0,1,0" />
                                                    <Setter Property="Padding" Value="6,4" />
                                                    <Style.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter Property="Background" Value="#073B5C" />
                                                            <Setter Property="Foreground" Value="#F6FAFF" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </DataGrid.CellStyle>
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="No." Binding="{Binding No}" Width="48" />
                                                <DataGridTextColumn Header="TYPE" Binding="{Binding Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="126" />
                                                <DataGridTextColumn Header="DEVICE" Binding="{Binding Device, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="142" />
                                                <DataGridTextColumn Header="NUMBER" Binding="{Binding Number, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="78" />
                                                <DataGridTextColumn Header="NICKNAME" Binding="{Binding NickName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="142" />
                                                <DataGridTextColumn Header="SYSTEM_SECTION" Binding="{Binding SystemSection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="140" />
                                                <DataGridTextColumn Header="AUTOCONNECTION" Binding="{Binding AutoConnection, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="132" />
                                                <DataGridTextColumn Header="SIMUL" Binding="{Binding Simul, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="82">
                                                    <DataGridTextColumn.ElementStyle>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{Binding SimulBrush}" />
                                                            <Setter Property="FontWeight" Value="SemiBold" />
                                                        </Style>
                                                    </DataGridTextColumn.ElementStyle>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Header="ARG1" Binding="{Binding Arg1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="122" />
                                                <DataGridTextColumn Header="ARG2" Binding="{Binding Arg2, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="122" />
                                                <DataGridTextColumn Header="ARG3" Binding="{Binding Arg3, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="92" />
                                                <DataGridTextColumn Header="ARG4" Binding="{Binding Arg4, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="92" />
                                                <DataGridTextColumn Header="ARG5" Binding="{Binding Arg5, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="82" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Change History"
                                   Style="{StaticResource PanelTitle}"
                                   FontSize="18" />

                        <ItemsControl Grid.Column="1"
                                      ItemsSource="{Binding CurrentScreen.Setting.SummaryRows}"
                                      HorizontalAlignment="Right">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="260" Height="30" Margin="18,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}"
                                                   HorizontalAlignment="Right"
                                                   Style="{StaticResource SettingSmallText}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   HorizontalAlignment="Right"
                                                   Foreground="{Binding ValueBrush}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding CurrentScreen.Setting.ChangeHistory}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              FontSize="12"
                              ColumnHeaderHeight="42"
                              RowHeight="42">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="110" />
                            <DataGridTextColumn Header="User" Binding="{Binding User}" Width="100" />
                            <DataGridTextColumn Header="Tab" Binding="{Binding Tab}" Width="110" />
                            <DataGridTextColumn Header="Parameter" Binding="{Binding Parameter}" Width="260" />
                            <DataGridTextColumn Header="Before" Binding="{Binding Before}" Width="*" />
                            <DataGridTextColumn Header="After" Binding="{Binding After}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding AfterBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
