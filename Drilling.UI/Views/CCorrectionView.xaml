<UserControl x:Class="Drilling.UI.Views.CCorrectionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="CorrectionLabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="CorrectionValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="CorrectionTabButton" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="{DynamicResource ButtonSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1,1,1,3" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5,5,0,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CorrectionCommandButton" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonTextOnColorBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Visibility="{Binding CurrentScreen.IsCorrectionLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="64" />
            <RowDefinition Height="50" />
            <RowDefinition Height="78" />
            <RowDefinition Height="*" />
            <RowDefinition Height="188" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Top">
                <TextBlock Text="{Binding CurrentScreen.Correction.Title}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="31"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding CurrentScreen.Correction.Subtitle}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="15" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Content="LOAD"
                        Command="{Binding CurrentScreen.Correction.ExecuteCommand}"
                        CommandParameter="LOAD"
                        Style="{StaticResource CorrectionCommandButton}"
                        Background="{DynamicResource ButtonSecondaryBrush}"
                        BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}"
                        Foreground="{DynamicResource TextSecondaryBrush}" />
                <Button Content="CALCULATE"
                        Command="{Binding CurrentScreen.Correction.ExecuteCommand}"
                        CommandParameter="CALCULATE"
                        Style="{StaticResource CorrectionCommandButton}"
                        Background="{DynamicResource ButtonPrimaryBrush}"
                        BorderBrush="{DynamicResource ButtonPrimaryBorderBrush}" />
                <Button Content="APPLY"
                        Command="{Binding CurrentScreen.Correction.ExecuteCommand}"
                        CommandParameter="APPLY"
                        Style="{StaticResource CorrectionCommandButton}"
                        Background="{DynamicResource ButtonSuccessBrush}"
                        BorderBrush="{DynamicResource ButtonSuccessBorderBrush}" />
                <Button Content="SAVE"
                        Command="{Binding CurrentScreen.Correction.ExecuteCommand}"
                        CommandParameter="SAVE"
                        Style="{StaticResource CorrectionCommandButton}"
                        Background="{DynamicResource ButtonWarningBrush}"
                        BorderBrush="{DynamicResource ButtonWarningBorderBrush}"
                        Margin="0" />
            </StackPanel>
        </Grid>

        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding CurrentScreen.Correction.Tabs}"
                      Margin="0,2,0,4">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Name}"
                            Command="{Binding DataContext.CurrentScreen.Correction.SelectTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding Name}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource CorrectionTabButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource MenuItemSelectedBackgroundBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource MenuItemSelectedBorderBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource MenuItemSelectedTextBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl Grid.Row="2"
                      ItemsSource="{Binding CurrentScreen.Correction.SummaryItems}"
                      Margin="0,0,0,12">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource PanelBorder}"
                            Padding="16,10"
                            Margin="0,0,10,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Name}"
                                       Style="{StaticResource CorrectionLabelText}" />
                            <TextBlock Grid.Row="1"
                                       Text="{Binding Value}"
                                       Foreground="{Binding ValueBrush}"
                                       FontSize="21"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Bottom"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource PanelBorder}"
                    Margin="0,0,12,12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Correction Source"
                               Style="{StaticResource PanelTitle}"
                               FontSize="18" />
                    <DataGrid ItemsSource="{Binding CurrentScreen.Correction.SourceRows}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              FontSize="12"
                              ColumnHeaderHeight="40"
                              RowHeight="40"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="86" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="150" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="170" />
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="78">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding StateBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="150" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource PanelBorder}"
                    Margin="0,0,12,12">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Correction Candidate"
                               Style="{StaticResource PanelTitle}"
                               FontSize="18" />
                    <DataGrid ItemsSource="{Binding CurrentScreen.Correction.CandidateRows}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              FontSize="13"
                              ColumnHeaderHeight="42"
                              RowHeight="42"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="190" />
                            <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="170" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="150">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding ValueBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="80" />
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="110">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding StateBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Grid Grid.Column="2"
                  Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="150" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelBorder}"
                        Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Detail"
                                   Style="{StaticResource PanelTitle}"
                                   FontSize="18" />
                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding CurrentScreen.Correction.DetailItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="122" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource CorrectionLabelText}" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Value}"
                                                   Style="{StaticResource CorrectionValueText}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource PanelBorder}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Apply Preview"
                                   Style="{StaticResource PanelTitle}"
                                   FontSize="18" />
                        <DataGrid ItemsSource="{Binding CurrentScreen.Correction.ApplyRows}"
                                  IsReadOnly="True"
                                  Style="{StaticResource PlainDataGrid}"
                                  FontSize="12"
                                  ColumnHeaderHeight="40"
                                  RowHeight="39"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="160" />
                                <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="120" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="160">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding ValueBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="70" />
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="90" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="4"
                Style="{StaticResource PanelBorder}"
                Margin="0,0,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Correction History"
                           Style="{StaticResource PanelTitle}"
                           FontSize="18" />
                <DataGrid ItemsSource="{Binding CurrentScreen.Correction.HistoryRows}"
                          IsReadOnly="True"
                          Style="{StaticResource PlainDataGrid}"
                          FontSize="12"
                          ColumnHeaderHeight="38"
                          RowHeight="34"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="96" />
                        <DataGridTextColumn Header="User" Binding="{Binding User}" Width="80" />
                        <DataGridTextColumn Header="Tab" Binding="{Binding Tab}" Width="150" />
                        <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="220" />
                        <DataGridTextColumn Header="Before" Binding="{Binding Before}" Width="*" MinWidth="150" />
                        <DataGridTextColumn Header="After" Binding="{Binding After}" Width="*" MinWidth="150" />
                        <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{Binding ResultBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
