<UserControl x:Class="Drilling.UI.Views.CAlarmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="AlarmSmallText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B6C2CF" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="AlarmValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F3F6FA" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="AlarmActionButton" TargetType="Button">
            <Setter Property="Height" Value="62" />
            <Setter Property="Foreground" Value="#F3F6FA" />
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Visibility="{Binding CurrentScreen.IsAlarmLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="62" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="ALARM / CURRENT HISTORY"
                       Foreground="#F3F6FA"
                       FontSize="28"
                       FontWeight="SemiBold" />
            <TextBlock Text="Current alarm, reset, buzzer off, history and trend"
                       Foreground="#B6C2CF"
                       FontSize="15" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="360" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="668" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelBorder}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Current Alarm"
                               Style="{StaticResource PanelTitle}"
                               FontSize="18" />
                    <DataGrid ItemsSource="{Binding CurrentScreen.Alarm.CurrentAlarmRows}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              ColumnHeaderHeight="42"
                              RowHeight="38"
                              FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="86">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#FFC400" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="80">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding LevelBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Device" Binding="{Binding Device}" Width="122" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="190" />
                            <DataGridTextColumn Header="Cause" Binding="{Binding Cause}" Width="190" />
                            <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="140" />
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="84" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Margin="12,0,0,0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="88" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Alarm Action"
                               Style="{StaticResource PanelTitle}"
                               FontSize="18" />

                    <Grid Grid.Row="1" Margin="0,8,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Background="#E00046"
                                BorderBrush="#FF2F6D"
                                Style="{StaticResource AlarmActionButton}"
                                Margin="0,0,10,0"
                                Command="{Binding CurrentScreen.Alarm.AlarmResetCommand}">
                            <Grid Width="190">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="28" Height="28" HorizontalAlignment="Center">
                                    <Canvas Width="32" Height="32">
                                        <Path Data="M8,22 H24 M11,22 V13 C11,9 13.5,7 16,7 C18.5,7 21,9 21,13 V22 M13,25 H19 M16,4 V7"
                                              Stroke="#F3F6FA"
                                              StrokeThickness="2.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="ALARM RESET" VerticalAlignment="Center" />
                            </Grid>
                        </Button>

                        <Button Grid.Column="1"
                                Background="#101923"
                                BorderBrush="#344251"
                                Style="{StaticResource AlarmActionButton}"
                                Command="{Binding CurrentScreen.Alarm.BuzzerOffCommand}">
                            <Grid Width="190">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="48" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="28" Height="28" HorizontalAlignment="Center">
                                    <Canvas Width="32" Height="32">
                                        <Path Data="M8,21 H23 M11,21 V13 C11,9 13.5,7 16,7 C18.5,7 21,9 21,13 V21 M13,24 H19 M7,6 L25,25"
                                              Stroke="#DDE6EF"
                                              StrokeThickness="2.4"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1" Text="BUZZER OFF" VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                    </Grid>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding CurrentScreen.Alarm.DetailRows}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              ColumnHeaderHeight="0"
                              RowHeight="40"
                              HeadersVisibility="None"
                              FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding Name}" Width="150" />
                            <DataGridTextColumn Binding="{Binding Value}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding ValueBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="0" Margin="0,12,0,0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="44" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Alarm History"
                               Style="{StaticResource PanelTitle}"
                               FontSize="18" />

                    <Grid Grid.Row="1" Margin="0,4,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="110" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Date" VerticalAlignment="Center" Style="{StaticResource AlarmSmallText}" />
                        <Border Grid.Column="1" Background="#101923" BorderBrush="#344251" BorderThickness="1" Margin="8,0,0,0">
                            <TextBlock Text="2026-05-15" Margin="10,0" VerticalAlignment="Center" Style="{StaticResource AlarmValueText}" FontSize="13" />
                        </Border>
                        <TextBlock Grid.Column="2" Text="~" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#8B98A8" />
                        <Border Grid.Column="3" Background="#101923" BorderBrush="#344251" BorderThickness="1">
                            <TextBlock Text="2026-05-15" Margin="10,0" VerticalAlignment="Center" Style="{StaticResource AlarmValueText}" FontSize="13" />
                        </Border>
                        <TextBlock Grid.Column="4" Text="Level" VerticalAlignment="Center" Margin="14,0,0,0" Style="{StaticResource AlarmSmallText}" />
                        <Border Grid.Column="5" Background="#101923" BorderBrush="#344251" BorderThickness="1">
                            <TextBlock Text="ALL" Margin="10,0" VerticalAlignment="Center" Style="{StaticResource AlarmValueText}" FontSize="13" />
                        </Border>
                        <TextBlock Grid.Column="6" Text="Device" VerticalAlignment="Center" Margin="14,0,0,0" Style="{StaticResource AlarmSmallText}" />
                        <Border Grid.Column="7" Background="#101923" BorderBrush="#344251" BorderThickness="1">
                            <TextBlock Text="ALL" Margin="10,0" VerticalAlignment="Center" Style="{StaticResource AlarmValueText}" FontSize="13" />
                        </Border>
                        <Border Grid.Column="8" Background="#101923" BorderBrush="#344251" BorderThickness="1" Margin="8,0,0,0">
                            <TextBlock Text="Code / Message" Margin="10,0" VerticalAlignment="Center" Foreground="#6F7B8A" FontSize="12" />
                        </Border>
                    </Grid>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding CurrentScreen.Alarm.HistoryRows}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              ColumnHeaderHeight="40"
                              RowHeight="34"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="86" />
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="82" />
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="90">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding LevelBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Device" Binding="{Binding Device}" Width="126" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" />
                            <DataGridTextColumn Header="Reset User" Binding="{Binding ResetUser}" Width="110" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Margin="12,12,0,0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="244" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Alarm Trend (Last 24 Hours)"
                                   Style="{StaticResource PanelTitle}"
                                   FontSize="18" />
                        <Border Grid.Column="1"
                                Background="#101923"
                                BorderBrush="#344251"
                                BorderThickness="1"
                                Height="34"
                                Margin="0,0,0,8">
                            <TextBlock Text="Group By    Hour"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Style="{StaticResource AlarmSmallText}" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="1" Margin="8,2,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="510" />
                            <ColumnDefinition Width="112" />
                        </Grid.ColumnDefinitions>

                        <Canvas Width="510" Height="206" Background="#071016">
                            <Rectangle Width="510" Height="170" Canvas.Top="0" Stroke="#263847" StrokeThickness="1" Fill="#071016" />
                            <Line X1="0" Y1="34" X2="510" Y2="34" Stroke="#263847" />
                            <Line X1="0" Y1="68" X2="510" Y2="68" Stroke="#263847" />
                            <Line X1="0" Y1="102" X2="510" Y2="102" Stroke="#263847" />
                            <Line X1="0" Y1="136" X2="510" Y2="136" Stroke="#263847" />
                            <ItemsControl Canvas.Left="8" Canvas.Top="0" ItemsSource="{Binding CurrentScreen.Alarm.TrendBars}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="38" Height="206">
                                            <Canvas Width="38" Height="170">
                                                <Rectangle Width="10" Height="{Binding Motion}" Fill="#FFC400" Canvas.Left="14" Canvas.Bottom="0" />
                                                <Rectangle Width="10" Height="{Binding Chiller}" Fill="#12D466" Canvas.Left="14" Canvas.Bottom="{Binding Motion}" />
                                                <Rectangle Width="10" Height="{Binding Laser}" Fill="#FF2F6D" Canvas.Left="14" Canvas.Top="124" />
                                                <Rectangle Width="10" Height="{Binding Scanner}" Fill="#27C7F7" Canvas.Left="14" Canvas.Top="104" />
                                            </Canvas>
                                            <TextBlock Text="{Binding Time}" Canvas.Top="178" Foreground="#B6C2CF" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Bottom" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Polyline Points="8,116 46,128 84,124 122,54 160,106 198,110 236,82 274,108 312,128 350,110 388,126 426,114 464,126"
                                      Stroke="#DDE6EF"
                                      StrokeThickness="1.8"
                                      Fill="Transparent" />
                        </Canvas>

                        <StackPanel Grid.Column="1" Margin="14,10,0,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Rectangle Width="16" Height="4" Fill="#27C7F7" VerticalAlignment="Center" />
                                <TextBlock Text="Scanner" Margin="8,0,0,0" Style="{StaticResource AlarmSmallText}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Rectangle Width="16" Height="4" Fill="#FF2F6D" VerticalAlignment="Center" />
                                <TextBlock Text="Laser" Margin="8,0,0,0" Style="{StaticResource AlarmSmallText}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Rectangle Width="16" Height="4" Fill="#12D466" VerticalAlignment="Center" />
                                <TextBlock Text="Chiller" Margin="8,0,0,0" Style="{StaticResource AlarmSmallText}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Rectangle Width="16" Height="4" Fill="#FFC400" VerticalAlignment="Center" />
                                <TextBlock Text="Motion" Margin="8,0,0,0" Style="{StaticResource AlarmSmallText}" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="7" Height="7" Stroke="#DDE6EF" StrokeThickness="1.5" VerticalAlignment="Center" />
                                <TextBlock Text="Total" Margin="8,0,0,0" Style="{StaticResource AlarmSmallText}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding CurrentScreen.Alarm.SummaryItems}"
                                  Margin="0,4,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#263847" BorderThickness="1" Padding="10">
                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" Style="{StaticResource AlarmSmallText}" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding Value}"
                                                   Margin="0,8,0,0"
                                                   Foreground="{Binding ValueBrush}"
                                                   FontSize="26"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
