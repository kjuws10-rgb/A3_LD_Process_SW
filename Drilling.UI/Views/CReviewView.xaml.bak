<UserControl x:Class="Drilling.UI.Views.CReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="ReviewLabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ReviewValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ReviewPanelTitle" TargetType="TextBlock" BasedOn="{StaticResource PanelTitle}">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Margin" Value="0,0,0,12" />
        </Style>

        <Style x:Key="ReviewModeButton" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Background" Value="{DynamicResource ButtonSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReviewTabButton" TargetType="Button">
            <Setter Property="Height" Value="46" />
            <Setter Property="MinWidth" Value="170" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="24,0" />
            <Setter Property="Background" Value="{DynamicResource ButtonSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1,1,1,3" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5,5,0,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReviewCommandButton" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="MinWidth" Value="112" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReviewComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ReviewComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ReviewComboBoxItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="4">
                                            <Grid Margin="10,0">
                                                <ContentPresenter HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <Path Data="M 0 0 L 5 5 L 10 0 Z"
                                                      Fill="{DynamicResource TextSecondaryBrush}"
                                                      Width="10"
                                                      Height="5"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource GridBackgroundBrush}"
                                        BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}"
                                        BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="220">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ReviewStateText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Grid Visibility="{Binding CurrentScreen.IsReviewLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="62" />
            <RowDefinition Height="50" />
            <RowDefinition Height="78" />
            <RowDefinition Height="*" />
            <RowDefinition Height="228" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <StackPanel VerticalAlignment="Top">
                <TextBlock Text="{Binding CurrentScreen.Review.Title}"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           FontSize="31"
                           FontWeight="SemiBold" />
                <TextBlock Text="{Binding CurrentScreen.Review.Subtitle}"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           FontSize="15" />
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Button Command="{Binding CurrentScreen.Review.StartCommand}"
                        Style="{StaticResource ReviewCommandButton}"
                        Background="{DynamicResource ButtonSuccessBrush}"
                        BorderBrush="{DynamicResource StatusReadyBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M6,4 L18,12 L6,20 Z"
                              Fill="{DynamicResource TextPrimaryBrush}"
                              Width="14"
                              Height="14"
                              Stretch="Uniform"
                              Margin="0,0,8,0" />
                        <TextBlock Text="START" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding CurrentScreen.Review.StopCommand}"
                        Style="{StaticResource ReviewCommandButton}"
                        Background="{DynamicResource ButtonDangerBrush}"
                        BorderBrush="{DynamicResource ButtonDangerBorderBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="13"
                                   Height="13"
                                   Fill="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="STOP" />
                    </StackPanel>
                </Button>
                <Button Command="{Binding CurrentScreen.Review.RetryCommand}"
                        Style="{StaticResource ReviewCommandButton}"
                        Background="{DynamicResource ButtonPrimaryBrush}"
                        BorderBrush="{DynamicResource ButtonPrimaryBorderBrush}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="M18,8 A6,6 0 1 0 19,14 M18,8 V4 H22"
                              Stroke="{DynamicResource TextPrimaryBrush}"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Fill="Transparent"
                              Width="16"
                              Height="16"
                              Stretch="Uniform"
                              Margin="0,0,8,0" />
                        <TextBlock Text="RETRY" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding CurrentScreen.Review.Tabs}"
                      Margin="0,2,0,4">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Name}"
                            Command="{Binding SelectCommand}"
                            CommandParameter="{Binding Name}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ReviewTabButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource MenuItemSelectedBackgroundBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ButtonPrimaryBorderBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl Grid.Row="2"
                      ItemsSource="{Binding CurrentScreen.Metrics}"
                      Margin="0,0,0,12">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource PanelBorder}"
                            Padding="16,10"
                            Margin="0,0,10,0"
                            BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding Name}"
                                       Style="{StaticResource ReviewLabelText}" />
                            <TextBlock Grid.Row="1"
                                       Text="{Binding Value}"
                                       Foreground="{Binding ValueBrush}"
                                       FontSize="23"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Bottom" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="3"
              Visibility="{Binding CurrentScreen.Review.IsRunTab, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="480" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource PanelBorder}"
                    Margin="0,0,12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Review Mode"
                               Style="{StaticResource ReviewPanelTitle}" />

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding CurrentScreen.Review.Modes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding SelectCommand}"
                                            CommandParameter="{Binding Name}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ReviewModeButton}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource MenuItemSelectedBackgroundBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ButtonPrimaryBorderBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Row="1"
                                                       Text="{Binding Detail}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="10"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <Border Grid.Row="2"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource PanelBackgroundBrush}"
                            Padding="12"
                            Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Target / Scope"
                                       Style="{StaticResource ReviewPanelTitle}"
                                       Margin="0,0,0,8" />
                            <ItemsControl Grid.Row="1"
                                          ItemsSource="{Binding CurrentScreen.Review.TargetItems}"
                                          ItemTemplate="{StaticResource DisplayItemRowTemplate}" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource PanelBorder}"
                    Margin="0,0,12,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="252" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <TextBlock Text="Review Point Plan"
                                   Style="{StaticResource ReviewPanelTitle}" />
                        <TextBlock Text="{Binding CurrentScreen.Review.PlanSummary}"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource AccentTextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                    </Grid>

                    <Border Grid.Row="1"
                            Background="{DynamicResource GridBackgroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="12"
                            Margin="0,0,0,12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding CurrentScreen.Review.PlanRows}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="8" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{Binding StateBrush}"
                                                BorderThickness="1"
                                                Background="{DynamicResource PanelBackgroundBrush}"
                                                Margin="3"
                                                MinHeight="48"
                                                Padding="4">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Opacity" Value="1" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding State}" Value="Current">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="CurrentPointBlink">
                                                                    <Storyboard RepeatBehavior="Forever"
                                                                                AutoReverse="True">
                                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                         From="1"
                                                                                         To="0.38"
                                                                                         Duration="0:0:0.45" />
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="CurrentPointBlink" />
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="{Binding No}"
                                                           Foreground="{DynamicResource TextMutedBrush}"
                                                           FontSize="9"
                                                           HorizontalAlignment="Right" />
                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Point}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Row="2"
                                                           Text="{Binding State}"
                                                           Foreground="{Binding StateBrush}"
                                                           FontSize="9"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding CurrentScreen.Review.PlanRows}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              RowHeight="38"
                              ColumnHeaderHeight="40"
                              FontSize="12"
                              EnableRowVirtualization="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                              ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="No." Binding="{Binding No}" Width="48" />
                            <DataGridTextColumn Header="Head" Binding="{Binding Head}" Width="70" />
                            <DataGridTextColumn Header="Cell" Binding="{Binding Cell}" Width="96" />
                            <DataGridTextColumn Header="Point" Binding="{Binding Point}" Width="92" />
                            <DataGridTextColumn Header="Design X" Binding="{Binding DesignX}" Width="106" />
                            <DataGridTextColumn Header="Design Y" Binding="{Binding DesignY}" Width="106" />
                            <DataGridTextColumn Header="Review X" Binding="{Binding ReviewX}" Width="106" />
                            <DataGridTextColumn Header="Review Y" Binding="{Binding ReviewY}" Width="106" />
                            <DataGridTemplateColumn Header="State" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding StateBrush}"
                                                Width="76"
                                                Height="24"
                                                CornerRadius="4"
                                                HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding State}"
                                                       Style="{StaticResource ReviewStateText}"
                                                       VerticalAlignment="Center" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Grid Grid.Column="2"
                  Margin="0,0,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="190" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <TextBlock Text="Review Camera"
                                       Style="{StaticResource ReviewPanelTitle}" />
                            <TextBlock Text="SINGLE CAMERA"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Grid>
                        <Border Grid.Row="1"
                                Background="{DynamicResource GridBackgroundBrush}"
                                BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}"
                                BorderThickness="1" />
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource PanelBorder}"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Current Measurement"
                                   Style="{StaticResource ReviewPanelTitle}" />
                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding CurrentScreen.Review.SelectedPointItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            MinHeight="25"
                                            Margin="0,0,0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="118" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Value}"
                                                       Foreground="{Binding ValueBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="4"
              Visibility="{Binding CurrentScreen.Review.IsRunTab, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="420" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource PanelBorder}"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Review Result"
                               Style="{StaticResource ReviewPanelTitle}" />
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding CurrentScreen.Review.ResultRows}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              RowHeight="36"
                              ColumnHeaderHeight="38"
                              FontSize="12"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="122" />
                            <DataGridTextColumn Header="Head" Binding="{Binding Head}" Width="72" />
                            <DataGridTextColumn Header="Cell" Binding="{Binding Cell}" Width="100" />
                            <DataGridTextColumn Header="Point" Binding="{Binding Point}" Width="100" />
                            <DataGridTextColumn Header="Error X" Binding="{Binding ErrorX}" Width="106" />
                            <DataGridTextColumn Header="Error Y" Binding="{Binding ErrorY}" Width="106" />
                            <DataGridTemplateColumn Header="Judge" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Judge}"
                                                   Foreground="{Binding JudgeBrush}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Review History"
                               Style="{StaticResource ReviewPanelTitle}" />
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding CurrentScreen.Review.HistoryRows}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              RowHeight="36"
                              ColumnHeaderHeight="38"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="90" />
                            <DataGridTextColumn Header="Mode" Binding="{Binding Mode}" Width="*" />
                            <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="64" />
                            <DataGridTextColumn Header="NG" Binding="{Binding Ng}" Width="54" />
                            <DataGridTemplateColumn Header="Result" Width="76">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Result}"
                                                   Foreground="{Binding ResultBrush}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3"
              Grid.RowSpan="2"
              Visibility="{Binding CurrentScreen.Review.IsSampleSelectTab, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource PanelBorder}"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="172" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Review Set"
                               Style="{StaticResource ReviewPanelTitle}" />

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding CurrentScreen.Review.ReviewSets}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              RowHeight="34"
                              ColumnHeaderHeight="36"
                              FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="72" />
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Count" Binding="{Binding Count}" Width="58" />
                            <DataGridTemplateColumn Header="State" Width="72">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding State}"
                                                   Foreground="{Binding StateBrush}"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <Border Grid.Row="2"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource PanelBackgroundBrush}"
                            Padding="12"
                            Margin="0,12,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="Selection Summary"
                                       Style="{StaticResource ReviewPanelTitle}"
                                       Margin="0,0,0,8" />
                            <ItemsControl Grid.Row="1"
                                          ItemsSource="{Binding CurrentScreen.Review.SelectionSummaryItems}"
                                          ItemTemplate="{StaticResource DisplayItemRowTemplate}" />
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Style="{StaticResource PanelBorder}"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="300" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <TextBlock Text="Sample Selection Map"
                                   Style="{StaticResource ReviewPanelTitle}" />
                        <TextBlock Text="{Binding CurrentScreen.Review.PlanSummary}"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource AccentTextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                    </Grid>

                    <Border Grid.Row="1"
                            Background="{DynamicResource GridBackgroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding CurrentScreen.Review.PointSelectRows}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="{Binding DataContext.CurrentScreen.Review.SampleMapColumnCount, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding ToggleCommand}"
                                                CommandParameter="{Binding HoleKey}"
                                                Margin="2"
                                                Padding="0"
                                                Background="{Binding BackgroundBrush}"
                                                BorderBrush="{Binding BorderBrush}"
                                                BorderThickness="1"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                Cursor="Hand">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                            CornerRadius="3">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Grid Height="26">
                                                <TextBlock Text="{Binding Point}"
                                                           Foreground="{Binding UseBrush}"
                                                           FontSize="10"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding CurrentScreen.Review.PointSelectRows}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              RowHeight="34"
                              ColumnHeaderHeight="38"
                              FontSize="12"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Use" Width="64">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding ToggleCommand}"
                                                CommandParameter="{Binding HoleKey}"
                                                Width="48"
                                                Height="22"
                                                Background="{Binding UseBrush}"
                                                BorderBrush="{Binding BorderBrush}"
                                                BorderThickness="1"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                FontSize="10"
                                                FontWeight="SemiBold"
                                                Content="{Binding UseText}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="No." Binding="{Binding No}" Width="52" />
                            <DataGridTextColumn Header="Head" Binding="{Binding Head}" Width="64" />
                            <DataGridTextColumn Header="Cell" Binding="{Binding Cell}" Width="88" />
                            <DataGridTextColumn Header="Point" Binding="{Binding Point}" Width="80" />
                            <DataGridTextColumn Header="Cell No" Binding="{Binding Row}" Width="74" />
                            <DataGridTextColumn Header="Hole No" Binding="{Binding Column}" Width="74" />
                            <DataGridTextColumn Header="Design X" Binding="{Binding DesignX}" Width="96" />
                            <DataGridTextColumn Header="Design Y" Binding="{Binding DesignY}" Width="96" />
                            <DataGridTextColumn Header="Review X" Binding="{Binding ReviewX}" Width="96" />
                            <DataGridTextColumn Header="Review Y" Binding="{Binding ReviewY}" Width="96" />
                            <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*" MinWidth="90" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="214" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Sampling Rule"
                               Style="{StaticResource ReviewPanelTitle}" />

                    <Grid Grid.Row="1"
                          Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="84" />
                            <ColumnDefinition Width="96" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="3"
                                   Text="Rule File"
                                   Style="{StaticResource ReviewLabelText}"
                                   Margin="0,0,0,6" />
                        <ComboBox Grid.Row="1"
                                  ItemsSource="{Binding CurrentScreen.Review.RuleFiles}"
                                  SelectedItem="{Binding CurrentScreen.Review.SelectedRuleFile, Mode=TwoWay}"
                                  Style="{StaticResource ReviewComboBox}"
                                  Margin="0,0,8,0" />
                        <Button Grid.Row="1"
                                Grid.Column="1"
                                Content="LOAD"
                                Command="{Binding CurrentScreen.Review.LoadRuleCommand}"
                                Style="{StaticResource ReviewCommandButton}"
                                Height="36"
                                MinWidth="76"
                                Margin="0,0,8,0"
                                Padding="10,0"
                                FontSize="12"
                                Background="{DynamicResource ButtonSecondaryBrush}"
                                BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}" />
                        <Button Grid.Row="1"
                                Grid.Column="2"
                                Content="SAVE RULE"
                                Command="{Binding CurrentScreen.Review.SaveRuleCommand}"
                                Style="{StaticResource ReviewCommandButton}"
                                Height="36"
                                MinWidth="88"
                                Margin="0"
                                Padding="10,0"
                                FontSize="12"
                                Background="{DynamicResource ButtonPrimaryBrush}"
                                BorderBrush="{DynamicResource ButtonPrimaryBorderBrush}" />
                    </Grid>

                    <UniformGrid Grid.Row="2"
                                 Columns="2"
                                 Rows="4">
                        <Button Content="ALL"
                                Command="{Binding CurrentScreen.Review.QuickSelectCommand}"
                                CommandParameter="ALL"
                                Style="{StaticResource ReviewCommandButton}"
                                Background="{DynamicResource ButtonPrimaryBrush}"
                                BorderBrush="{DynamicResource ButtonPrimaryBorderBrush}" />
                        <Button Content="CLEAR"
                                Command="{Binding CurrentScreen.Review.QuickSelectCommand}"
                                CommandParameter="CLEAR"
                                Style="{StaticResource ReviewCommandButton}"
                                Background="{DynamicResource ButtonSecondaryBrush}"
                                BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}" />
                        <Button Content="EDGE"
                                Command="{Binding CurrentScreen.Review.QuickSelectCommand}"
                                CommandParameter="EDGE"
                                Style="{StaticResource ReviewCommandButton}"
                                Background="{DynamicResource ButtonSecondaryBrush}"
                                BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}" />
                        <Button Content="CENTER"
                                Command="{Binding CurrentScreen.Review.QuickSelectCommand}"
                                CommandParameter="CENTER"
                                Style="{StaticResource ReviewCommandButton}"
                                Background="{DynamicResource ButtonSecondaryBrush}"
                                BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}" />
                        <Button Content="HEAD POINT"
                                Command="{Binding CurrentScreen.Review.QuickSelectCommand}"
                                CommandParameter="HEAD"
                                Style="{StaticResource ReviewCommandButton}"
                                Background="{DynamicResource ButtonSecondaryBrush}"
                                BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}" />
                        <Button Content="CELL POINT"
                                Command="{Binding CurrentScreen.Review.QuickSelectCommand}"
                                CommandParameter="CELL"
                                Style="{StaticResource ReviewCommandButton}"
                                Background="{DynamicResource ButtonSecondaryBrush}"
                                BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}" />
                        <Button Content="0-LINE"
                                Command="{Binding CurrentScreen.Review.QuickSelectCommand}"
                                CommandParameter="ZERO"
                                Style="{StaticResource ReviewCommandButton}"
                                Background="{DynamicResource ButtonWarningBrush}"
                                BorderBrush="{DynamicResource ButtonWarningBorderBrush}" />
                    </UniformGrid>

                    <TextBlock Grid.Row="3"
                               Text="Rule Preview"
                               Style="{StaticResource ReviewPanelTitle}"
                               Margin="0,12,0,8" />

                    <Border Grid.Row="4"
                            Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="12">
                        <StackPanel>
                            <TextBlock Text="SAMPLE SELECT creates the Review Plan used by RUN."
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Selected points are measured by Stage PC / Vision PC sequence."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,10,0,0" />
                            <TextBlock Text="Correction menu will consume Review Result after measurement."
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       Margin="0,6,0,0" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3"
              Grid.RowSpan="2"
              Visibility="{Binding CurrentScreen.Review.IsOneHoleTab, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="430" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource PanelBorder}"
                    Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="182" />
                    </Grid.RowDefinitions>

                    <Grid>
                        <TextBlock Text="{Binding CurrentScreen.Review.OneHoleMapTitle}"
                                   Style="{StaticResource ReviewPanelTitle}" />
                        <Button Command="{Binding CurrentScreen.Review.BackToOneHoleCellMapCommand}"
                                Visibility="{Binding CurrentScreen.Review.IsOneHoleHoleMap, Converter={StaticResource BooleanToVisibilityConverter}}"
                                Width="88"
                                Height="30"
                                HorizontalAlignment="Right"
                                Margin="0,0,116,0"
                                Background="{DynamicResource ButtonSecondaryBrush}"
                                BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}"
                                BorderThickness="1"
                                Foreground="{DynamicResource TextPrimaryBrush}"
                                FontSize="12"
                                FontWeight="SemiBold"
                                Cursor="Hand"
                                Content="BACK" />
                        <TextBlock Text="{Binding CurrentScreen.Review.PlanSummary}"
                                   HorizontalAlignment="Right"
                                   Foreground="{DynamicResource AccentTextBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold" />
                    </Grid>

                    <Border Grid.Row="1"
                            Background="{DynamicResource GridBackgroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="10"
                            Margin="0,0,0,12">
                        <Grid>
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          Visibility="{Binding CurrentScreen.Review.IsOneHoleCellMap, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl ItemsSource="{Binding CurrentScreen.Review.CellSelectRows}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="{Binding DataContext.CurrentScreen.Review.OneHoleCellMapColumnCount, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding SelectCommand}"
                                                    CommandParameter="{Binding CellNo}"
                                                    MinHeight="86"
                                                    Margin="4"
                                                    Padding="12"
                                                    Background="{Binding BackgroundBrush}"
                                                    BorderBrush="{Binding BorderBrush}"
                                                    BorderThickness="1"
                                                    Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="5">
                                                            <ContentPresenter HorizontalAlignment="Stretch"
                                                                              VerticalAlignment="Stretch" />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Cell}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" />
                                                    <TextBlock Text="{Binding HoleCount, StringFormat={}{0} holes}"
                                                               Foreground="{DynamicResource AccentTextBrush}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,8,0,0" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto"
                                          Visibility="{Binding CurrentScreen.Review.IsOneHoleHoleMap, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl ItemsSource="{Binding CurrentScreen.Review.OneHoleRows}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="{Binding DataContext.CurrentScreen.Review.OneHoleHoleMapColumnCount, RelativeSource={RelativeSource AncestorType=ItemsControl}}" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding ToggleCommand}"
                                                    CommandParameter="{Binding HoleKey}"
                                                    Width="58"
                                                    Height="58"
                                                    Margin="3"
                                                    Padding="4"
                                                    Background="Transparent"
                                                    BorderBrush="{Binding BorderBrush}"
                                                    BorderThickness="0"
                                                    Cursor="Hand">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Grid Background="{TemplateBinding Background}">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center" />
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Button.Template>
                                                <StackPanel HorizontalAlignment="Center">
                                                    <Grid Width="30"
                                                          Height="30">
                                                        <Ellipse Fill="{Binding BackgroundBrush}"
                                                                 Stroke="{Binding BorderBrush}"
                                                                 StrokeThickness="2" />
                                                    </Grid>
                                                    <TextBlock Text="{Binding Column, StringFormat=HOLE {0}}"
                                                               Foreground="{DynamicResource TextMutedBrush}"
                                                               FontSize="9"
                                                               FontWeight="SemiBold"
                                                               HorizontalAlignment="Center"
                                                               Margin="0,4,0,0" />
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            Background="{DynamicResource PanelBackgroundBrush}"
                            Padding="10">
                        <Grid>
                            <TextBlock Text="{Binding CurrentScreen.Review.OneHoleMapGuide}"
                                       Visibility="{Binding CurrentScreen.Review.IsOneHoleCellMap, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center" />
                            <DataGrid ItemsSource="{Binding CurrentScreen.Review.OneHoleRows}"
                                      Visibility="{Binding CurrentScreen.Review.IsOneHoleHoleMap, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      IsReadOnly="True"
                                      Style="{StaticResource PlainDataGrid}"
                                      RowHeight="32"
                                      ColumnHeaderHeight="34"
                                      FontSize="12"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Hole" Binding="{Binding Point}" Width="82" />
                                    <DataGridTextColumn Header="Head" Binding="{Binding Head}" Width="62" />
                                    <DataGridTextColumn Header="Design X" Binding="{Binding DesignX}" Width="94" />
                                    <DataGridTextColumn Header="Design Y" Binding="{Binding DesignY}" Width="94" />
                                    <DataGridTextColumn Header="Review X" Binding="{Binding ReviewX}" Width="94" />
                                    <DataGridTextColumn Header="Review Y" Binding="{Binding ReviewY}" Width="94" />
                                    <DataGridTextColumn Header="State" Binding="{Binding Reason}" Width="*" MinWidth="90" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="220" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Style="{StaticResource PanelBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <TextBlock Text="Review Camera"
                                       Style="{StaticResource ReviewPanelTitle}" />
                            <TextBlock Text="SINGLE CAMERA"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                        </Grid>
                        <Border Grid.Row="1"
                                Background="{DynamicResource GridBackgroundBrush}"
                                BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}"
                                BorderThickness="1" />
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Style="{StaticResource PanelBorder}"
                        Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="Current Measurement"
                                   Style="{StaticResource ReviewPanelTitle}" />
                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding CurrentScreen.Review.SelectedPointItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="0,0,0,1"
                                            MinHeight="28"
                                            Margin="0,0,0,3">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="128" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{DynamicResource TextMutedBrush}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Value}"
                                                       Foreground="{Binding ValueBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

