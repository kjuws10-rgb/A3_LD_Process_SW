<UserControl x:Class="Drilling.UI.Views.CRecipeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="RecipeSmallText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="RecipeValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="RecipeActionButton" TargetType="Button">
            <Setter Property="Height" Value="58" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecipeTabButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="{DynamicResource ButtonSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.42" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RecipeMainTabButton" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="MinWidth" Value="148" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="22,0" />
            <Setter Property="Background" Value="{DynamicResource ButtonSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1,1,1,3" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5,5,0,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecipeListButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Visibility="{Binding CurrentScreen.IsRecipeLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="RECIPE / MANAGE"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="31"
                       FontWeight="SemiBold" />
            <TextBlock Text="Recipe item edit, create, modify, save, delete"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="16" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="232" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.RowSpan="2" Grid.Column="0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="352" />
                        <RowDefinition Height="102" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Recipe List"
                               Style="{StaticResource PanelTitle}"
                               FontSize="20" />

                    <Grid Grid.Row="1" Margin="0,6,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="42" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Background="{DynamicResource GridHeaderBackgroundBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="78" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}" BorderThickness="1,1,1,1">
                                <TextBlock Text="No."
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource RecipeSmallText}"
                                           FontWeight="SemiBold" />
                            </Border>
                            <Border Grid.Column="1" BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}" BorderThickness="0,1,1,1">
                                <TextBlock Text="Recipe File"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource RecipeSmallText}"
                                           FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding CurrentScreen.Recipe.RecipeFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource RecipeListButton}"
                                            Command="{Binding DataContext.CurrentScreen.Recipe.SelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding FileName}">
                                        <Grid Height="48">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource MenuItemSelectedBackgroundBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="78" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="34" />
                                            </Grid.ColumnDefinitions>
                                            <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1,0,1,1">
                                                <TextBlock Text="{Binding No}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource RecipeValueText}" />
                                            </Border>
                                            <Border Grid.Column="1"
                                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                                    BorderThickness="0,0,1,1">
                                                <TextBlock Text="{Binding FileName}"
                                                           Margin="18,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource RecipeValueText}" />
                                            </Border>
                                            <Border Grid.Column="2"
                                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                                    BorderThickness="0,0,1,1">
                                                <Path Data="M4,4 L12,12 L4,20"
                                                      Stroke="{DynamicResource TextPrimaryBrush}"
                                                      StrokeThickness="2.4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <Border Grid.Row="2"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="0,1,0,1"
                            Padding="0,14">
                        <StackPanel>
                            <TextBlock Text="Selected Recipe"
                                       Style="{StaticResource RecipeSmallText}" />
                            <TextBlock Text="{Binding CurrentScreen.Recipe.SelectedRecipeFile}"
                                       Margin="0,10,0,0"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       FontSize="27"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="3" Margin="0,14,0,0">
                        <Button Style="{StaticResource RecipeActionButton}"
                                Background="{DynamicResource ButtonPrimaryBrush}"
                                BorderBrush="{DynamicResource ButtonPrimaryBorderBrush}"
                                Margin="0,0,0,12"
                                Command="{Binding CurrentScreen.Recipe.CreateCommand}">
                            <Grid Width="178">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                                    <Path Data="M12,3 V21 M3,12 H21"
                                          Stroke="{DynamicResource TextPrimaryBrush}"
                                          StrokeThickness="2.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Fill="Transparent" />
                                </Viewbox>
                                <TextBlock Grid.Column="1"
                                           Text="CREATE"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource RecipeActionButton}"
                                Background="{DynamicResource ButtonWarningBrush}"
                                BorderBrush="{DynamicResource ButtonWarningBorderBrush}"
                                Margin="0,0,0,12"
                                Command="{Binding CurrentScreen.Recipe.ModifyCommand}">
                            <Grid Width="178">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                                    <Path Data="M5,18 L7,13 L16,4 L20,8 L11,17 Z M14,6 L18,10"
                                          Stroke="{DynamicResource TextPrimaryBrush}"
                                          StrokeThickness="2.2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent" />
                                </Viewbox>
                                <TextBlock Grid.Column="1"
                                           Text="MODIFY"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource RecipeActionButton}"
                                Background="{DynamicResource ButtonSuccessBrush}"
                                BorderBrush="{DynamicResource StatusReadyBrush}"
                                Margin="0,0,0,12"
                                Command="{Binding CurrentScreen.Recipe.SaveCommand}">
                            <Grid Width="178">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                                    <Path Data="M5,4 H17 L20,7 V20 H4 V4 Z M8,4 V10 H16 V4 M8,17 H16"
                                          Stroke="{DynamicResource TextPrimaryBrush}"
                                          StrokeThickness="2.2"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent" />
                                </Viewbox>
                                <TextBlock Grid.Column="1"
                                           Text="SAVE"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource RecipeActionButton}"
                                Background="{DynamicResource ButtonDangerBrush}"
                                BorderBrush="{DynamicResource ButtonDangerBorderBrush}"
                                Command="{Binding CurrentScreen.Recipe.DeleteCommand}">
                            <Grid Width="178">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                                    <Path Data="M6,7 H18 M9,7 V5 H15 V7 M8,9 V20 H16 V9 M11,11 V18 M13,11 V18"
                                          Stroke="{DynamicResource TextPrimaryBrush}"
                                          StrokeThickness="2.2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent" />
                                </Viewbox>
                                <TextBlock Grid.Column="1"
                                           Text="DELETE"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Margin="12,0,0,0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition>
                            <RowDefinition.Style>
                                <Style TargetType="RowDefinition">
                                    <Setter Property="Height" Value="Auto" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentScreen.Recipe.IsCellCategory}" Value="True">
                                            <Setter Property="Height" Value="*" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </RowDefinition.Style>
                        </RowDefinition>
                        <RowDefinition>
                            <RowDefinition.Style>
                                <Style TargetType="RowDefinition">
                                    <Setter Property="Height" Value="*" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentScreen.Recipe.IsCellCategory}" Value="True">
                                            <Setter Property="Height" Value="160" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </RowDefinition.Style>
                        </RowDefinition>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Recipe Managed Items"
                               Style="{StaticResource PanelTitle}"
                               FontSize="20" />

                    <Border Grid.Row="1"
                            Margin="0,12,0,10"
                            Padding="8,8,8,0"
                            Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <ItemsControl ItemsSource="{Binding CurrentScreen.Recipe.ItemTabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Category}"
                                            Command="{Binding DataContext.CurrentScreen.Recipe.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Category}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource RecipeMainTabButton}">
                                                <Setter Property="Background" Value="{DynamicResource ButtonSecondaryBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource MenuItemSelectedBackgroundBrush}" />
                                                        <Setter Property="BorderBrush" Value="{DynamicResource ButtonPrimaryBorderBrush}" />
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding CurrentScreen.Recipe.GroupTabs}"
                                  Margin="0,0,0,12">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentScreen.Recipe.IsCellCategory}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Group}"
                                        Command="{Binding DataContext.CurrentScreen.Recipe.SelectGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Group}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource RecipeTabButton}">
                                            <Setter Property="Height" Value="34" />
                                            <Setter Property="MinWidth" Value="86" />
                                            <Setter Property="Margin" Value="0,0,7,7" />
                                            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource MenuItemSelectedBackgroundBrush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource MenuItemSelectedBorderBrush}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Grid.Row="3"
                          Grid.RowSpan="2"
                          Margin="0,0,0,4"
                        Visibility="{Binding CurrentScreen.Recipe.IsCellCategory, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="38*" />
                            <RowDefinition Height="7" />
                            <RowDefinition Height="62*" MinHeight="220" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="53*" />
                            <ColumnDefinition Width="47*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="0"
                                Grid.Column="0"
                                Height="76"
                                Margin="0,0,12,9"
                                Padding="10,6"
                                Background="{DynamicResource GridBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="94" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="GLASS"
                                           Grid.RowSpan="2"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" />
                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                        <TextBlock Text="SIZE X" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" />
                                        <TextBox Text="{Binding CurrentScreen.Recipe.GlassSizeXItem.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="62" Height="25" Padding="5,2" VerticalContentAlignment="Center" />
                                        <TextBlock Text="mm" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" FontSize="9" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                        <TextBlock Text="SIZE Y" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" />
                                        <TextBox Text="{Binding CurrentScreen.Recipe.GlassSizeYItem.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="62" Height="25" Padding="5,2" VerticalContentAlignment="Center" />
                                        <TextBlock Text="mm" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" FontSize="9" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                                        <TextBlock Text="CELL COUNT" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" />
                                        <TextBox Text="{Binding CurrentScreen.Recipe.CellCountItem.Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Width="50" Height="25" Padding="5,2" VerticalContentAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                                        <TextBlock Text="AK MARGIN X" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" />
                                        <TextBox Text="{Binding CurrentScreen.Recipe.AkMarginXItem.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="52" Height="25" Padding="5,2" VerticalContentAlignment="Center" />
                                        <TextBlock Text="mm" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" FontSize="9" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                                        <TextBlock Text="AK MARGIN Y" Margin="0,0,4,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10" />
                                        <TextBox Text="{Binding CurrentScreen.Recipe.AkMarginYItem.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="52" Height="25" Padding="5,2" VerticalContentAlignment="Center" />
                                        <TextBlock Text="mm" Margin="4,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" FontSize="9" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <DockPanel Grid.Row="1" Grid.Column="0" Margin="0,0,12,7">
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                                <Button Content="SELECT ALL"
                                        Command="{Binding CurrentScreen.Recipe.SelectAllCellsCommand}"
                                        Style="{StaticResource RecipeTabButton}"
                                        MinWidth="92" Height="30" Margin="6,0,0,0" />
                                <Button Content="CLEAR"
                                        Command="{Binding CurrentScreen.Recipe.ClearCellSelectionCommand}"
                                        Style="{StaticResource RecipeTabButton}"
                                        MinWidth="70" Height="30" Margin="6,0,0,0" />
                                <Button Content="APPLY HOLE PATTERN"
                                        Command="{Binding CurrentScreen.Recipe.ApplyPointPatternCommand}"
                                        Style="{StaticResource RecipeTabButton}"
                                        MinWidth="148" Height="30" Margin="6,0,0,0"
                                        FontSize="11" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="CELL"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           FontWeight="SemiBold" />
                                <Border Height="24"
                                        Margin="10,0,0,0"
                                        Padding="8,0"
                                        VerticalAlignment="Center"
                                        Background="{DynamicResource MenuItemSelectedBackgroundBrush}"
                                        BorderBrush="{DynamicResource ButtonPrimaryBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="2">
                                    <TextBlock Text="{Binding CurrentScreen.Recipe.CurrentCellIndicatorText}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold" />
                                </Border>
                            </StackPanel>
                        </DockPanel>
                        <Grid Grid.Row="2"
                              Grid.RowSpan="3"
                              Grid.Column="0"
                              Margin="0,0,12,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <DataGrid Grid.Row="0"
                                      ItemsSource="{Binding CurrentScreen.Recipe.CellOverviewRows}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HeadersVisibility="All"
                                      EnableRowVirtualization="True"
                                      FontSize="12"
                                      RowHeight="31"
                                      ColumnHeaderHeight="32"
                                      Style="{StaticResource PlainDataGrid}">
                            <DataGrid.Resources>
                                <Style x:Key="CellOverviewValueText" TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="Padding" Value="5,0" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                </Style>
                                <Style x:Key="CellOverviewValueEditor" TargetType="TextBox">
                                    <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                    <Setter Property="BorderBrush" Value="{DynamicResource ButtonPrimaryBorderBrush}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                    <Setter Property="Padding" Value="5,2" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                    <Setter Property="VerticalContentAlignment" Value="Center" />
                                </Style>
                            </DataGrid.Resources>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Setter Property="BorderBrush" Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="2,0,0,0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource MenuItemSelectedBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource ButtonPrimaryBorderBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="✓" Width="38">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Cell" Width="62">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding CellNo}"
                                                    Command="{Binding DataContext.CurrentScreen.Recipe.SelectCellCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding CellNo}"
                                                    Style="{StaticResource RecipeTabButton}"
                                                    Height="25"
                                                    Margin="3,2"
                                                    Padding="4,1" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="First X" Binding="{Binding FirstX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="82" ElementStyle="{StaticResource CellOverviewValueText}" EditingElementStyle="{StaticResource CellOverviewValueEditor}" />
                                <DataGridTextColumn Header="First Y" Binding="{Binding FirstY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="82" ElementStyle="{StaticResource CellOverviewValueText}" EditingElementStyle="{StaticResource CellOverviewValueEditor}" />
                                <DataGridTextColumn Header="Rot" Binding="{Binding Rotation, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="62" ElementStyle="{StaticResource CellOverviewValueText}" EditingElementStyle="{StaticResource CellOverviewValueEditor}" />
                                <DataGridTextColumn Header="Count X" Binding="{Binding CountX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="72" ElementStyle="{StaticResource CellOverviewValueText}" EditingElementStyle="{StaticResource CellOverviewValueEditor}" />
                                <DataGridTextColumn Header="Count Y" Binding="{Binding CountY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="72" ElementStyle="{StaticResource CellOverviewValueText}" EditingElementStyle="{StaticResource CellOverviewValueEditor}" />
                                <DataGridTextColumn Header="Pitch X" Binding="{Binding PitchX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="68" ElementStyle="{StaticResource CellOverviewValueText}" EditingElementStyle="{StaticResource CellOverviewValueEditor}" />
                                <DataGridTextColumn Header="Pitch Y" Binding="{Binding PitchY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="68" ElementStyle="{StaticResource CellOverviewValueText}" EditingElementStyle="{StaticResource CellOverviewValueEditor}" />
                                <DataGridTextColumn Header="Hole Size" Binding="{Binding PixelSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="82" ElementStyle="{StaticResource CellOverviewValueText}" EditingElementStyle="{StaticResource CellOverviewValueEditor}" />
                             </DataGrid.Columns>
                             </DataGrid>
                        </Grid>
                        <Border Grid.Row="0"
                                Grid.RowSpan="5"
                                Grid.Column="1"
                                Background="{DynamicResource GridBackgroundBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="1"
                                Visibility="{Binding CurrentScreen.Recipe.IsCellDetailVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="34" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0"
                                            Padding="7,0"
                                            Background="{DynamicResource GridHeaderBackgroundBrush}"
                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                            BorderThickness="0,0,0,1">
                                        <DockPanel>
                                            <Button Content="← BACK"
                                                    DockPanel.Dock="Left"
                                                    Command="{Binding CurrentScreen.Recipe.BackToCellPreviewCommand}"
                                                    Style="{StaticResource RecipeTabButton}"
                                                    Width="72"
                                                    Height="26"
                                                    Margin="0,0,10,0"
                                                    FontSize="10" />
                                            <TextBlock Text="{Binding CurrentScreen.Recipe.SelectedCellHoleTitle}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                        </DockPanel>
                                    </Border>
                                    <Grid Grid.Row="1">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="7" />
                                            <RowDefinition Height="Auto" MinHeight="82" />
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0"
                                                Background="{DynamicResource PanelBackgroundBrush}"
                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                BorderThickness="0,0,0,1">
                                            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                          VerticalScrollBarVisibility="Auto"
                                                          CanContentScroll="False">
                                                <StackPanel>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="50" Height="27"
                                                                Background="{DynamicResource GridHeaderBackgroundBrush}"
                                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                                BorderThickness="0,0,1,1">
                                                            <TextBlock Text="Row"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                                       FontSize="10"
                                                                       FontWeight="SemiBold" />
                                                        </Border>
                                                        <ItemsControl ItemsSource="{Binding CurrentScreen.Recipe.HoleMatrixColumnHeaders}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Width="88" Height="27"
                                                                            Background="{DynamicResource GridHeaderBackgroundBrush}"
                                                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                                                            BorderThickness="0,0,1,1">
                                                                        <TextBlock Text="{Binding}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                   FontSize="11"
                                                                                   FontWeight="SemiBold" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding CurrentScreen.Recipe.HoleMatrixRows}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Border Width="50" Height="57"
                                                                            Background="{DynamicResource GridBackgroundBrush}"
                                                                            BorderBrush="{DynamicResource PanelBorderBrush}"
                                                                            BorderThickness="0,0,1,1">
                                                                        <TextBlock Text="{Binding RowNo}"
                                                                                   HorizontalAlignment="Center"
                                                                                   VerticalAlignment="Center"
                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                   FontSize="12"
                                                                                   FontWeight="SemiBold" />
                                                                    </Border>
                                                                    <ItemsControl ItemsSource="{Binding Cells}">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <StackPanel Orientation="Horizontal" />
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Button Width="88" Height="57"
                                                                                        Margin="0"
                                                                                        Padding="3"
                                                                                        Command="{Binding DataContext.CurrentScreen.Recipe.SelectHoleCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                        CommandParameter="{Binding}">
                                                                                    <Button.Style>
                                                                                        <Style TargetType="Button">
                                                                                            <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}" />
                                                                                            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                                                                                            <Setter Property="BorderThickness" Value="0,0,1,1" />
                                                                                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                                                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                                                                            <Setter Property="Template">
                                                                                                <Setter.Value>
                                                                                                    <ControlTemplate TargetType="Button">
                                                                                                        <Border Background="{TemplateBinding Background}"
                                                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                                                Padding="{TemplateBinding Padding}"
                                                                                                                SnapsToDevicePixels="True">
                                                                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                                                                                        </Border>
                                                                                                    </ControlTemplate>
                                                                                                </Setter.Value>
                                                                                            </Setter>
                                                                                            <Style.Triggers>
                                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                                    <Setter Property="Background" Value="{DynamicResource MenuItemSelectedBackgroundBrush}" />
                                                                                                    <Setter Property="BorderBrush" Value="{DynamicResource MenuItemSelectedBorderBrush}" />
                                                                                                </Trigger>
                                                                                                <Trigger Property="IsPressed" Value="True">
                                                                                                    <Setter Property="Background" Value="{DynamicResource HeaderNavPressedBackgroundBrush}" />
                                                                                                </Trigger>
                                                                                                <DataTrigger Binding="{Binding IsInsideGlass}" Value="False">
                                                                                                    <Setter Property="BorderBrush" Value="{DynamicResource ButtonDangerBorderBrush}" />
                                                                                                </DataTrigger>
                                                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                                    <Setter Property="Background" Value="{DynamicResource ButtonWarningBrush}" />
                                                                                                    <Setter Property="BorderBrush" Value="{DynamicResource ButtonWarningBorderBrush}" />
                                                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </Button.Style>
                                                                                    <Grid>
                                                                                        <Grid.RowDefinitions>
                                                                                            <RowDefinition Height="Auto" />
                                                                                            <RowDefinition Height="*" />
                                                                                        </Grid.RowDefinitions>
                                                                                        <TextBlock Text="{Binding MatrixPointName}"
                                                                                                   HorizontalAlignment="Center"
                                                                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                                                                   FontSize="11"
                                                                                                   FontWeight="SemiBold" />
                                                                                        <TextBlock Grid.Row="1"
                                                                                                   Text="{Binding OffsetCoordinateText}"
                                                                                                   HorizontalAlignment="Center"
                                                                                                   VerticalAlignment="Center"
                                                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                                                   FontSize="9"
                                                                                                   TextWrapping="Wrap"
                                                                                                   TextAlignment="Center" />
                                                                                    </Grid>
                                                                                    <Button.ToolTip>
                                                                                        <StackPanel>
                                                                                            <TextBlock Text="{Binding MatrixPointName}" FontWeight="Bold" />
                                                                                            <TextBlock Text="{Binding OffsetCoordinateText, StringFormat=Offset: {0} mm}" />
                                                                                            <TextBlock Text="{Binding PlacementState}" />
                                                                                        </StackPanel>
                                                                                    </Button.ToolTip>
                                                                                </Button>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </ScrollViewer>
                                        </Border>
                                        <Border Grid.Row="1"
                                                Height="5"
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource ButtonSecondaryBorderBrush}" />
                                        <Border Grid.Row="2"
                                                Margin="7"
                                                Padding="10,8"
                                                Background="{DynamicResource PanelBackgroundBrush}"
                                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                                BorderThickness="1">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                                    <TextBlock Text="HOLE OFFSET"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding CurrentScreen.Recipe.SelectedHoleIndicatorText}"
                                                               Margin="10,0,0,0"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource AccentTextBrush}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold" />
                                                </StackPanel>
                                                <WrapPanel Grid.Row="1" Margin="0,7,0,0">
                                                    <Grid Width="275" Height="25" Margin="0,0,12,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="68" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="28" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="OFFSET X" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding CurrentScreen.Recipe.SelectedHole.OffsetX, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 Padding="5,2" VerticalContentAlignment="Center" />
                                                        <TextBlock Grid.Column="2" Text="mm" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" />
                                                    </Grid>
                                                    <Grid Width="275" Height="25">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="68" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="28" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="OFFSET Y" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                                                        <TextBox Grid.Column="1"
                                                                 Text="{Binding CurrentScreen.Recipe.SelectedHole.OffsetY, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 Padding="5,2" VerticalContentAlignment="Center" />
                                                        <TextBlock Grid.Column="2" Text="mm" Margin="5,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" FontSize="10" />
                                                    </Grid>
                                                </WrapPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Border>
                        <Grid Grid.Row="0"
                              Grid.RowSpan="5"
                              Grid.Column="1"
                              Visibility="{Binding CurrentScreen.Recipe.IsCellPreviewVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0"
                                    Background="{DynamicResource GridBackgroundBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    Padding="4">
                                <Grid>
                                    <Image Source="{Binding CurrentScreen.Recipe.CellPreviewImage}"
                                           Stretch="Uniform"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch" />
                                    <ItemsControl ItemsSource="{Binding CurrentScreen.Recipe.CellPreviewLabels}"
                                                  Style="{StaticResource CellPreviewLabelItemsControl}"
                                                  IsHitTestVisible="True">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Width="{Binding Width}"
                                                        Height="18"
                                                        Padding="0"
                                                        Cursor="Hand"
                                                        Command="{Binding DataContext.CurrentScreen.Recipe.SelectPreviewCellCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding CellNo}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="{DynamicResource PanelAltBackgroundBrush}" />
                                                            <Setter Property="BorderBrush" Value="{DynamicResource MenuItemSelectedBorderBrush}" />
                                                            <Setter Property="BorderThickness" Value="1" />
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="CellBadge"
                                                                                Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="2"
                                                                                SnapsToDevicePixels="True">
                                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                                              VerticalAlignment="Center" />
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="CellBadge" Property="BorderBrush" Value="{DynamicResource ButtonPrimaryBorderBrush}" />
                                                                            </Trigger>
                                                                            <Trigger Property="IsPressed" Value="True">
                                                                                <Setter TargetName="CellBadge" Property="Background" Value="{DynamicResource MenuItemSelectedBackgroundBrush}" />
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                                    <Setter Property="BorderThickness" Value="2" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <TextBlock Text="{Binding DisplayText}"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontSize="10"
                                                               FontWeight="SemiBold" />
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <DataGrid Grid.Row="4"
                              ItemsSource="{Binding CurrentScreen.Recipe.ManagedItems}"
                              IsReadOnly="False"
                              FontSize="13"
                              ColumnHeaderHeight="42"
                              RowHeight="40">
                        <DataGrid.Style>
                            <Style TargetType="DataGrid" BasedOn="{StaticResource PlainDataGrid}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentScreen.Recipe.IsCellCategory}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.Style>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="128" IsReadOnly="True" />
                            <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="280" IsReadOnly="True" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="170">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding ValueBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ButtonPrimaryBorderBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Padding" Value="6,2" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="96" IsReadOnly="True" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>

                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Margin="12,12,0,0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="330" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="2"
                               Text="Change History"
                               Style="{StaticResource PanelTitle}"
                               FontSize="20" />

                    <DataGrid Grid.Row="1"
                              Grid.Column="0"
                              ItemsSource="{Binding CurrentScreen.Recipe.ChangeHistory}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              FontSize="13"
                              ColumnHeaderHeight="42"
                              RowHeight="36"
                              Margin="0,8,12,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="86" />
                            <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="96" />
                            <DataGridTextColumn Header="Tab" Binding="{Binding Tab}" Width="96" />
                            <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="116" />
                            <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="*" />
                            <DataGridTextColumn Header="Before" Binding="{Binding Before}" Width="130" />
                            <DataGridTextColumn Header="After" Binding="{Binding After}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding AfterBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <ItemsControl Grid.Row="1"
                                  Grid.Column="1"
                                  ItemsSource="{Binding CurrentScreen.Recipe.StateRows}"
                                  Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="52">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,1,1,0">
                                        <TextBlock Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource RecipeValueText}" />
                                    </Border>
                                    <Border Grid.Column="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,1,0,0">
                                        <TextBlock Text="{Binding Value}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding ValueBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>


