<UserControl x:Class="Drilling.UI.Views.CRecipeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="RecipeSmallText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B6C2CF" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="RecipeValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F3F6FA" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="RecipeActionButton" TargetType="Button">
            <Setter Property="Height" Value="58" />
            <Setter Property="Foreground" Value="#F3F6FA" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecipeTabButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="86" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="#101923" />
            <Setter Property="BorderBrush" Value="#344251" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#DDE6EF" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecipeMainTabButton" TargetType="Button">
            <Setter Property="Height" Value="48" />
            <Setter Property="MinWidth" Value="148" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Padding" Value="22,0" />
            <Setter Property="Background" Value="#101923" />
            <Setter Property="BorderBrush" Value="#344251" />
            <Setter Property="BorderThickness" Value="1,1,1,3" />
            <Setter Property="Foreground" Value="#DDE6EF" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5,5,0,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RecipeListButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Visibility="{Binding CurrentScreen.IsRecipeLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="RECIPE / MANAGE"
                       Foreground="#F3F6FA"
                       FontSize="31"
                       FontWeight="SemiBold" />
            <TextBlock Text="Recipe item edit, create, modify, save, delete"
                       Foreground="#B6C2CF"
                       FontSize="16" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="232" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="390" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.RowSpan="2" Grid.Column="0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="352" />
                        <RowDefinition Height="102" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Recipe List"
                               Style="{StaticResource PanelTitle}"
                               FontSize="20" />

                    <Grid Grid.Row="1" Margin="0,6,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="42" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Background="#17212C">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="78" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="#344251" BorderThickness="1,1,1,1">
                                <TextBlock Text="No."
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource RecipeSmallText}"
                                           FontWeight="SemiBold" />
                            </Border>
                            <Border Grid.Column="1" BorderBrush="#344251" BorderThickness="0,1,1,1">
                                <TextBlock Text="Recipe File"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource RecipeSmallText}"
                                           FontWeight="SemiBold" />
                            </Border>
                        </Grid>

                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding CurrentScreen.Recipe.RecipeFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource RecipeListButton}"
                                            Command="{Binding DataContext.CurrentScreen.Recipe.SelectCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding FileName}">
                                        <Grid Height="48">
                                            <Grid.Style>
                                                <Style TargetType="Grid">
                                                    <Setter Property="Background" Value="#0B1119" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="#0B3B78" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Grid.Style>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="78" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="34" />
                                            </Grid.ColumnDefinitions>
                                            <Border BorderBrush="#273241" BorderThickness="1,0,1,1">
                                                <TextBlock Text="{Binding No}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource RecipeValueText}" />
                                            </Border>
                                            <Border Grid.Column="1"
                                                    BorderBrush="#273241"
                                                    BorderThickness="0,0,1,1">
                                                <TextBlock Text="{Binding FileName}"
                                                           Margin="18,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Style="{StaticResource RecipeValueText}" />
                                            </Border>
                                            <Border Grid.Column="2"
                                                    BorderBrush="#273241"
                                                    BorderThickness="0,0,1,1">
                                                <Path Data="M4,4 L12,12 L4,20"
                                                      Stroke="#F3F6FA"
                                                      StrokeThickness="2.4"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Visibility="{Binding IsSelected, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <Border Grid.Row="2"
                            BorderBrush="#273241"
                            BorderThickness="0,1,0,1"
                            Padding="0,14">
                        <StackPanel>
                            <TextBlock Text="Selected Recipe"
                                       Style="{StaticResource RecipeSmallText}" />
                            <TextBlock Text="{Binding CurrentScreen.Recipe.SelectedRecipeFile}"
                                       Margin="0,10,0,0"
                                       Foreground="#27C7F7"
                                       FontSize="27"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="3" Margin="0,14,0,0">
                        <Button Style="{StaticResource RecipeActionButton}"
                                Background="#0759C8"
                                BorderBrush="#2F81F7"
                                Margin="0,0,0,12"
                                Command="{Binding CurrentScreen.Recipe.CreateCommand}">
                            <Grid Width="178">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                                    <Path Data="M12,3 V21 M3,12 H21"
                                          Stroke="#F3F6FA"
                                          StrokeThickness="2.8"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Fill="Transparent" />
                                </Viewbox>
                                <TextBlock Grid.Column="1"
                                           Text="CREATE"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource RecipeActionButton}"
                                Background="#B27700"
                                BorderBrush="#FFC400"
                                Margin="0,0,0,12"
                                Command="{Binding CurrentScreen.Recipe.ModifyCommand}">
                            <Grid Width="178">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                                    <Path Data="M5,18 L7,13 L16,4 L20,8 L11,17 Z M14,6 L18,10"
                                          Stroke="#F3F6FA"
                                          StrokeThickness="2.2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent" />
                                </Viewbox>
                                <TextBlock Grid.Column="1"
                                           Text="MODIFY"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource RecipeActionButton}"
                                Background="#0A8F4A"
                                BorderBrush="#12D466"
                                Margin="0,0,0,12"
                                Command="{Binding CurrentScreen.Recipe.SaveCommand}">
                            <Grid Width="178">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                                    <Path Data="M5,4 H17 L20,7 V20 H4 V4 Z M8,4 V10 H16 V4 M8,17 H16"
                                          Stroke="#F3F6FA"
                                          StrokeThickness="2.2"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent" />
                                </Viewbox>
                                <TextBlock Grid.Column="1"
                                           Text="SAVE"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap" />
                            </Grid>
                        </Button>
                        <Button Style="{StaticResource RecipeActionButton}"
                                Background="#C8143B"
                                BorderBrush="#FF2F6D"
                                Command="{Binding CurrentScreen.Recipe.DeleteCommand}">
                            <Grid Width="178">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="24" Height="24" HorizontalAlignment="Center">
                                    <Path Data="M6,7 H18 M9,7 V5 H15 V7 M8,9 V20 H16 V9 M11,11 V18 M13,11 V18"
                                          Stroke="#F3F6FA"
                                          StrokeThickness="2.2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="Transparent" />
                                </Viewbox>
                                <TextBlock Grid.Column="1"
                                           Text="DELETE"
                                           Margin="18,0,0,0"
                                           VerticalAlignment="Center"
                                           TextWrapping="NoWrap" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="0" Grid.Column="1" Margin="12,0,0,0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Recipe Managed Items"
                               Style="{StaticResource PanelTitle}"
                               FontSize="20" />

                    <Border Grid.Row="1"
                            Margin="0,12,0,10"
                            Padding="8,8,8,0"
                            Background="#0B1119"
                            BorderBrush="#273241"
                            BorderThickness="0,0,0,1">
                        <ItemsControl ItemsSource="{Binding CurrentScreen.Recipe.ItemTabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding Category}"
                                            Command="{Binding DataContext.CurrentScreen.Recipe.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Category}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource RecipeMainTabButton}">
                                                <Setter Property="Background" Value="#101923" />
                                                <Setter Property="BorderBrush" Value="#344251" />
                                                <Setter Property="Foreground" Value="#B6C2CF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#0B3B78" />
                                                        <Setter Property="BorderBrush" Value="#2F81F7" />
                                                        <Setter Property="Foreground" Value="#F3F6FA" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <ItemsControl Grid.Row="2"
                                  ItemsSource="{Binding CurrentScreen.Recipe.GroupTabs}"
                                  Margin="0,0,0,12">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Group}"
                                        Command="{Binding DataContext.CurrentScreen.Recipe.SelectGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding Group}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource RecipeTabButton}">
                                            <Setter Property="Height" Value="34" />
                                            <Setter Property="MinWidth" Value="86" />
                                            <Setter Property="Margin" Value="0,0,7,7" />
                                            <Setter Property="Background" Value="#0B1119" />
                                            <Setter Property="BorderBrush" Value="#344251" />
                                            <Setter Property="Foreground" Value="#B6C2CF" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="#082B38" />
                                                    <Setter Property="BorderBrush" Value="#00D8FF" />
                                                    <Setter Property="Foreground" Value="#27C7F7" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <DataGrid Grid.Row="3"
                              ItemsSource="{Binding CurrentScreen.Recipe.ManagedItems}"
                              IsReadOnly="False"
                              Style="{StaticResource PlainDataGrid}"
                              FontSize="13"
                              ColumnHeaderHeight="42"
                              RowHeight="40">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="128" IsReadOnly="True" />
                            <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="280" IsReadOnly="True" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="170">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding ValueBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                                <DataGridTextColumn.EditingElementStyle>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Background" Value="#07111B" />
                                        <Setter Property="Foreground" Value="#F3F6FA" />
                                        <Setter Property="BorderBrush" Value="#2F81F7" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Padding" Value="6,2" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.EditingElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="96" IsReadOnly="True" />
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" IsReadOnly="True" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <Border Grid.Row="1" Grid.Column="1" Margin="12,12,0,0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="330" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.ColumnSpan="2"
                               Text="Change History"
                               Style="{StaticResource PanelTitle}"
                               FontSize="20" />

                    <DataGrid Grid.Row="1"
                              Grid.Column="0"
                              ItemsSource="{Binding CurrentScreen.Recipe.ChangeHistory}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              FontSize="13"
                              ColumnHeaderHeight="42"
                              RowHeight="36"
                              Margin="0,8,12,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="86" />
                            <DataGridTextColumn Header="Action" Binding="{Binding Action}" Width="96" />
                            <DataGridTextColumn Header="Tab" Binding="{Binding Tab}" Width="96" />
                            <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="116" />
                            <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="*" />
                            <DataGridTextColumn Header="Before" Binding="{Binding Before}" Width="130" />
                            <DataGridTextColumn Header="After" Binding="{Binding After}" Width="130">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{Binding AfterBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <ItemsControl Grid.Row="1"
                                  Grid.Column="1"
                                  ItemsSource="{Binding CurrentScreen.Recipe.StateRows}"
                                  Margin="0,8,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="52">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="145" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border BorderBrush="#273241" BorderThickness="0,1,1,0">
                                        <TextBlock Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource RecipeValueText}" />
                                    </Border>
                                    <Border Grid.Column="1" BorderBrush="#273241" BorderThickness="0,1,0,0">
                                        <TextBlock Text="{Binding Value}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Foreground="{Binding ValueBrush}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
