<UserControl x:Class="Drilling.UI.Views.CPmView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="PmButton" TargetType="Button">
            <Setter Property="Height" Value="76" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Visibility="{Binding CurrentScreen.IsPmLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="440" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="116" />
                <RowDefinition Height="*" />
                <RowDefinition Height="190" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Background="{DynamicResource PanelAltBackgroundBrush}"
                    Opacity="0.55" />
            <Border Grid.Row="1"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    Margin="16,0,14,0"
                    Opacity="0.42">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="AUTO Run"
                               Foreground="{DynamicResource PanelBorderBrush}"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Margin="26,18,0,0" />
                    <UniformGrid Grid.Row="1" Columns="2" Margin="26,8,26,28">
                        <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Margin="0,0,12,0" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Check Rule" Foreground="{DynamicResource PanelBorderBrush}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="Door" Foreground="{DynamicResource PanelBorderBrush}" FontSize="15" Margin="0,22,0,0" />
                                <TextBlock Text="Recipe" Foreground="{DynamicResource PanelBorderBrush}" FontSize="15" Margin="0,18,0,0" />
                                <TextBlock Text="Scanner" Foreground="{DynamicResource PanelBorderBrush}" FontSize="15" Margin="0,18,0,0" />
                                <TextBlock Text="Chiller" Foreground="{DynamicResource PanelBorderBrush}" FontSize="15" Margin="0,18,0,0" />
                            </StackPanel>
                        </Border>
                        <Border BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Padding="18">
                            <StackPanel>
                                <TextBlock Text="Process" Foreground="{DynamicResource PanelBorderBrush}" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="Build plan" Foreground="{DynamicResource PanelBorderBrush}" FontSize="15" Margin="0,22,0,0" />
                                <TextBlock Text="Script" Foreground="{DynamicResource PanelBorderBrush}" FontSize="15" Margin="0,18,0,0" />
                                <TextBlock Text="Task" Foreground="{DynamicResource PanelBorderBrush}" FontSize="15" Margin="0,18,0,0" />
                                <TextBlock Text="Result" Foreground="{DynamicResource PanelBorderBrush}" FontSize="15" Margin="0,18,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </Grid>
            </Border>
            <Border Grid.Row="1"
                    Grid.Column="1"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    Margin="0,0,16,0"
                    Opacity="0.36">
                <StackPanel Margin="28">
                    <TextBlock Text="Run Inspector" Foreground="{DynamicResource PanelBorderBrush}" FontSize="18" FontWeight="SemiBold" />
                    <Grid Margin="0,34,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Check" Foreground="{DynamicResource PanelBorderBrush}" FontSize="14" Margin="0,0,0,24" />
                            <TextBlock Text="Recipe" Foreground="{DynamicResource PanelBorderBrush}" FontSize="14" Margin="0,0,0,24" />
                            <TextBlock Text="Scanner" Foreground="{DynamicResource PanelBorderBrush}" FontSize="14" Margin="0,0,0,24" />
                            <TextBlock Text="PM Lock" Foreground="{DynamicResource PanelBorderBrush}" FontSize="14" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="OK" Foreground="{DynamicResource PanelBorderBrush}" FontSize="14" Margin="0,0,0,24" />
                            <TextBlock Text="OK" Foreground="{DynamicResource PanelBorderBrush}" FontSize="14" Margin="0,0,0,24" />
                            <TextBlock Text="OK" Foreground="{DynamicResource PanelBorderBrush}" FontSize="14" Margin="0,0,0,24" />
                            <TextBlock Text="Ready" Foreground="{DynamicResource PanelBorderBrush}" FontSize="14" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.RowSpan="3"
                    Grid.ColumnSpan="2"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    Opacity="0.72" />
        </Grid>

        <Border Width="920"
                Height="690"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}"
                BorderThickness="1.3"
                Padding="84,42">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="112" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="118" />
                    <RowDefinition Height="88" />
                    <RowDefinition Height="116" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="210" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Viewbox Width="94"
                             Height="94"
                             HorizontalAlignment="Right"
                             Margin="0,0,28,0">
                        <Grid Width="96" Height="96">
                            <Ellipse Stroke="{DynamicResource ButtonWarningBorderBrush}"
                                     StrokeThickness="5"
                                     Fill="Transparent" />
                            <Path Data="M32,45 H64 V72 H32 Z M40,45 V36 C40,25 56,25 56,36 V45"
                                  Stroke="{DynamicResource ButtonWarningBorderBrush}"
                                  StrokeThickness="6"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="{DynamicResource ButtonWarningBorderBrush}" />
                            <Ellipse Width="7"
                                     Height="7"
                                     Fill="{DynamicResource PanelBackgroundBrush}"
                                     Canvas.Left="44"
                                     Canvas.Top="52" />
                        </Grid>
                    </Viewbox>
                    <TextBlock Grid.Column="1"
                               Text="PM LOCK"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="48"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </Grid>

                <Border Grid.Row="1" Background="{DynamicResource PanelBorderBrush}" />

                <StackPanel Grid.Row="2" VerticalAlignment="Center">
                    <TextBlock Text="OPERATION LOCKED"
                               Foreground="{DynamicResource ButtonDangerBorderBrush}"
                               FontSize="52"
                               FontWeight="SemiBold"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Enter password to close PM mode"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="26"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0" />
                </StackPanel>

                <Border Grid.Row="3"
                        Width="560"
                        Height="70"
                        HorizontalAlignment="Center"
                        Background="{DynamicResource GridBackgroundBrush}"
                        BorderBrush="{DynamicResource ButtonPrimaryBorderBrush}"
                        BorderThickness="1.5"
                        CornerRadius="6">
                    <Grid Margin="30,0,18,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="42" />
                        </Grid.ColumnDefinitions>
                        <PasswordBox VerticalAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource TextPrimaryBrush}"
                                     FontSize="28"
                                     FontWeight="SemiBold"
                                     Padding="0"
                                     Height="44" />
                        <Viewbox Grid.Column="1" Width="34" Height="34">
                            <Path Data="M2,12 C5,6 9,4 12,4 C15,4 19,6 22,12 C19,18 15,20 12,20 C9,20 5,18 2,12 Z M8,12 A4,4 0 1 1 16,12 A4,4 0 1 1 8,12"
                                  Stroke="{DynamicResource TextMutedBrush}"
                                  StrokeThickness="2"
                                  Fill="Transparent" />
                        </Viewbox>
                    </Grid>
                </Border>

                <Grid Grid.Row="4" Width="720" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="22" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0"
                            Background="{DynamicResource ButtonDangerBrush}"
                            BorderBrush="{DynamicResource ButtonDangerBorderBrush}"
                            Style="{StaticResource PmButton}">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Viewbox Width="34" Height="34" Margin="0,0,20,0">
                                <Path Data="M7,10 H17 V21 H7 Z M9,10 V7 C9,3.5 15,3.5 15,7 V10"
                                      Stroke="{DynamicResource TextPrimaryBrush}"
                                      StrokeThickness="2.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="{DynamicResource TextPrimaryBrush}" />
                            </Viewbox>
                            <TextBlock Text="PM CLOSE" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="2"
                            Content="CLEAR"
                            Background="{DynamicResource PanelAltBackgroundBrush}"
                            BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}"
                            Style="{StaticResource PmButton}" />
                </Grid>

                <Border Grid.Row="5" Background="{DynamicResource PanelBorderBrush}" />

                <Grid Grid.Row="6" Margin="0,22,0,0">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top">
                        <Viewbox Width="30" Height="30" Margin="0,0,14,0">
                            <Path Data="M12,3 A9,9 0 1 1 12,21 A9,9 0 1 1 12,3 M12,7 V12 L16,15"
                                  Stroke="{DynamicResource TextMutedBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Fill="Transparent" />
                        </Viewbox>
                        <TextBlock Text="PM Start Time:"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="22"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="{Binding CurrentScreen.Pm.StartTime}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="18,0,0,0"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>


