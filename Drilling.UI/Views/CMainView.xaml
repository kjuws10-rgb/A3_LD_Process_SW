<UserControl x:Class="Drilling.UI.Views.CMainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="MainSmallText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B6C2CF" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="MainValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F3F6FA" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style x:Key="MainSequenceButton" TargetType="Button">
            <Setter Property="Width" Value="132" />
            <Setter Property="Height" Value="46" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Foreground" Value="#F3F6FA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MainStartButton" TargetType="Button" BasedOn="{StaticResource MainSequenceButton}">
            <Setter Property="Background" Value="#078744" />
            <Setter Property="BorderBrush" Value="#12D466" />
        </Style>
        <Style x:Key="MainStopButton" TargetType="Button" BasedOn="{StaticResource MainSequenceButton}">
            <Setter Property="Background" Value="#A60834" />
            <Setter Property="BorderBrush" Value="#FF2F6D" />
        </Style>
        <Style x:Key="HeadSelectButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="MainDataGrid" TargetType="DataGrid" BasedOn="{StaticResource PlainDataGrid}">
            <Setter Property="MinRowHeight" Value="32" />
            <Setter Property="ColumnHeaderHeight" Value="34" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        </Style>
        <Style x:Key="MainGridText" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="None" />
            <Setter Property="TextWrapping" Value="NoWrap" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="58" />
            <RowDefinition Height="*" />
            <RowDefinition Height="314" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                <TextBlock Text="MAIN / AUTO PROCESS"
                           Foreground="#F3F6FA"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="Scan path preview, script lifecycle status"
                           Foreground="#8B98A8"
                           FontSize="14" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <Button Command="{Binding StartCommand}"
                            Style="{StaticResource MainStartButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▶"
                                       FontSize="15"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="START" />
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding StopCommand}"
                            Style="{StaticResource MainStopButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="■"
                                       FontSize="13"
                                       Margin="0,0,8,0" />
                            <TextBlock Text="STOP" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Grid.Row="1" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="315" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="560" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="132" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource PanelBorder}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="Process Sequence" Style="{StaticResource PanelTitle}" />

                        <StackPanel DockPanel.Dock="Bottom" Margin="0,14,0,0">
                            <TextBlock Text="Current Step Details" Style="{StaticResource MainValueText}" Margin="0,0,0,8" />
                            <ItemsControl ItemsSource="{Binding CurrentScreen.MainOperating.CurrentStepDetails}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,7">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="86" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="7"
                                                     Height="7"
                                                     Fill="{Binding StateBrush}"
                                                     VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Name}"
                                                       Foreground="#DDE6EF"
                                                       FontSize="12" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Value}"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{Binding StateBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding CurrentScreen.MainOperating.ProcessSequenceItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="11,8"
                                            Background="#0C131C"
                                            BorderBrush="#263847"
                                            BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="32" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="74" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="20"
                                                    Height="20"
                                                    BorderBrush="#8B98A8"
                                                    BorderThickness="1"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Name}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="#DDE6EF"
                                                           FontSize="11"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Value}"
                                                       VerticalAlignment="Center"
                                                       Foreground="#F3F6FA"
                                                       FontSize="13"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Detail}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       Foreground="{Binding ValueBrush}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Margin="0,12,0,0" Style="{StaticResource PanelBorder}">
                    <ItemsControl ItemsSource="{Binding CurrentScreen.MainOperating.ProcessSummaryItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" Rows="2" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="#B6C2CF"
                                               FontSize="12"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding Value}"
                                               Margin="0,8,0,0"
                                               Foreground="#F3F6FA"
                                               FontSize="17"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Grid>

            <Border Grid.Column="1" Margin="12,0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="54" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="110" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Head Scan / Automation Preview"
                               Style="{StaticResource PanelTitle}" />

                    <ItemsControl Grid.Row="1"
                                  ItemsSource="{Binding CurrentScreen.MainOperating.HeadPreviews}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.CurrentScreen.MainOperating.SelectHeadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding HeadNo}"
                                        Style="{StaticResource HeadSelectButton}">
                                    <Border Margin="2"
                                            Padding="7"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#0C131C" />
                                                <Setter Property="BorderBrush" Value="#263847" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Background" Value="#0B3B78" />
                                                        <Setter Property="BorderBrush" Value="#2F81F7" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding HeadName}"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#F3F6FA"
                                                       FontSize="11"
                                                       FontWeight="SemiBold" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                                                <Ellipse Width="7"
                                                         Height="7"
                                                         Fill="{Binding StatusBrush}"
                                                         VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Status}"
                                                           Margin="4,0,0,0"
                                                           Foreground="#B6C2CF"
                                                           FontSize="10" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Viewbox Stretch="Uniform">
                            <Canvas Width="860" Height="360" Background="#06101A">
                                <Rectangle Canvas.Left="36" Canvas.Top="32" Width="824" Height="250"
                                           Stroke="#00D8FF" StrokeThickness="2" StrokeDashArray="2 3" Fill="#07141D" />
                                <TextBlock Canvas.Left="42" Canvas.Top="306" Text="GY" Foreground="#12D466" FontWeight="SemiBold" />
                                <TextBlock Canvas.Left="62" Canvas.Top="330" Text="GX" Foreground="#FF2F6D" FontWeight="SemiBold" />
                                <Line X1="52" Y1="330" X2="88" Y2="330" Stroke="#FF2F6D" StrokeThickness="3" />
                                <Line X1="52" Y1="330" X2="52" Y2="304" Stroke="#12D466" StrokeThickness="3" />
                                <Ellipse Canvas.Left="46" Canvas.Top="298" Width="12" Height="12" Stroke="#12D466" StrokeThickness="3" />

                                <TextBlock Canvas.Left="62"
                                           Canvas.Top="48"
                                           Text="{Binding CurrentScreen.MainOperating.SelectedHeadPreview.HeadName}"
                                           Foreground="#F3F6FA"
                                           FontSize="20"
                                           FontWeight="SemiBold" />
                                <StackPanel Canvas.Left="178"
                                            Canvas.Top="54"
                                            Orientation="Horizontal">
                                    <Ellipse Width="10"
                                             Height="10"
                                             Fill="{Binding CurrentScreen.MainOperating.SelectedHeadPreview.StatusBrush}"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding CurrentScreen.MainOperating.SelectedHeadPreview.Status}"
                                               Margin="8,0,0,0"
                                               Foreground="#B6C2CF"
                                               FontSize="13"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                                <TextBlock Canvas.Left="782"
                                           Canvas.Top="54"
                                           Text="{Binding CurrentScreen.MainOperating.SelectedHeadPreview.PointSummary}"
                                           Foreground="#8B98A8"
                                           FontSize="13" />

                                <Viewbox Canvas.Left="210"
                                          Canvas.Top="76"
                                          Width="500"
                                          Height="190"
                                          Stretch="Uniform">
                                    <Canvas Width="120" Height="84" Background="Transparent">
                                        <Path Data="{Binding CurrentScreen.MainOperating.SelectedHeadPreview.PreviewGeometry}"
                                              Stroke="#27C7F7"
                                              StrokeThickness="3"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent" />
                                        <Path Data="{Binding CurrentScreen.MainOperating.SelectedHeadPreview.PreviewGeometry}"
                                              Stroke="#FFC400"
                                              StrokeThickness="1.2"
                                              StrokeDashArray="4 4"
                                              Fill="Transparent" />
                                        <Path Data="{Binding CurrentScreen.MainOperating.SelectedHeadPreview.PreviewGeometry}"
                                              Stroke="#FF2F6D"
                                              StrokeThickness="0.9"
                                              StrokeDashArray="8 18"
                                              Fill="Transparent" />
                                    </Canvas>
                                </Viewbox>

                                <TextBlock Canvas.Left="418" Canvas.Top="318" Text="X (mm)" Foreground="#B6C2CF" />
                                <TextBlock Canvas.Left="62" Canvas.Top="288" Text="Stage Start (0,0,0)" Foreground="#DDE6EF" />
                            </Canvas>
                        </Viewbox>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="64" />
                        </Grid.ColumnDefinitions>

                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="All Head Mini Map" Style="{StaticResource MainValueText}" Margin="0,0,0,8" />
                            <ItemsControl ItemsSource="{Binding CurrentScreen.MainOperating.HeadPreviews}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Rows="1" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.CurrentScreen.MainOperating.SelectHeadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding HeadNo}"
                                                Style="{StaticResource HeadSelectButton}">
                                            <Border Margin="2" Padding="4" BorderThickness="1">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#0C131C" />
                                                        <Setter Property="BorderBrush" Value="#263847" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#0B3B78" />
                                                                <Setter Property="BorderBrush" Value="#2F81F7" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="16" />
                                                        <RowDefinition Height="*" />
                                                    </Grid.RowDefinitions>
                                                    <TextBlock Text="{Binding HeadName}" HorizontalAlignment="Center" Foreground="#DDE6EF" FontSize="10" />
                                                    <Viewbox Grid.Row="1" Stretch="Uniform">
                                                        <Canvas Width="90" Height="50">
                                                            <Path Data="{Binding PreviewGeometry}" Stroke="#27C7F7" StrokeThickness="3" Fill="Transparent" />
                                                            <Path Data="{Binding PreviewGeometry}" Stroke="#FFC400" StrokeThickness="1" Fill="Transparent" StrokeDashArray="2 2" />
                                                        </Canvas>
                                                    </Viewbox>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>

                        <StackPanel Grid.Column="1" VerticalAlignment="Bottom" Margin="8,0,0,0">
                            <Button Content="+" Style="{StaticResource SecondaryButton}" MinWidth="44" Margin="0,0,0,8" />
                            <Button Content="FIT" Style="{StaticResource SecondaryButton}" MinWidth="44" Margin="0" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Head Parameter" Style="{StaticResource PanelTitle}" />
                    <DataGrid ItemsSource="{Binding CurrentScreen.MainOperating.HeadParameters}"
                              IsReadOnly="True"
                              Style="{StaticResource MainDataGrid}"
                              FontSize="11">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Head" Binding="{Binding Head}" Width="58" ElementStyle="{StaticResource MainGridText}" />
                            <DataGridCheckBoxColumn Header="Use" Binding="{Binding Use}" Width="56" />
                            <DataGridTextColumn Header="Shape" Binding="{Binding Shape}" Width="92" ElementStyle="{StaticResource MainGridText}" />
                            <DataGridTextColumn Header="Power" Binding="{Binding Power, StringFormat=F2}" Width="74" ElementStyle="{StaticResource MainGridText}" />
                            <DataGridTextColumn Header="Freq" Binding="{Binding Frequency, StringFormat=F1}" Width="74" ElementStyle="{StaticResource MainGridText}" />
                            <DataGridTextColumn Header="Shot" Binding="{Binding Shot}" Width="78" ElementStyle="{StaticResource MainGridText}" />
                            <DataGridTextColumn Header="Speed" Binding="{Binding Speed, StringFormat=F0}" Width="78" ElementStyle="{StaticResource MainGridText}" />
                            <DataGridTextColumn Header="Offset X" Binding="{Binding OffsetX, StringFormat=F3}" Width="92" ElementStyle="{StaticResource MainGridText}" />
                            <DataGridTextColumn Header="Offset Y" Binding="{Binding OffsetY, StringFormat=F3}" Width="92" ElementStyle="{StaticResource MainGridText}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="660" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelBorder}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Interface Log" Style="{StaticResource PanelTitle}" />
                    <DataGrid ItemsSource="{Binding CurrentScreen.MainOperating.InterfaceLogs}"
                              IsReadOnly="True"
                              Style="{StaticResource MainDataGrid}"
                              FontSize="11">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="104" ElementStyle="{StaticResource MainGridText}" />
                            <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="70" ElementStyle="{StaticResource MainGridText}" />
                            <DataGridTextColumn Header="Source" Binding="{Binding Source}" Width="92" ElementStyle="{StaticResource MainGridText}" />
                            <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="*" MinWidth="300" ElementStyle="{StaticResource MainGridText}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Margin="12,0" Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Automation1 Script Status" Style="{StaticResource PanelTitle}" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="270" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <DataGrid Grid.Column="0"
                                  ItemsSource="{Binding CurrentScreen.MainOperating.ScriptStatusItems}"
                                  IsReadOnly="True"
                                  Style="{StaticResource MainDataGrid}"
                                  FontSize="11">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Item" Binding="{Binding Name}" Width="106" ElementStyle="{StaticResource MainGridText}" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" MinWidth="140" ElementStyle="{StaticResource MainGridText}" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Column="1" Margin="12,0,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="88" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <DockPanel Grid.Row="0">
                                <TextBlock DockPanel.Dock="Top" Text="Lifecycle" Style="{StaticResource MainValueText}" Margin="0,0,0,12" />
                                <ItemsControl ItemsSource="{Binding CurrentScreen.MainOperating.LifecycleItems}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Rows="1" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel HorizontalAlignment="Center">
                                                <Ellipse Width="18"
                                                         Height="18"
                                                         Stroke="{Binding StateBrush}"
                                                         StrokeThickness="3"
                                                         Fill="#0B1119" />
                                                <TextBlock Text="{Binding Name}" Margin="0,8,0,0" Foreground="#B6C2CF" FontSize="11" />
                                                <TextBlock Text="{Binding Value}" Foreground="{Binding StateBrush}" FontSize="11" FontWeight="SemiBold" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>

                            <StackPanel Grid.Row="1">
                                <TextBlock Text="{Binding CurrentScreen.MainOperating.TotalPointsText}" Style="{StaticResource MainValueText}" Margin="0,0,0,7" FontSize="12" />
                                <TextBlock Text="{Binding CurrentScreen.MainOperating.MoveCountText}" Style="{StaticResource MainValueText}" Margin="0,0,0,7" FontSize="12" />
                                <TextBlock Text="{Binding CurrentScreen.MainOperating.LaserOnSegmentsText}" Style="{StaticResource MainValueText}" Margin="0,0,0,7" FontSize="12" />
                                <TextBlock Text="{Binding CurrentScreen.MainOperating.EstimatedTimeText}" Style="{StaticResource MainValueText}" Margin="0,0,0,7" FontSize="12" />
                                <TextBlock Text="{Binding CurrentScreen.MainOperating.ElapsedTimeText}" Style="{StaticResource MainValueText}" Margin="0,0,0,7" FontSize="12" />
                                <TextBlock Text="{Binding CurrentScreen.MainOperating.ProgressText}" Style="{StaticResource MainValueText}" Margin="0,0,0,6" FontSize="12" />
                                <ProgressBar Height="14" Value="{Binding CurrentScreen.MainOperating.ProgressPercent, Mode=OneWay}" Maximum="100" Foreground="#2F81F7" Background="#273241" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Interlock / Safety Summary" Style="{StaticResource PanelTitle}" />
                    <Border DockPanel.Dock="Bottom"
                            BorderBrush="#263847"
                            BorderThickness="1,0,0,0"
                            Padding="0,10,0,0"
                            Margin="0,10,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Process Result" Style="{StaticResource MainValueText}" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding CurrentScreen.MainOperating.ProcessResultValue}"
                                       Foreground="{Binding CurrentScreen.MainOperating.ProcessResultBrush}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right" />
                        </Grid>
                    </Border>
                    <DataGrid ItemsSource="{Binding CurrentScreen.MainOperating.InterlockItems}"
                              IsReadOnly="True"
                              Style="{StaticResource MainDataGrid}"
                              FontSize="11">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Signal" Binding="{Binding Signal}" Width="118" ElementStyle="{StaticResource MainGridText}" />
                            <DataGridTextColumn Header="State" Binding="{Binding State}" Width="82" ElementStyle="{StaticResource MainGridText}" />
                            <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*" MinWidth="170" ElementStyle="{StaticResource MainGridText}" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
