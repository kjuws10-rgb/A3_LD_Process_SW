                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,10" />
                        </Grid>

                        <DataGrid ItemsSource="{Binding CurrentScreen.Monitor.MelsecRows}"
                                  Style="{StaticResource PlainDataGrid}"
                                  FontSize="12"
                                  ColumnHeaderHeight="38"
                                  RowHeight="38"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="190" IsReadOnly="True" />
                                <DataGridTextColumn Header="Group" Binding="{Binding Group}" Width="96" IsReadOnly="True" />
                                <DataGridTextColumn Header="Addr" Binding="{Binding Address}" Width="104" IsReadOnly="True" />
                                <DataGridTextColumn Header="Type" Binding="{Binding DataType}" Width="82" IsReadOnly="True" />
                                <DataGridTextColumn Header="Dir" Binding="{Binding Direction}" Width="62" IsReadOnly="True" />
                                <DataGridTextColumn Header="Access" Binding="{Binding Access}" Width="70" IsReadOnly="True" />
                                <DataGridTextColumn Header="Read Value" Binding="{Binding ReadValue}" Width="120" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding ValueBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Write Value" Binding="{Binding WriteValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                                <DataGridTemplateColumn Header="Read" Width="82">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="READ"
                                                    IsEnabled="{Binding CanRead}"
                                                    Background="{DynamicResource MenuItemSelectedBackgroundBrush}"
                                                    BorderBrush="{DynamicResource ButtonPrimaryBorderBrush}"
                                                    Command="{Binding DataContext.CurrentScreen.Monitor.ReadMelsecCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource IoCommandButton}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Write" Width="82">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="WRITE"
                                                    IsEnabled="{Binding CanWrite}"
                                                    Background="{DynamicResource ButtonWarningBrush}"
                                                    BorderBrush="{DynamicResource ButtonWarningBorderBrush}"
                                                    Command="{Binding DataContext.CurrentScreen.Monitor.WriteMelsecCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource IoCommandButton}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="86" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding StateBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="180" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="280" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Map Rule"
                                       Style="{StaticResource PanelTitle}"
                                       FontSize="18" />
                            <DataGrid ItemsSource="{Binding CurrentScreen.Monitor.ParameterRows}"
                                      IsReadOnly="True"
                                      Style="{StaticResource PlainDataGrid}"
                                      FontSize="12"
                                      ColumnHeaderHeight="38"
                                      RowHeight="34">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Parameter" Binding="{Binding Parameter}" Width="150" />
                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{Binding ValueBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource PanelBorder}">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="{Binding CurrentScreen.Monitor.HistoryPanelTitle}"
                                       Style="{StaticResource PanelTitle}"
                                       FontSize="18" />
                            <DataGrid ItemsSource="{Binding CurrentScreen.Monitor.CommandHistoryRows}"
                                      IsReadOnly="True"
                                      Style="{StaticResource PlainDataGrid}"
                                      FontSize="12"
                                      ColumnHeaderHeight="38"
                                      RowHeight="36"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="104" />
                                    <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="150" />
                                    <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="*" MinWidth="130" />
                                    <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="80">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{Binding ResultBrush}" />
                                                <Setter Property="FontWeight" Value="SemiBold" />
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Visibility="{Binding CurrentScreen.Monitor.IsGenericDevice, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="520" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="560" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,12,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding CurrentScreen.Monitor.StatusPanelTitle}"
                                   Style="{StaticResource PanelTitle}"
                                   FontSize="18" />
                        <DataGrid ItemsSource="{Binding CurrentScreen.Monitor.StatusRows}"
                                  IsReadOnly="True"
                                  Style="{StaticResource PlainDataGrid}"
                                  ColumnHeaderHeight="38"
                                  RowHeight="40">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Item" Binding="{Binding Item}" Width="150" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="130" />
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="90" />
                                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="0,0,12,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding CurrentScreen.Monitor.ParameterPanelTitle}"
                                   Style="{StaticResource PanelTitle}"
                                   FontSize="18" />
                        <DataGrid ItemsSource="{Binding CurrentScreen.Monitor.ParameterRows}"
                                  IsReadOnly="True"
                                  Style="{StaticResource PlainDataGrid}"
                                  ColumnHeaderHeight="38"
                                  RowHeight="40">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Parameter" Binding="{Binding Parameter}" Width="220" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="160" />
                                <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource PanelBorder}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding CurrentScreen.Monitor.HistoryPanelTitle}"
                                   Style="{StaticResource PanelTitle}"
                                   FontSize="18" />
                        <DataGrid ItemsSource="{Binding CurrentScreen.Monitor.CommandHistoryRows}"
                                  IsReadOnly="True"
                                  Style="{StaticResource PlainDataGrid}"
                                  ColumnHeaderHeight="38"
                                  RowHeight="38">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="118" />
                                <DataGridTextColumn Header="User" Binding="{Binding User}" Width="72" />
                                <DataGridTextColumn Header="Device" Binding="{Binding Name}" Width="110" />
                                <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="160" />
                                <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

