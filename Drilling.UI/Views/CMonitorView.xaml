<UserControl x:Class="Drilling.UI.Views.CMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="MonitorSmallText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="MonitorValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="MonitorTabButton" TargetType="Button">
            <Setter Property="Height" Value="42" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="{DynamicResource ButtonSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MonitorActionButton" TargetType="Button">
            <Setter Property="Height" Value="58" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IoCommandButton" TargetType="Button">
            <Setter Property="Height" Value="26" />
            <Setter Property="Width" Value="66" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MonitorInputCell" TargetType="Border">
            <Setter Property="Height" Value="30" />
            <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </UserControl.Resources>

    <Grid Visibility="{Binding CurrentScreen.IsMonitorLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="62" />
            <RowDefinition Height="54" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="{Binding CurrentScreen.Monitor.Title}"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="31"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding CurrentScreen.Monitor.Subtitle}"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="15" />
        </StackPanel>

        <ItemsControl Grid.Row="1"
                      ItemsSource="{Binding CurrentScreen.Monitor.Tabs}"
                      Margin="0,6,0,6">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="1" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button Content="{Binding Name}"
                            Command="{Binding DataContext.CurrentScreen.Monitor.SelectTabCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding Name}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource MonitorTabButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource MenuItemSelectedBackgroundBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ButtonPrimaryBorderBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Grid Grid.Row="2">
            <Grid Visibility="{Binding CurrentScreen.Monitor.IsIo, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44*" />
                    <ColumnDefinition Width="56*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,12,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Input Monitor"
                                   Style="{StaticResource PanelTitle}"
                                   FontSize="18" />
                        <DataGrid ItemsSource="{Binding CurrentScreen.Monitor.InputRows}"
                                  IsReadOnly="True"
                                  Style="{StaticResource PlainDataGrid}"
                                  FontSize="12"
                                  ColumnHeaderHeight="42"
                                  RowHeight="38">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="100" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                <DataGridTemplateColumn Header="State" Width="110">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding StateBrush}"
                                                    CornerRadius="4"
                                                    Width="56"
                                                    Height="24"
                                                    HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding State}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource PanelBorder}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Output Monitor"
                                       Style="{StaticResource PanelTitle}"
                                       FontSize="18" />
                            <TextBlock Grid.Column="1"
                                       Text="Output rows can be operated directly from ON / OFF cells"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,4,10" />
                        </Grid>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding CurrentScreen.Monitor.OutputRows}"
                                  IsReadOnly="True"
                                  Style="{StaticResource PlainDataGrid}"
                                  FontSize="12"
                                  ColumnHeaderHeight="42"
                                  RowHeight="38">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="96" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                                <DataGridTemplateColumn Header="State" Width="96">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Background="{Binding StateBrush}"
                                                    CornerRadius="4"
                                                    Width="56"
                                                    Height="24"
                                                    HorizontalAlignment="Center">
                                                <TextBlock Text="{Binding State}"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="ON" Width="96">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="ON"
                                                    Background="{DynamicResource ButtonSuccessBrush}"
                                                    BorderBrush="{DynamicResource StatusReadyBrush}"
                                                    Command="{Binding DataContext.CurrentScreen.Monitor.SetOutputOnCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Style="{StaticResource IoCommandButton}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="OFF" Width="96">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="OFF"
                                                    Background="{DynamicResource ButtonSecondaryBrush}"
                                                    BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}"
                                                    Command="{Binding DataContext.CurrentScreen.Monitor.SetOutputOffCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    Style="{StaticResource IoCommandButton}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </Grid>

            <Grid Visibility="{Binding CurrentScreen.Monitor.IsMotor, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="610" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="250" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,12,12">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Axis Monitor"
                                   Style="{StaticResource PanelTitle}"
                                   FontSize="18" />
                        <DataGrid ItemsSource="{Binding CurrentScreen.Monitor.AxisRows}"
                                  SelectedItem="{Binding CurrentScreen.Monitor.SelectedAxisRow, Mode=TwoWay}"
                                  IsReadOnly="True"
                                  Style="{StaticResource PlainDataGrid}"
                                  FontSize="12"
                                  ColumnHeaderHeight="36"
                                  RowHeight="34"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Axis" Binding="{Binding Axis}" Width="112" />
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="130" />
                                <DataGridTextColumn Header="Current" Binding="{Binding CurrentPosition}" Width="105" />
                                <DataGridTextColumn Header="Target" Binding="{Binding TargetPosition}" Width="105" />
                                <DataGridTextColumn Header="Command" Binding="{Binding CommandPosition}" Width="110" />
                                <DataGridTextColumn Header="Servo" Binding="{Binding Servo}" Width="50">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding ServoBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Home" Binding="{Binding Home}" Width="56" />
                                <DataGridTextColumn Header="Lim +" Binding="{Binding LimitPlus}" Width="56" />
                                <DataGridTextColumn Header="Lim -" Binding="{Binding LimitMinus}" Width="56" />
                                <DataGridTextColumn Header="Alarm" Binding="{Binding Alarm}" Width="50" />
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="68">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding StateBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,12,0">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding CurrentScreen.Monitor.HistoryPanelTitle}"
                                   Style="{StaticResource PanelTitle}"
                                   FontSize="18" />
                        <DataGrid ItemsSource="{Binding CurrentScreen.Monitor.CommandHistoryRows}"
                                  IsReadOnly="True"
                                  Style="{StaticResource PlainDataGrid}"
                                  FontSize="12"
                                  ColumnHeaderHeight="38"
                                  RowHeight="34">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="210" />
                                <DataGridTextColumn Header="User" Binding="{Binding User}" Width="140" />
                                <DataGridTextColumn Header="Axis" Binding="{Binding Name}" Width="160" />
                                <DataGridTextColumn Header="Command" Binding="{Binding Command}" Width="210" />
                                <DataGridTextColumn Header="Target" Binding="{Binding Target}" Width="200" />
                                <DataGridTextColumn Header="Result" Binding="{Binding Result}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding ResultBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="142" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="{Binding CurrentScreen.Monitor.SelectedAxisId, StringFormat=Axis Operation  (Selected Axis : {0})}"
                                   Style="{StaticResource PanelTitle}"
                                   FontSize="18" />
                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding CurrentScreen.Monitor.OperationButtons}"
                                      Margin="0,8,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="{Binding BackgroundBrush}"
                                            BorderBrush="{Binding BorderBrush}"
                                            Command="{Binding DataContext.CurrentScreen.Monitor.ExecuteOperationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource MonitorActionButton}">
                                        <Grid HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="26" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Viewbox Width="18" Height="18">
                                                <Path Data="{Binding IconGeometry}"
                                                      Stroke="{DynamicResource TextPrimaryBrush}"
                                                      StrokeThickness="2"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      StrokeLineJoin="Round"
                                                      Fill="Transparent" />
                                            </Viewbox>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Label}"
                                                       VerticalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <ItemsControl Grid.Row="2"
                                      ItemsSource="{Binding CurrentScreen.Monitor.OperationFields}"
                                      Margin="0,14,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="38">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="76" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Parameter}"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource MonitorSmallText}" />
                                        <Border Grid.Column="1" Style="{StaticResource MonitorInputCell}">
                                            <TextBlock Text="{Binding Value}"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource AccentTextBrush}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Unit}"
                                                   Margin="10,0,0,8"
                                                   VerticalAlignment="Center"
                                                   Style="{StaticResource MonitorSmallText}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelBorder}">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding CurrentScreen.Monitor.ParameterPanelTitle}"
                                   Style="{StaticResource PanelTitle}"
                                   FontSize="18" />
                        <DataGrid ItemsSource="{Binding CurrentScreen.Monitor.ParameterRows}"
                                  IsReadOnly="True"
                                  Style="{StaticResource PlainDataGrid}"
                                  FontSize="12"
                                  ColumnHeaderHeight="38"
                                  RowHeight="32">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Parameter" Binding="{Binding Parameter}" Width="220" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="180">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding ValueBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <Grid Visibility="{Binding CurrentScreen.Monitor.IsPowerMeter, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" Style="{StaticResource PanelBorder}" Margin="0,0,8,6">
                    <TextBlock Text="PROCESS LIST"
                               Style="{StaticResource PanelTitle}"
                               FontSize="17"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <Border Grid.Row="1" Grid.RowSpan="15" Grid.Column="0" Grid.ColumnSpan="4" Style="{StaticResource PanelBorder}" Margin="0,0,8,8">
                    <DockPanel>
                        <DataGrid ItemsSource="{Binding CurrentScreen.Monitor.PwmProcessRows}"
                                  IsReadOnly="True"
                                  Style="{StaticResource PlainDataGrid}"
                                  FontSize="12"
                                  ColumnHeaderHeight="38"
                                  RowHeight="38"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Foreground" Value="{Binding RowBrush}" />
                                    <Setter Property="FontWeight" Value="SemiBold" />
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="NO" Binding="{Binding No}" Width="58" />
                                <DataGridTextColumn Header="FILE NAME" Binding="{Binding ProcessName}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{Binding RowBrush}" />
                                            <Setter Property="FontWeight" Value="SemiBold" />
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>

                <ItemsControl Grid.Row="16" Grid.RowSpan="4" Grid.Column="0" Grid.ColumnSpan="4"
                              ItemsSource="{Binding CurrentScreen.Monitor.PwmProcessButtons}"
                              Margin="0,0,8,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="2" Columns="2" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Background="{Binding BackgroundBrush}"
                                    BorderBrush="{Binding BorderBrush}"
                                    Command="{Binding DataContext.CurrentScreen.Monitor.ExecuteOperationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Height="54"
                                    Margin="4"
                                    Style="{StaticResource MonitorActionButton}">
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Viewbox Width="16" Height="16">
                                        <Path Data="{Binding IconGeometry}"
                                              Stroke="{DynamicResource TextPrimaryBrush}"
                                              StrokeThickness="2"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Fill="Transparent" />
                                    </Viewbox>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Label}"
                                               VerticalAlignment="Center"
                                               TextAlignment="Center"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="0" Grid.Column="4" Grid.ColumnSpan="16" Style="{StaticResource PanelBorder}" Margin="0,0,0,6">
                    <TextBlock Text="MEASURE STEP"
                               Style="{StaticResource PanelTitle}"
                               FontSize="17"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <Border Grid.Row="1" Grid.RowSpan="9" Grid.Column="4" Grid.ColumnSpan="16" Style="{StaticResource PanelBorder}" Margin="0,0,0,8">
                    <DataGrid ItemsSource="{Binding CurrentScreen.Monitor.PwmStepRows}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              FontSize="11"
                              ColumnHeaderHeight="36"
                              RowHeight="33"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Foreground" Value="{Binding RowBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="NO" Binding="{Binding Step}" Width="50" />
                            <DataGridTextColumn Header="Option Name" Binding="{Binding OptionName}" Width="*" MinWidth="145" />
                            <DataGridTextColumn Header="Power (%)" Binding="{Binding SettingPower}" Width="88" />
                            <DataGridTextColumn Header="Freq (kHz)" Binding="{Binding SettingFreq}" Width="86" />
                            <DataGridTextColumn Header="Cycle" Binding="{Binding MeasureCycle}" Width="64" />
                            <DataGridTextColumn Header="Measure Time" Binding="{Binding MeasureTime}" Width="106" />
                            <DataGridTextColumn Header="Interval Time" Binding="{Binding MeasureInterval}" Width="108" />
                            <DataGridTextColumn Header="Start Delay" Binding="{Binding StartDelay}" Width="96" />
                            <DataGridTextColumn Header="Cooling Time" Binding="{Binding CycleDelay}" Width="98" />
                            <DataGridTextColumn Header="ATT Power(%)" Binding="{Binding SettingAtt}" Width="100" />
                            <DataGridTextColumn Header="Rotator" Binding="{Binding Rotator}" Width="78" />
                            <DataGridTextColumn Header="MeasurePower(W)" Binding="{Binding MeasurePower}" Width="122" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="10" Grid.Column="4" Grid.ColumnSpan="12" Style="{StaticResource PanelBorder}" Margin="0,0,8,6">
                    <TextBlock Text="SETTING"
                               Style="{StaticResource PanelTitle}"
                               FontSize="17"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <Border Grid.Row="11" Grid.RowSpan="9" Grid.Column="4" Grid.ColumnSpan="9" Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                    <DataGrid ItemsSource="{Binding CurrentScreen.Monitor.PwmSettingRows}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              FontSize="12"
                              ColumnHeaderHeight="34"
                              RowHeight="28">
                        <DataGrid.Columns>
