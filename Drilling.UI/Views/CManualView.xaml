<UserControl x:Class="Drilling.UI.Views.CManualView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             FontFamily="Segoe UI">
    <UserControl.Resources>
        <Style x:Key="ManualSmallText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="ManualValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ManualInput" TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="ManualHeadButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ManualCommandButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonPrimaryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="{DynamicResource ButtonPrimaryBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LaserActionButton" TargetType="Button" BasedOn="{StaticResource ManualCommandButton}">
            <Setter Property="Height" Value="68" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ManualCreateButton" TargetType="Button" BasedOn="{StaticResource ManualCommandButton}">
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="{DynamicResource ButtonPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonPrimaryBorderBrush}" />
        </Style>

        <Style x:Key="ManualDeleteButton" TargetType="Button" BasedOn="{StaticResource ManualCommandButton}">
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="{DynamicResource ButtonDangerBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonDangerBrush}" />
        </Style>

        <Style x:Key="ManualRenameButton" TargetType="Button" BasedOn="{StaticResource ManualCommandButton}">
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="{DynamicResource ButtonWarningBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonWarningBorderBrush}" />
        </Style>

        <Style x:Key="ManualSaveButton" TargetType="Button" BasedOn="{StaticResource ManualCommandButton}">
            <Setter Property="Height" Value="28" />
            <Setter Property="Background" Value="{DynamicResource ButtonSuccessBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource StatusReadyBrush}" />
        </Style>

        <Style x:Key="ManualComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource MenuItemSelectedBackgroundBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonPrimaryBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ManualComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource GridBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource ManualComboBoxItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Shell"
                                                Background="{DynamicResource GridBackgroundBrush}"
                                                BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Grid>
                                                <ContentPresenter Margin="10,0,36,0"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  RecognizesAccessKey="True"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  ContentStringFormat="{Binding SelectionBoxItemStringFormat, RelativeSource={RelativeSource AncestorType=ComboBox}}" />
                                                <Path Data="M 0 0 L 5 5 L 10 0 Z"
                                                      Fill="{DynamicResource TextSecondaryBrush}"
                                                      Width="10"
                                                      Height="5"
                                                      Stretch="Fill"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Shell" Property="BorderBrush" Value="{DynamicResource AccentTextBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource GridBackgroundBrush}"
                                        BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="160">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingListText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
    </UserControl.Resources>

    <Grid Visibility="{Binding CurrentScreen.IsManualLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="58" />
            <RowDefinition Height="154" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="MANUAL / SCANNER CONTROL"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       FontSize="28"
                       FontWeight="SemiBold" />
            <TextBlock Text="Single head scanner move, shape scan, manual parameter save/load"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       FontSize="14" />
        </StackPanel>

        <Border Grid.Row="1"
                Style="{StaticResource PanelBorder}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="Head Select (Select one head)"
                           Style="{StaticResource PanelTitle}" />

                <ItemsControl ItemsSource="{Binding CurrentScreen.Manual.HeadCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding DataContext.CurrentScreen.Manual.SelectHeadCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding HeadNo}"
                                    Style="{StaticResource ManualHeadButton}">
                                <Border Margin="4,0"
                                        Padding="12,10"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource MenuItemSelectedBackgroundBrush}" />
                                                    <Setter Property="BorderBrush" Value="{DynamicResource MenuItemSelectedBorderBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="24" />
                                            <RowDefinition Height="22" />
                                            <RowDefinition Height="22" />
                                            <RowDefinition Height="22" />
                                        </Grid.RowDefinitions>

                                        <StackPanel Orientation="Horizontal">
                                            <Ellipse Width="17"
                                                     Height="17"
                                                     Stroke="{DynamicResource TextPrimaryBrush}"
                                                     StrokeThickness="2"
                                                     VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="Transparent" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Fill" Value="{DynamicResource AccentTextBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>
                                            <TextBlock Text="{Binding HeadName}"
                                                       Margin="8,0,0,0"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>

                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Gx, StringFormat=GX  {0}}"
                                                   Style="{StaticResource ManualValueText}"
                                                   FontSize="12" />
                                        <TextBlock Grid.Row="2"
                                                   Text="{Binding Gy, StringFormat=GY  {0}}"
                                                   Style="{StaticResource ManualValueText}"
                                                   FontSize="12" />
                                        <StackPanel Grid.Row="3"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center">
                                            <Ellipse Width="12"
                                                     Height="12"
                                                     Fill="{Binding StateBrush}" />
                                            <TextBlock Text="{Binding State}"
                                                       Margin="8,0,0,0"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="430" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="470" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="72" />
                        <RowDefinition Height="174" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Manual Setting (SCAN SETTING/*.scan)"
                               Style="{StaticResource PanelTitle}" />

                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36" />
                            <RowDefinition Height="36" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Row="0" Grid.Column="0" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1" Padding="8">
                            <TextBlock Text="Loaded Setting" Style="{StaticResource ManualSmallText}" />
                        </Border>
                        <Border Grid.Row="0" Grid.Column="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,1,1,1" Padding="8">
                            <TextBlock Text="{Binding CurrentScreen.Manual.LoadedSettingName}"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                        </Border>
                        <Border Grid.Row="1" Grid.Column="0" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="1,0,1,1" Padding="8">
                            <TextBlock Text="Path" Style="{StaticResource ManualSmallText}" />
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" BorderBrush="{DynamicResource PanelBorderBrush}" BorderThickness="0,0,1,1" Padding="8">
                            <TextBlock Text="{Binding CurrentScreen.Manual.LoadedSettingPath}"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="122" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Setting List"
                                   Style="{StaticResource ManualValueText}" />

                        <ItemsControl Grid.Row="1"
                                      ItemsSource="{Binding CurrentScreen.Manual.SettingFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.CurrentScreen.Manual.SelectSettingCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Name}"
                                            Style="{StaticResource ManualHeadButton}">
                                        <Border Height="27"
                                                Padding="8,5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource ButtonPrimaryBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Name}"
                                                       Style="{StaticResource SettingListText}" />
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="12,0,0,0">
                            <Button Content="CREATE"
                                    Command="{Binding CurrentScreen.Manual.CreateCommand}"
                                    Style="{StaticResource ManualCreateButton}"
                                    Margin="0,0,0,7" />
                            <Button Content="DELETE"
                                    Command="{Binding CurrentScreen.Manual.DeleteCommand}"
                                    Style="{StaticResource ManualDeleteButton}"
                                    Margin="0,0,0,7" />
                            <Button Content="RENAME"
                                    Command="{Binding CurrentScreen.Manual.RenameCommand}"
                                    Style="{StaticResource ManualRenameButton}"
                                    Margin="0,0,0,7" />
                            <Button Content="SAVE"
                                    Command="{Binding CurrentScreen.Manual.SaveCommand}"
                                    Style="{StaticResource ManualSaveButton}"
                                    Margin="0" />
                        </StackPanel>
                    </Grid>

                    <DockPanel Grid.Row="3" Margin="0,12,0,0">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{Binding CurrentScreen.Manual.LoadedSettingName, StringFormat=Setting Parameter (for {0})}"
                                   Style="{StaticResource ManualValueText}"
                                   Margin="0,0,0,8" />
                        <DataGrid ItemsSource="{Binding CurrentScreen.Manual.SettingParameters}"
                                  IsReadOnly="False"
                                  Style="{StaticResource PlainDataGrid}"
                                  FontSize="11">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Parameter" Binding="{Binding Parameter}" Width="*" IsReadOnly="True" />
                                <DataGridTextColumn Header="Value" Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="86" />
                                <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="72" IsReadOnly="True" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="12,0"
                    Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="182" />
                        <RowDefinition Height="1" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding CurrentScreen.Manual.SelectedHead, StringFormat=Manual Scan Command (Selected Head : {0})}"
                               Style="{StaticResource PanelTitle}" />

                    <Grid Grid.Row="1" Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="300" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Position Move"
                                   Style="{StaticResource ManualValueText}" />

                        <UniformGrid Grid.Row="1"
                                     Columns="3"
                                     Margin="0,14,24,0">
                            <Button Height="118"
                                    Style="{StaticResource ManualCommandButton}"
                                    Margin="0,0,12,0">
                                <StackPanel>
                                    <Viewbox Width="42" Height="42" Margin="0,0,0,10">
                                        <Canvas Width="48" Height="48">
                                            <Ellipse Canvas.Left="12" Canvas.Top="12" Width="24" Height="24"
                                                     Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" Fill="Transparent" />
                                            <Ellipse Canvas.Left="21" Canvas.Top="21" Width="6" Height="6"
                                                     Fill="{DynamicResource TextSecondaryBrush}" />
                                            <Line X1="24" Y1="4" X2="24" Y2="44" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" />
                                            <Line X1="4" Y1="24" X2="44" Y2="24" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="CENTER MOVE"
                                               HorizontalAlignment="Center"
                                               FontSize="15"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Height="118"
                                    Style="{StaticResource ManualCommandButton}"
                                    Margin="0,0,12,0">
                                <StackPanel>
                                    <Viewbox Width="42" Height="42" Margin="0,0,0,10">
                                        <Canvas Width="48" Height="48">
                                            <Path Data="M24,4 C15,4 9,11 9,20 C9,33 24,44 24,44 C24,44 39,33 39,20 C39,11 33,4 24,4 Z"
                                                  Fill="{DynamicResource TextSecondaryBrush}" />
                                            <Ellipse Canvas.Left="17" Canvas.Top="13" Width="14" Height="14"
                                                     Fill="{DynamicResource ButtonPrimaryBrush}" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="POSITION MOVE"
                                               HorizontalAlignment="Center"
                                               FontSize="15"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Height="118"
                                    Background="{DynamicResource ButtonDangerBrush}"
                                    BorderBrush="{DynamicResource ButtonDangerBrush}"
                                    Style="{StaticResource ManualCommandButton}">
                                <StackPanel>
                                    <Viewbox Width="42" Height="42" Margin="0,0,0,10">
                                        <Canvas Width="48" Height="48">
                                            <Rectangle Canvas.Left="12" Canvas.Top="12" Width="24" Height="24"
                                                       Stroke="{DynamicResource TextPrimaryBrush}" StrokeThickness="4" Fill="Transparent" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="MOVE STOP"
                                               HorizontalAlignment="Center"
                                               FontSize="15"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>

                        <Grid Grid.Row="1"
                              Grid.Column="1"
                              Margin="0,20,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="52" />
                                <RowDefinition Height="52" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="145" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="SX Target Position"
                                       Style="{StaticResource ManualSmallText}"
                                       FontSize="14" />
                            <TextBox Grid.Column="1"
                                     Text="{Binding CurrentScreen.Manual.SelectedHeadItems[1].Value}"
                                     Style="{StaticResource ManualInput}" />
                            <TextBlock Grid.Row="1"
                                       Text="SY Target Position"
                                       Style="{StaticResource ManualSmallText}"
                                       FontSize="14" />
                            <TextBox Grid.Row="1"
                                     Grid.Column="1"
                                     Text="{Binding CurrentScreen.Manual.SelectedHeadItems[2].Value}"
                                     Style="{StaticResource ManualInput}" />
                        </Grid>
                    </Grid>

                    <Border Grid.Row="2" Background="{DynamicResource PanelBorderBrush}" />

                    <TextBlock Grid.Row="3"
                               Text="Shape Scan"
                               Style="{StaticResource ManualValueText}"
                               Margin="0,20,0,12" />

                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="72" />
                            <RowDefinition Height="116" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="172" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Margin="0,0,14,0">
                                <TextBlock Text="Shape Size" Style="{StaticResource ManualSmallText}" Margin="0,0,0,6" />
                                <TextBox Text="10.000" Style="{StaticResource ManualInput}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,14,0">
                                <TextBlock Text="Offset X" Style="{StaticResource ManualSmallText}" Margin="0,0,0,6" />
                                <TextBox Text="0.000" Style="{StaticResource ManualInput}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,14,0">
                                <TextBlock Text="Offset Y" Style="{StaticResource ManualSmallText}" Margin="0,0,0,6" />
                                <TextBox Text="0.000" Style="{StaticResource ManualInput}" />
                            </StackPanel>
                            <StackPanel Grid.Column="3">
                                <TextBlock Text="Direction" Style="{StaticResource ManualSmallText}" Margin="0,0,0,6" />
                                <ComboBox Style="{StaticResource ManualComboBox}"
                                          SelectedIndex="0">
                                    <ComboBoxItem Content="CW" />
                                    <ComboBoxItem Content="CCW" />
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <UniformGrid Grid.Row="1"
                                     Columns="6"
                                     Margin="0,12,0,0">
                            <Button Style="{StaticResource ManualCommandButton}" Background="{DynamicResource ButtonSecondaryBrush}" BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}" Margin="0,0,10,0">
                                <StackPanel>
                                    <Viewbox Width="42" Height="38" Margin="0,0,0,8">
                                        <Canvas Width="48" Height="40">
                                            <Ellipse Canvas.Left="21" Canvas.Top="17" Width="6" Height="6" Fill="{DynamicResource TextSecondaryBrush}" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="DOT" HorizontalAlignment="Center" FontSize="15" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ManualCommandButton}" Background="{DynamicResource ButtonSecondaryBrush}" BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}" Margin="0,0,10,0">
                                <StackPanel>
                                    <Viewbox Width="42" Height="38" Margin="0,0,0,8">
                                        <Canvas Width="48" Height="40">
                                            <Line X1="24" Y1="6" X2="24" Y2="34" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" />
                                            <Line X1="10" Y1="20" X2="38" Y2="20" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" />
                                            <Ellipse Canvas.Left="21" Canvas.Top="17" Width="6" Height="6" Fill="{DynamicResource TextSecondaryBrush}" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="CROSS" HorizontalAlignment="Center" FontSize="15" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ManualCommandButton}" Background="{DynamicResource ButtonPrimaryBrush}" BorderBrush="{DynamicResource ButtonPrimaryBorderBrush}" Margin="0,0,10,0">
                                <StackPanel>
                                    <Viewbox Width="42" Height="38" Margin="0,0,0,8">
                                        <Canvas Width="48" Height="40">
                                            <Ellipse Canvas.Left="10" Canvas.Top="3" Width="28" Height="28"
                                                     Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" Fill="Transparent" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="CIRCLE" HorizontalAlignment="Center" FontSize="15" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ManualCommandButton}" Background="{DynamicResource ButtonSecondaryBrush}" BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}" Margin="0,0,10,0">
                                <StackPanel>
                                    <Viewbox Width="42" Height="38" Margin="0,0,0,8">
                                        <Canvas Width="48" Height="40">
                                            <Rectangle Canvas.Left="10" Canvas.Top="8" Width="28" Height="18"
                                                       Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" Fill="Transparent" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="RECT" HorizontalAlignment="Center" FontSize="15" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ManualCommandButton}" Background="{DynamicResource ButtonSecondaryBrush}" BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}" Margin="0,0,10,0">
                                <StackPanel>
                                    <Viewbox Width="42" Height="38" Margin="0,0,0,8">
                                        <Canvas Width="48" Height="40">
                                            <Line X1="9" Y1="20" X2="39" Y2="20" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="H-LINE" HorizontalAlignment="Center" FontSize="15" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource ManualCommandButton}" Background="{DynamicResource ButtonSecondaryBrush}" BorderBrush="{DynamicResource ButtonSecondaryBorderBrush}">
                                <StackPanel>
                                    <Viewbox Width="42" Height="38" Margin="0,0,0,8">
                                        <Canvas Width="48" Height="40">
                                            <Line X1="24" Y1="5" X2="24" Y2="35" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="V-LINE" HorizontalAlignment="Center" FontSize="15" />
                                </StackPanel>
                            </Button>
                        </UniformGrid>

                        <Grid Grid.Row="2" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Height="112"
                                    Background="{DynamicResource ButtonSuccessBrush}"
                                    BorderBrush="{DynamicResource StatusReadyBrush}"
                                    Style="{StaticResource ManualCommandButton}"
                                    Margin="0,0,14,0">
                                <StackPanel>
                                    <Viewbox Width="44" Height="38" Margin="0,0,0,8">
                                        <Canvas Width="48" Height="40">
                                            <Polygon Points="15,7 15,33 36,20" Fill="{DynamicResource TextSecondaryBrush}" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="START"
                                               HorizontalAlignment="Center"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1"
                                    Height="112"
                                    Background="{DynamicResource ButtonDangerBrush}"
                                    BorderBrush="{DynamicResource ButtonDangerBorderBrush}"
                                    Style="{StaticResource ManualCommandButton}">
                                <StackPanel>
                                    <Viewbox Width="44" Height="38" Margin="0,0,0,8">
                                        <Canvas Width="48" Height="40">
                                            <Rectangle Canvas.Left="14" Canvas.Top="10" Width="20" Height="20"
                                                       Fill="{DynamicResource TextSecondaryBrush}" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Text="STOP"
                                               HorizontalAlignment="Center"
                                               FontSize="18"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource PanelBorder}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="260" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="{Binding CurrentScreen.Manual.SelectedHead, StringFormat=Laser Action ({0})}"
                               Style="{StaticResource PanelTitle}" />

                    <StackPanel Grid.Row="1"
                                Margin="0,8,0,12">
                        <Button Background="{DynamicResource ButtonSuccessBrush}"
                                BorderBrush="{DynamicResource StatusReadyBrush}"
                                Style="{StaticResource LaserActionButton}"
                                Margin="0,0,0,10">
                            <Grid Width="230">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="62" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="44" Height="44" HorizontalAlignment="Center">
                                    <Canvas Width="48" Height="48">
                                        <Line X1="24" Y1="5" X2="24" Y2="43" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" />
                                        <Line X1="5" Y1="24" X2="43" Y2="24" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" />
                                        <Line X1="10" Y1="10" X2="38" Y2="38" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="2" />
                                        <Line X1="38" Y1="10" X2="10" Y2="38" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="2" />
                                        <Ellipse Canvas.Left="20" Canvas.Top="20" Width="8" Height="8" Fill="{DynamicResource TextSecondaryBrush}" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1"
                                           Text="LASER ON"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                        <Button Background="{DynamicResource ButtonSecondaryBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                Style="{StaticResource LaserActionButton}"
                                Margin="0,0,0,10">
                            <Grid Width="230">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="62" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="44" Height="44" HorizontalAlignment="Center">
                                    <Canvas Width="48" Height="48">
                                        <Line X1="24" Y1="5" X2="24" Y2="43" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" />
                                        <Line X1="5" Y1="24" X2="43" Y2="24" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" />
                                        <Line X1="10" Y1="10" X2="38" Y2="38" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="2" />
                                        <Line X1="38" Y1="10" X2="10" Y2="38" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="2" />
                                        <Line X1="7" Y1="41" X2="41" Y2="7" Stroke="{DynamicResource ButtonDangerBorderBrush}" StrokeThickness="3" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1"
                                           Text="LASER OFF"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                        <Button Background="{DynamicResource ButtonPrimaryBrush}"
                                BorderBrush="{DynamicResource ButtonPrimaryBorderBrush}"
                                Style="{StaticResource LaserActionButton}">
                            <Grid Width="230">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="62" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Viewbox Width="44" Height="44" HorizontalAlignment="Center">
                                    <Canvas Width="48" Height="48">
                                        <Ellipse Canvas.Left="12" Canvas.Top="12" Width="24" Height="24"
                                                 Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" Fill="Transparent" />
                                        <Ellipse Canvas.Left="21" Canvas.Top="21" Width="6" Height="6"
                                                 Fill="{DynamicResource TextSecondaryBrush}" />
                                        <Line X1="24" Y1="4" X2="24" Y2="44" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" />
                                        <Line X1="4" Y1="24" X2="44" Y2="24" Stroke="{DynamicResource TextSecondaryBrush}" StrokeThickness="3" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Grid.Column="1"
                                           Text="CENTER ON"
                                           FontSize="19"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                            </Grid>
                        </Button>
                    </StackPanel>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding CurrentScreen.Manual.CommandStateRows}"
                              IsReadOnly="True"
                              Style="{StaticResource PlainDataGrid}"
                              FontSize="13">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Item" Binding="{Binding Name}" Width="170" />
                            <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="*" />
                            <DataGridTextColumn Header="Unit" Binding="{Binding Unit}" Width="72" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>


