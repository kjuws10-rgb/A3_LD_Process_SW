<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:Drilling.UI.Views"
        mc:Ignorable="d"
        Title="Laser Drilling"
        Width="1920"
        Height="1080"
        MinWidth="1500"
        MinHeight="820"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="HeaderStatusNavButton" TargetType="Button">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{DynamicResource ButtonSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HeaderNavHoverBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource MenuItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HeaderNavPressedBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemeToggleButton" TargetType="Button">
            <Setter Property="MinWidth" Value="84" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="{DynamicResource ButtonSecondaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ButtonSecondaryBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HeaderNavHoverBackgroundBrush}" />
                                <Setter Property="BorderBrush" Value="{DynamicResource MenuItemSelectedBorderBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="{DynamicResource HeaderNavPressedBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource ShellBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="88" />
            <RowDefinition Height="*" />
            <RowDefinition Height="34" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource HeaderBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="300" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="190" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Laser Drilling"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="30"
                               FontWeight="SemiBold" />
                    <TextBlock Text="SYS &amp; J / Drilling"
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="15" />
                </StackPanel>

                <ItemsControl Grid.Column="1"
                              ItemsSource="{Binding HeaderStatusItems}"
                              Margin="10,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4,2"
                                    Padding="8,5,8,0"
                                    Background="{DynamicResource HeaderCardBackgroundBrush}"
                                    BorderBrush="{DynamicResource HeaderCardBorderBrush}"
                                    BorderThickness="1">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding Open}" />
                                </Border.InputBindings>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="4" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               TextWrapping="NoWrap" />
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Value}"
                                               Margin="0,2,0,0"
                                               Foreground="{Binding ValueBrush}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextWrapping="NoWrap" />
                                    <Grid Grid.Row="2"
                                          Margin="0,2,0,0"
                                          Visibility="{Binding CanNavigate, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="22" />
                                        </Grid.ColumnDefinitions>

                                        <Button Style="{StaticResource HeaderStatusNavButton}"
                                                Command="{Binding Previous}"
                                                Content="&lt;" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding PageText}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="10"
                                                   FontWeight="SemiBold" />
                                        <Button Grid.Column="2"
                                                Style="{StaticResource HeaderStatusNavButton}"
                                                Command="{Binding Next}"
                                                Content="&gt;" />
                                    </Grid>
                                    <Border Grid.Row="3"
                                            Background="{Binding AccentBrush}"
                                            Margin="-8,3,-8,0" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Grid.Column="2"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentDateText}"
                               HorizontalAlignment="Right"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="16" />
                    <TextBlock Text="{Binding CurrentTimeText}"
                               HorizontalAlignment="Right"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="15" />
                    <Button Content="{Binding ThemeToggleText}"
                            Command="{Binding ToggleThemeCommand}"
                            Style="{StaticResource ThemeToggleButton}"
                            HorizontalAlignment="Right"
                            Margin="0,2,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource SideBarBackgroundBrush}"
                    BorderBrush="{DynamicResource HeaderBorderBrush}"
                    BorderThickness="0,0,1,0"
                    Padding="12,12,12,18">
                <DockPanel>
                    <Border DockPanel.Dock="Bottom"
                            Height="84"
                            Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource PanelBorderBrush}"
                            BorderThickness="1"
                            Padding="12"
                            Margin="0,14,0,0">
                        <StackPanel>
                            <TextBlock Text="SIM MODE"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Device-free"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="12" />
                            <TextBlock Text="UI + Logic"
                                       Foreground="{DynamicResource TextMutedBrush}"
                                       FontSize="12" />
                        </StackPanel>
                    </Border>

                    <ListBox ItemsSource="{Binding Menus}"
                             SelectedItem="{Binding SelectedMenu}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,9" />
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource MenuItemSelectedBackgroundBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource MenuItemSelectedTextBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Height="64"
                                        Padding="0"
                                        Background="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Background}"
                                        BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderBrush" Value="{DynamicResource PanelBorderBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource MenuItemSelectedBorderBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4" />
                                            <ColumnDefinition Width="36" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border>
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource MenuAccentBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <Viewbox Width="22"
                                                 Height="22"
                                                 Grid.Column="1"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 Margin="11,0,0,0">
                                            <Path Data="{Binding IconGeometry}"
                                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                                  StrokeThickness="1.9"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round"
                                                  Fill="Transparent" />
                                        </Viewbox>
                                        <StackPanel Grid.Column="2"
                                                    Margin="10,0,0,0"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=Foreground}"
                                                       FontSize="14"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="11">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource MenuItemSelectedTextBrush}" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1" Margin="14,12,14,12">
                <views:CMainView Visibility="{Binding CurrentScreen.IsMainLayout, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <views:CManualView Visibility="{Binding CurrentScreen.IsManualLayout, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <views:CRecipeView Visibility="{Binding CurrentScreen.IsRecipeLayout, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <views:CSettingView Visibility="{Binding CurrentScreen.IsSettingLayout, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <views:CAlarmView Visibility="{Binding CurrentScreen.IsAlarmLayout, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <views:CMonitorView Visibility="{Binding CurrentScreen.IsMonitorLayout, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <views:CReviewView Visibility="{Binding CurrentScreen.IsReviewLayout, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <views:CCorrectionView Visibility="{Binding CurrentScreen.IsCorrectionLayout, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <views:CPmView Visibility="{Binding CurrentScreen.IsPmLayout, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <views:CExitView Visibility="{Binding CurrentScreen.IsGenericLayout, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </Grid>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource FooterBackgroundBrush}"
                BorderBrush="{DynamicResource HeaderBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="18,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="16" Height="16" Fill="{DynamicResource StatusReadyBrush}" />
                    <TextBlock Text="Ready"
                               Margin="10,0,0,0"
                               Foreground="{DynamicResource StatusReadyBrush}"
                               FontSize="15"
                               FontWeight="SemiBold" />
                </StackPanel>

                <ItemsControl Grid.Column="1"
                              ItemsSource="{Binding FooterStatusItems}"
                              VerticalAlignment="Center"
                              Margin="20,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Value}"
                                       Foreground="{Binding AccentBrush}"
                                       FontSize="14"
                                       FontWeight="SemiBold" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Grid.Column="2"
                           Text="X 123.590     Y 21.484     Theta 0.002     |     Script PASS     |     User: Engineer"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="13" />
            </Grid>
        </Border>
    </Grid>
</Window>
